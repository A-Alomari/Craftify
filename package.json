{
  "name": "craftify",
  "version": "1.0.0",
  "description": "E-commerce platform for local artisans",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeds/seed.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles --verbose",
    "test:coverage": "jest --runInBand --coverage",
    "test:controllers": "jest --runInBand tests/controllers.suite.js",
    "test:models": "jest --runInBand tests/models.suite.js",
    "test:views": "jest --runInBand tests/views.suite.js"
  },
  "keywords": [
    "e-commerce",
    "artisan",
    "marketplace"
  ],
  "author": "ITCS489 Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.7.4",
    "sql.js": "^1.10.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2"
  }
}
