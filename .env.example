# Craftify Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# Session (REQUIRED in production - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=your-super-secret-session-key-change-this

# Application URL (used in password reset emails)
APP_URL=http://localhost:3000

# Email Configuration (for password reset and notifications)
# For development, use Ethereal: https://ethereal.email/create
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=Craftify <noreply@craftify.com>

# Database (optional - defaults to craftify.db in project root)
# CRAFTIFY_DB_PATH=./craftify.db

# Persistent paths (recommended for Railway volume mounting)
# UPLOAD_DIR=./public/uploads
# SESSION_STORE_PATH=./.sessions
