<%- include('../partials/header', { title: title }) %>

<main class="flex-grow flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-[480px] bg-surface-container-lowest rounded-xl shadow-[0px_20px_40px_rgba(25,28,30,0.06)] overflow-hidden z-10 relative">
    <div class="pt-10 pb-6 flex flex-col items-center">
      <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mb-6">
        <span class="material-symbols-outlined text-on-primary text-3xl">key</span>
      </div>
    </div>
    <div class="px-8 pb-10 pt-4">
      <header class="text-center mb-8">
        <h1 class="font-headline text-3xl font-bold text-on-surface mb-2 tracking-tight">Reset Password</h1>
        <p class="text-secondary font-body text-sm">Create a new secure password</p>
      </header>
      <form class="space-y-5" action="/auth/reset-password/<%= token %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="space-y-1.5">
          <label class="text-[10px] font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1" for="password">New Password</label>
          <div class="relative group">
            <input name="password" id="password" required minlength="6" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-highest transition-colors placeholder:text-outline/50 text-on-surface" placeholder="Create a password" type="password"/>
            <div class="absolute left-0 top-1/4 bottom-1/4 w-0.5 bg-primary opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="text-[10px] font-label font-bold uppercase tracking-widest text-on-surface-variant ml-1" for="confirm_password">Confirm Password</label>
          <div class="relative group">
            <input name="confirm_password" id="confirm_password" required minlength="6" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl focus:ring-0 focus:bg-surface-container-highest transition-colors placeholder:text-outline/50 text-on-surface" placeholder="Confirm your password" type="password"/>
            <div class="absolute left-0 top-1/4 bottom-1/4 w-0.5 bg-primary opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
          </div>
        </div>
        <div class="pt-4">
          <button class="w-full bg-primary-container text-on-primary-container font-label font-bold uppercase tracking-widest py-4 rounded-xl shadow-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center space-x-2" type="submit">
            <span>Reset Password</span>
            <span class="material-symbols-outlined text-sm">lock_reset</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
