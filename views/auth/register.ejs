<%- include('../partials/header', { title: 'Create Account | Craftify' }) %>

<main class="relative flex-grow px-4 py-12 md:py-20 overflow-hidden">
    <div class="pointer-events-none absolute -top-28 -left-24 w-96 h-96 rounded-full bg-primary-container/25 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-28 -right-24 w-96 h-96 rounded-full bg-tertiary-container/20 blur-3xl"></div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        <!-- Left branding panel -->
        <section class="hidden lg:flex lg:col-span-5 rounded-3xl bg-surface-container-low p-8 md:p-10 flex-col justify-between">
            <div>
                <p class="font-label text-xs uppercase tracking-[0.2em] text-secondary">The Digital Atelier</p>
                <h1 class="font-headline text-4xl mt-3 leading-tight">Join the Craftify Community</h1>
                <p class="text-secondary mt-4">Create your account to discover unique handmade items, track orders, and connect with artisans worldwide.</p>
            </div>

            <div class="mt-8 space-y-4 text-sm text-on-surface">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">favorite</span>
                    Save pieces to your wishlist
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">local_shipping</span>
                    Track orders and deliveries
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">gavel</span>
                    Bid on exclusive artisan auctions
                </div>
            </div>
        </section>

        <!-- Right form panel -->
        <section class="lg:col-span-7 bg-surface-container-lowest rounded-3xl p-8 md:p-10 shadow-sm">
            <div class="flex items-center justify-between border-b border-outline-variant/10 pb-4 mb-8">
                <a href="/auth/login" class="text-sm font-semibold uppercase tracking-wider text-secondary hover:text-on-surface transition-colors">Sign In</a>
                <a href="/auth/register" class="text-sm font-semibold uppercase tracking-wider text-primary border-b-2 border-primary-container pb-2">Create Account</a>
            </div>

            <form class="space-y-5" action="/auth/register" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="role" value="customer">

                <!-- Full Name -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2">Full Name</label>
                    <input name="name" required class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none" placeholder="John Doe" type="text"/>
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2">Email Address</label>
                    <input name="email" required class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none" placeholder="you@example.com" type="email"/>
                </div>

                <!-- Password grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2">Password</label>
                        <input name="password" required class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface transition-all outline-none" placeholder="Create a password" type="password"/>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2">Confirm Password</label>
                        <input name="confirm_password" required class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface transition-all outline-none" placeholder="Confirm your password" type="password"/>
                    </div>
                </div>

                <!-- Terms -->
                <div class="flex items-start gap-3 pt-1">
                    <input required class="h-5 w-5 mt-0.5 rounded border-outline-variant text-primary focus:ring-primary/20 bg-surface-container-low" id="terms" name="terms" type="checkbox"/>
                    <label class="text-sm text-secondary leading-tight" for="terms">
                        I agree to the <a class="text-on-surface underline underline-offset-4 hover:text-primary transition-colors" href="/terms">Terms of Service</a> and <a class="text-on-surface underline underline-offset-4 hover:text-primary transition-colors" href="/privacy">Privacy Policy</a>
                    </label>
                </div>

                <!-- Submit -->
                <button class="w-full bg-primary-container text-on-primary-container font-bold py-3.5 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all shadow-sm" type="submit">
                    Create Account
                </button>
            </form>

            <p class="mt-6 text-sm text-on-surface-variant">
                Are you an artisan?
                <a class="font-bold text-primary hover:underline underline-offset-4 ml-1" href="/auth/artisan-register">Register as Seller</a>
            </p>
        </section>
    </div>
</main>

<%- include('../partials/footer') %>
