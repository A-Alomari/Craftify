<%- include('../partials/header', { title: 'Sign In | Craftify' }) %>

<main class="relative flex-grow px-4 py-12 md:py-20 overflow-hidden">
    <div class="pointer-events-none absolute -top-28 -left-24 w-96 h-96 rounded-full bg-primary-container/25 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-28 -right-24 w-96 h-96 rounded-full bg-tertiary-container/20 blur-3xl"></div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        <section class="lg:col-span-5 rounded-3xl bg-surface-container-low p-8 md:p-10 flex flex-col justify-between">
            <div>
                <p class="font-label text-xs uppercase tracking-[0.2em] text-secondary">The Digital Atelier</p>
                <h1 class="font-headline text-4xl mt-3 leading-tight">Welcome Back To Craftify</h1>
                <p class="text-secondary mt-4">Sign in to continue your orders, bids, wishlists, and conversations with artisans.</p>
            </div>

            <div class="mt-8 space-y-4 text-sm text-on-surface">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">verified_user</span>
                    Secure account access
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">chat</span>
                    Continue messages with sellers
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">gavel</span>
                    Track your bids and auctions
                </div>
            </div>
        </section>

        <section class="lg:col-span-7 bg-surface-container-lowest rounded-3xl p-8 md:p-10 shadow-sm">
            <div class="flex items-center justify-between border-b border-outline-variant/10 pb-4 mb-8">
                <a href="/auth/login" class="text-sm font-semibold uppercase tracking-wider text-primary border-b-2 border-primary-container pb-2">Sign In</a>
                <a href="/auth/register" class="text-sm font-semibold uppercase tracking-wider text-secondary hover:text-on-surface transition-colors">Create Account</a>
            </div>

            <form action="/auth/login" class="space-y-6" method="POST" data-validate="true">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2" for="identifier">Email or Phone Number</label>
                    <input
                        class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none"
                        id="identifier"
                        name="identifier"
                        placeholder="you@example.com or +973 3XXX XXXX"
                        type="text"
                        data-validate="required"
                        required
                    />
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2" for="password">Password</label>
                    <input class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface transition-all outline-none" id="password" name="password" type="password" placeholder="••••••••" data-validate="required" required/>
                </div>

                <div class="flex items-center justify-between">
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary-container" name="remember" type="checkbox"/>
                        <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">Remember me</span>
                    </label>
                    <a class="text-sm font-semibold text-primary hover:text-on-primary-fixed-variant transition-colors" href="/auth/forgot-password">Forgot password?</a>
                </div>

                <button class="w-full bg-primary-container text-on-primary-container font-bold py-3.5 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all shadow-sm" type="submit">
                    Sign In
                </button>
            </form>

            <p class="mt-8 text-sm text-on-surface-variant">
                New to Craftify?
                <a class="font-bold text-primary hover:underline underline-offset-4 ml-1" href="/auth/register">Create your account</a>
            </p>
        </section>
    </div>
</main>

<%- include('../partials/footer') %>
