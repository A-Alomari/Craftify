<%- include('../partials/header', { title: 'Sign In | Craftify' }) %>

<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center px-4 py-12 md:py-20">
<div class="w-full max-w-md">
<!-- Centered Branding Header -->
<div class="text-center mb-8">
<div class="inline-flex items-center justify-center w-16 h-16 bg-primary rounded-full mb-4 shadow-sm">
<span class="text-on-primary font-serif text-3xl font-bold italic leading-none">A</span>
</div>
<h1 class="text-on-surface text-3xl font-bold tracking-tight mb-2">Welcome back</h1>
<p class="text-on-surface-variant font-body text-sm">Sign in to your account to continue shopping</p>
</div>
<!-- Login Card -->
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/10 overflow-hidden">
<!-- Tab Navigation -->
<div class="flex border-b border-outline-variant/10">
<a href="/auth/login" class="flex-1 py-4 text-center text-sm font-semibold text-primary border-b-2 border-primary-container">
    Sign In
</a>
<a href="/auth/register" class="flex-1 py-4 text-center text-sm font-medium text-on-surface-variant hover:text-on-surface transition-colors">
    Create Account
</a>
</div>
<div class="p-8">
<form action="/auth/login" class="space-y-6" method="POST">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<!-- Email Field -->
<div>
<label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2" for="email">Email Address</label>
<input class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface placeholder:text-on-surface-variant/50 transition-all outline-none" id="email" name="email" placeholder="you@example.com" type="email" required/>
</div>
<!-- Password Field -->
<div>
<label class="block text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-2" for="password">Password</label>
<div class="relative">
<input class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary-container/50 text-on-surface transition-all outline-none" id="password" name="password" type="password" placeholder="••••••••" required/>
</div>
</div>
<!-- Utilities Row -->
<div class="flex items-center justify-between">
<label class="flex items-center space-x-2 cursor-pointer group">
<input class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary-container" name="remember" type="checkbox"/>
<span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">Remember me</span>
</label>
<a class="text-sm font-semibold text-primary hover:text-on-primary-fixed-variant transition-colors" href="/auth/forgot-password">Forgot password?</a>
</div>
<!-- Primary CTA -->
<button class="w-full bg-primary-container text-on-primary-container font-bold py-3.5 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all shadow-sm" type="submit">
    Sign In
</button>
</form>

<!-- Divider -->
<div class="relative my-8 text-center">
<div aria-hidden="true" class="absolute inset-0 flex items-center">
<div class="w-full border-t border-outline-variant/20"></div>
</div>
<span class="relative px-4 bg-surface-container-lowest text-xs font-bold uppercase tracking-widest text-on-surface-variant/60">Or</span>
</div>
<!-- Footer Link -->
<div class="mt-8 text-center">
<p class="text-sm text-on-surface-variant">
    Don't have an account? 
    <a class="font-bold text-primary hover:underline underline-offset-4 ml-1" href="/auth/register">Create one</a>
</p>
</div>
</div>
</div>
</div>
</main>

<%- include('../partials/footer') %>
