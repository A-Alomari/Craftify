<%- include('../partials/header', { title: title }) %>

<main class="flex-grow min-h-screen">

<%
  const artisanList = Array.isArray(artisans) ? artisans : [];
  
  const formatRating = function(value) {
    return Number(value || 0).toFixed(1);
  };
  
  const renderStars = function(rating) {
    const safeRating = Number(rating || 0);
    const stars = [];
    for (let i = 1; i <= 5; i += 1) {
      if (safeRating >= i) {
        stars.push('star');
      } else if (safeRating >= i - 0.5) {
        stars.push('star_half');
      } else {
        stars.push('star');
      }
    }
    return stars;
  };
%>

<section class="max-w-7xl mx-auto px-6 py-12">
  <!-- Header -->
  <div class="text-center mb-12">
    <span class="text-xs uppercase tracking-[0.2em] text-primary font-bold">Artisan Directory</span>
    <h1 class="font-headline text-4xl md:text-5xl font-bold text-on-surface mt-3 mb-4">
      Meet Our Artisans
    </h1>
    <p class="text-secondary text-lg max-w-2xl mx-auto">
      Discover talented creators from around the world. Each artisan brings unique skills and passion to their handcrafted creations.
    </p>
  </div>

  <!-- Artisan Grid -->
  <% if (artisanList.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% artisanList.forEach(function(artisan) { %>
        <article class="bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all group">
          <!-- Profile Header -->
          <div class="relative h-40 bg-gradient-to-br from-primary-container to-secondary-container">
            <% if (artisan.is_featured) { %>
              <div class="absolute top-4 right-4 bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                Featured
              </div>
            <% } %>
          </div>
          
          <!-- Profile Image -->
          <div class="px-6 -mt-16 relative z-10">
            <div class="w-28 h-28 rounded-full border-4 border-surface-container-lowest overflow-hidden bg-surface-container-low">
              <img 
                src="<%= artisan.profile_image || '/images/default-avatar.png' %>" 
                alt="<%= artisan.shop_name || artisan.name %>"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                onerror="this.src='/images/default-avatar.png'"
              >
            </div>
          </div>

          <!-- Profile Info -->
          <div class="px-6 pb-6 pt-3">
            <h3 class="font-headline text-xl font-bold text-on-surface mb-1">
              <%= artisan.shop_name || artisan.name %>
            </h3>
            
            <% if (artisan.avg_rating && artisan.review_count > 0) { %>
              <div class="flex items-center gap-2 mb-3">
                <div class="flex items-center">
                  <% renderStars(artisan.avg_rating).forEach(function(star) { %>
                    <span class="material-symbols-outlined text-amber-500 text-sm <%= star === 'star' ? '' : 'filled-icon' %>"><%= star %></span>
                  <% }) %>
                </div>
                <span class="text-xs text-secondary">
                  <%= formatRating(artisan.avg_rating) %> (<%= artisan.review_count %> review<%= artisan.review_count !== 1 ? 's' : '' %>)
                </span>
              </div>
            <% } %>

            <% if (artisan.bio) { %>
              <p class="text-sm text-secondary line-clamp-3 mb-4">
                <%= artisan.bio.substring(0, 120) %><%= artisan.bio.length > 120 ? '...' : '' %>
              </p>
            <% } %>

            <!-- Stats -->
            <div class="flex items-center gap-4 mb-4 text-xs text-secondary">
              <div class="flex items-center gap-1">
                <span class="material-symbols-outlined text-base">inventory_2</span>
                <span><%= artisan.product_count %> product<%= artisan.product_count !== 1 ? 's' : '' %></span>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-2">
              <a 
                href="/user/artisan/<%= artisan.id %>" 
                class="flex-1 bg-primary-container text-on-primary-container text-center font-semibold px-4 py-2.5 rounded-xl hover:opacity-90 transition-all text-sm"
              >
                View Shop
              </a>
              <% if (user) { %>
                <a 
                  href="/user/messages/<%= artisan.id %>" 
                  class="p-2.5 border border-outline-variant text-on-surface rounded-xl hover:bg-surface-container-low transition-all"
                  aria-label="Message artisan"
                >
                  <span class="material-symbols-outlined text-lg">chat</span>
                </a>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="text-center py-20">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-surface-container-low rounded-full mb-6">
        <span class="material-symbols-outlined text-4xl text-secondary">store</span>
      </div>
      <h3 class="font-headline text-2xl font-bold text-on-surface mb-2">No Artisans Found</h3>
      <p class="text-secondary mb-6">Check back soon to discover talented creators.</p>
      <a href="/" class="inline-block bg-primary-container text-on-primary-container font-semibold px-6 py-3 rounded-xl hover:opacity-90 transition-all">
        Back to Home
      </a>
    </div>
  <% } %>

  <!-- Call to Action -->
  <div class="mt-16 bg-gradient-to-br from-primary-container/20 to-secondary-container/20 rounded-2xl p-10 text-center">
    <h2 class="font-headline text-2xl font-bold text-on-surface mb-3">
      Are You an Artisan?
    </h2>
    <p class="text-secondary mb-6 max-w-xl mx-auto">
      Join our community of talented creators. Share your handcrafted products with customers who value quality and craftsmanship.
    </p>
    <a 
      href="/auth/artisan-register" 
      class="inline-block bg-primary-container text-on-primary-container font-bold px-8 py-3 rounded-xl hover:opacity-90 transition-all"
    >
      Become an Artisan
    </a>
  </div>
</section>

</main>

<%- include('../partials/footer') %>
