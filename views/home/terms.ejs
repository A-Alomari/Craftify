<%- include('../partials/header', { title: title }) %>
<main class="pt-12 pb-20 px-6 max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-2 block">Legal</span>
    <h1 class="text-5xl font-headline font-bold text-on-surface leading-tight">Terms of Service</h1>
    <p class="text-secondary mt-4 font-body">Last updated: 2024</p>
  </div>

  <!-- Terms Content -->
  <div class="bg-surface-container-lowest rounded-xl p-8 md:p-12 space-y-10">
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">1. Acceptance</h2>
      <p class="text-secondary font-body leading-relaxed">By using Craftify, you agree to these terms. This is a university project demonstration.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">2. Accounts</h2>
      <p class="text-secondary font-body leading-relaxed">Users must provide accurate information when registering. You are responsible for maintaining the security of your account.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">3. Products & Sales</h2>
      <p class="text-secondary font-body leading-relaxed">Artisans are responsible for the accuracy of their product listings. All prices are in USD and include applicable taxes.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">4. Auctions</h2>
      <p class="text-secondary font-body leading-relaxed">Bids placed on auctions are binding. The highest bidder at auction close wins the item. Reserve prices may apply.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">5. Payments</h2>
      <p class="text-secondary font-body leading-relaxed">All payments are simulated in this demo. No real financial transactions are processed.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">6. Disclaimer</h2>
      <p class="text-secondary font-body leading-relaxed">Craftify is a university project. It is provided "as is" for educational purposes only.</p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
