<%- include('../partials/header', { title: title }) %>
<main class="pt-12 pb-20 px-6 max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-2 block">Support</span>
    <h1 class="text-4xl font-headline font-bold text-on-surface">Frequently Asked Questions</h1>
    <p class="text-secondary mt-3 font-body leading-relaxed">Everything you need to know about shopping on Craftify.</p>
  </div>

  <!-- FAQ Accordion -->
  <div class="space-y-4">
    <!-- FAQ 1 -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-6 text-left hover:bg-surface-container-low transition-colors">
        <span class="font-headline text-lg font-bold text-on-surface">How do I place an order?</span>
        <span class="material-symbols-outlined text-secondary transition-transform duration-300">expand_more</span>
      </button>
      <div class="hidden px-6 pb-6">
        <p class="text-secondary font-body leading-relaxed">Browse products, add items to your cart, and proceed to checkout. You'll need an account to complete your purchase.</p>
      </div>
    </div>

    <!-- FAQ 2 -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-6 text-left hover:bg-surface-container-low transition-colors">
        <span class="font-headline text-lg font-bold text-on-surface">How do auctions work?</span>
        <span class="material-symbols-outlined text-secondary transition-transform duration-300">expand_more</span>
      </button>
      <div class="hidden px-6 pb-6">
        <p class="text-secondary font-body leading-relaxed">Our live auctions allow you to bid on exclusive artisan pieces in real-time. The highest bidder when the auction ends wins the item.</p>
      </div>
    </div>

    <!-- FAQ 3 -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-6 text-left hover:bg-surface-container-low transition-colors">
        <span class="font-headline text-lg font-bold text-on-surface">How do I become a seller?</span>
        <span class="material-symbols-outlined text-secondary transition-transform duration-300">expand_more</span>
      </button>
      <div class="hidden px-6 pb-6">
        <p class="text-secondary font-body leading-relaxed">Register as an artisan, submit your shop details, and wait for admin approval. Once approved, you can start listing products.</p>
      </div>
    </div>

    <!-- FAQ 4 -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-6 text-left hover:bg-surface-container-low transition-colors">
        <span class="font-headline text-lg font-bold text-on-surface">What payment methods do you accept?</span>
        <span class="material-symbols-outlined text-secondary transition-transform duration-300">expand_more</span>
      </button>
      <div class="hidden px-6 pb-6">
        <p class="text-secondary font-body leading-relaxed">We accept credit/debit cards and cash on delivery. All online payments are processed securely (simulated in this demo).</p>
      </div>
    </div>

    <!-- FAQ 5 -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden">
      <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180')" class="w-full flex items-center justify-between p-6 text-left hover:bg-surface-container-low transition-colors">
        <span class="font-headline text-lg font-bold text-on-surface">How do I track my order?</span>
        <span class="material-symbols-outlined text-secondary transition-transform duration-300">expand_more</span>
      </button>
      <div class="hidden px-6 pb-6">
        <p class="text-secondary font-body leading-relaxed">Go to "My Orders" in your account dashboard and click "Track" to see real-time shipment updates.</p>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="mt-16 text-center">
    <p class="text-secondary font-body mb-4">Still have questions?</p>
    <a href="/contact" class="inline-flex items-center gap-2 text-primary font-headline font-bold underline underline-offset-8 hover:opacity-80 transition-opacity">
      Contact our support team
      <span class="material-symbols-outlined text-sm">arrow_forward</span>
    </a>
  </div>
</main>
<%- include('../partials/footer') %>
