<%- include('../partials/header', { title: title }) %>
<main class="pt-12 pb-20 px-6 max-w-5xl mx-auto">
  <!-- Header -->
  <div class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-2 block">Get in Touch</span>
    <h1 class="text-5xl font-headline font-bold text-on-surface leading-tight">Contact Us</h1>
    <p class="text-secondary mt-4 text-lg font-body leading-relaxed">Have questions? We'd love to hear from you.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Contact Info -->
    <div class="space-y-6">
      <div class="bg-surface-container-lowest rounded-xl p-8">
        <h2 class="font-headline text-xl font-bold text-on-surface mb-6">Reach Out</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-container/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">mail</span>
            </div>
            <div>
              <p class="font-label text-xs uppercase tracking-widest text-secondary font-bold mb-1">Email</p>
              <p class="text-on-surface font-body">support@craftify.bh</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-container/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">phone</span>
            </div>
            <div>
              <p class="font-label text-xs uppercase tracking-widest text-secondary font-bold mb-1">Phone</p>
              <p class="text-on-surface font-body">+973 1700 0000</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-container/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl">location_on</span>
            </div>
            <div>
              <p class="font-label text-xs uppercase tracking-widest text-secondary font-bold mb-1">Address</p>
              <p class="text-on-surface font-body">University of Bahrain<br>Sakhir, Kingdom of Bahrain</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="bg-surface-container-lowest rounded-xl p-8">
      <h2 class="font-headline text-xl font-bold text-on-surface mb-6">Send us a message</h2>
      <form class="space-y-5" action="mailto:support@craftify.bh" method="GET">
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-2 ml-1">Your Name</label>
          <input type="text" name="name" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors text-on-surface placeholder:text-secondary/50" placeholder="John Doe" required/>
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-2 ml-1">Your Email</label>
          <input type="email" name="email" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors text-on-surface placeholder:text-secondary/50" placeholder="you@example.com" required/>
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-2 ml-1">Message</label>
          <textarea name="body" rows="4" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors text-on-surface placeholder:text-secondary/50 resize-none" placeholder="How can we help you?" required></textarea>
        </div>
        <button type="submit" class="w-full bg-primary-container text-on-primary-container font-bold py-4 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
          Send Message
          <span class="material-symbols-outlined text-sm">send</span>
        </button>
        <p class="text-xs text-secondary">This opens your email app addressed to support@craftify.bh.</p>
      </form>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
