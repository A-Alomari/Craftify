<%- include('../partials/header', { title: title }) %>
<div class="container py-5"><div class="row justify-content-center"><div class="col-lg-8">
  <h1>Contact Us</h1>
  <p class="lead">Have questions? We'd love to hear from you.</p>
  <div class="row mt-4">
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm border-0"><div class="card-body">
        <h5><i class="bi bi-envelope"></i> Email</h5><p>support@craftify.bh</p>
        <h5><i class="bi bi-telephone"></i> Phone</h5><p>+973 1700 0000</p>
        <h5><i class="bi bi-geo-alt"></i> Address</h5><p>University of Bahrain<br>Sakhir, Kingdom of Bahrain</p>
      </div></div>
    </div>
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm border-0"><div class="card-body">
        <h5>Send us a message</h5>
