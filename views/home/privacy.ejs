<%- include('../partials/header', { title: title }) %>
<main class="pt-12 pb-20 px-6 max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-2 block">Legal</span>
    <h1 class="text-5xl font-headline font-bold text-on-surface leading-tight">Privacy Policy</h1>
    <p class="text-secondary mt-4 font-body">Last updated: 2024</p>
  </div>

  <!-- Privacy Content -->
  <div class="bg-surface-container-lowest rounded-xl p-8 md:p-12 space-y-10">
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">1. Information We Collect</h2>
      <p class="text-secondary font-body leading-relaxed">We collect information you provide when registering, making purchases, or contacting us, including name, email, and shipping address.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">2. How We Use Information</h2>
      <p class="text-secondary font-body leading-relaxed">Your information is used to process orders, manage your account, and improve our services.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">3. Data Protection</h2>
      <p class="text-secondary font-body leading-relaxed">We implement appropriate security measures to protect your data. Passwords are hashed using bcrypt.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">4. Cookies</h2>
      <p class="text-secondary font-body leading-relaxed">We use session cookies to maintain your login state and shopping cart.</p>
    </div>
    <div>
      <h2 class="font-headline text-xl font-bold text-on-surface mb-3">5. Disclaimer</h2>
      <p class="text-secondary font-body leading-relaxed">This is a university project demo. No real personal data is processed in production.</p>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
