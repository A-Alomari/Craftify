<%- include('../partials/header', { title: title }) %>

<%
  const currentStatus = shipment ? shipment.status : (order ? order.status : 'pending');
  const normalizedStatus = String(currentStatus || 'pending').toLowerCase();

  // Determine each step's state: 'done', 'current', or 'pending'
  const isPending    = ['pending', 'confirmed'].includes(normalizedStatus);
  const isProcessing = normalizedStatus === 'processing';
  const isShipped    = ['shipped', 'in_transit'].includes(normalizedStatus);
  const isDelivered  = normalizedStatus === 'delivered';

  // Order Placed: always at least current (we have an order)
  const orderPlacedDone    = isProcessing || isShipped || isDelivered;
  const orderPlacedCurrent = isPending;

  // Processing step
  const processingDone    = isShipped || isDelivered;
  const processingCurrent = isProcessing;
  const processingReached = isProcessing || isShipped || isDelivered;

  // Shipped step
  const shippedDone    = isDelivered;
  const shippedCurrent = isShipped;
  const shippedReached = isShipped || isDelivered;

  // Delivered step
  const deliveredDone    = isDelivered;
  const deliveredCurrent = isDelivered;
  const deliveredReached = isDelivered;

  const history = (shipmentHistory || []).slice().reverse();

  const estimatedDate = shipment && shipment.estimated_delivery
    ? new Date(shipment.estimated_delivery)
    : new Date(order.created_at);
  if (!(shipment && shipment.estimated_delivery)) {
    estimatedDate.setDate(estimatedDate.getDate() + 7);
  }
%>

<main class="max-w-7xl mx-auto px-6 py-12 md:px-12">
  <div class="mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-on-surface mb-2">Track Your Order</h1>
    <p class="text-secondary font-medium tracking-tight">Order ID: <span class="text-on-surface">#ORD-<%= String(order.id).padStart(6, '0') %></span></p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    <div class="lg:col-span-8 space-y-12">
      <section class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/20 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider <%= order.payment_status === 'paid' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
            <%= order.payment_status || 'pending' %>
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant font-semibold mb-1">Order Date</p>
            <p class="text-lg font-headline font-semibold text-on-surface"><%= new Date(order.created_at).toLocaleDateString() %></p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant font-semibold mb-1">Delivery Estimate</p>
            <p class="text-lg font-headline font-semibold text-primary"><%= estimatedDate.toLocaleDateString() %></p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant font-semibold mb-1">Total Amount</p>
            <p class="text-lg font-headline font-semibold text-on-surface">$<%= Number(order.total_amount || 0).toFixed(2) %></p>
          </div>
        </div>
      </section>

      <section class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/20">
        <div class="flex items-center justify-between">
          <!-- Step 1: Order Placed -->
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 rounded-full <%= orderPlacedDone ? 'bg-emerald-500 text-white' : 'bg-amber-500 text-white' %> flex items-center justify-center mb-3">
              <span class="material-symbols-outlined text-xl"><%= orderPlacedDone ? 'check_circle' : 'receipt_long' %></span>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest <%= orderPlacedDone ? 'text-emerald-600' : 'text-amber-600' %>">Order Placed</p>
          </div>
          <div class="tracking-stepper-line <%= processingReached ? 'completed' : '' %> mx-2 md:mx-4"></div>

          <!-- Step 2: Processing -->
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 rounded-full <%= processingDone ? 'bg-emerald-500 text-white' : processingCurrent ? 'bg-amber-500 text-white' : 'bg-surface-container-high text-on-surface-variant' %> flex items-center justify-center mb-3">
              <span class="material-symbols-outlined text-xl"><%= processingDone ? 'sync_saved_locally' : processingCurrent ? 'sync_saved_locally' : 'schedule' %></span>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest <%= processingDone ? 'text-emerald-600' : processingCurrent ? 'text-amber-600' : 'text-on-surface-variant' %>">Processing</p>
          </div>
          <div class="tracking-stepper-line <%= shippedReached ? 'completed' : '' %> mx-2 md:mx-4"></div>

          <!-- Step 3: Shipped -->
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 rounded-full <%= shippedDone ? 'bg-emerald-500 text-white' : shippedCurrent ? 'bg-amber-500 text-white' : 'bg-surface-container-high text-on-surface-variant' %> flex items-center justify-center mb-3">
              <span class="material-symbols-outlined text-xl">local_shipping</span>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest <%= shippedDone ? 'text-emerald-600' : shippedCurrent ? 'text-amber-600' : 'text-on-surface-variant' %>">Shipped</p>
          </div>
          <div class="tracking-stepper-line <%= deliveredReached ? 'completed' : '' %> mx-2 md:mx-4"></div>

          <!-- Step 4: Delivered -->
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 rounded-full <%= deliveredDone ? 'bg-emerald-500 text-white' : 'bg-surface-container-high text-on-surface-variant' %> flex items-center justify-center mb-3">
              <span class="material-symbols-outlined text-xl">inventory_2</span>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest <%= deliveredDone ? 'text-emerald-600' : 'text-on-surface-variant' %>">Delivered</p>
          </div>
        </div>
      </section>

      <section class="space-y-6">
        <h3 class="text-2xl font-bold mb-8">Tracking Details</h3>
        <div class="relative pl-8 space-y-10">
          <div class="absolute left-[11px] top-2 bottom-0 w-0.5 bg-surface-container-high"></div>

          <% if (history.length > 0) { %>
            <% history.forEach(function(h, idx) { %>
              <div class="relative">
                <div class="absolute -left-[30px] w-6 h-6 rounded-full <%= idx === 0 ? 'bg-primary' : 'bg-surface-dim' %> flex items-center justify-center ring-4 ring-background">
                  <span class="w-2.5 h-2.5 rounded-full <%= idx === 0 ? 'bg-white' : 'bg-secondary' %>"></span>
                </div>
                <div>
                  <p class="<%= idx === 0 ? 'text-on-surface font-semibold text-lg' : 'text-on-surface-variant font-medium' %>"><%= String(h.status || '').replace(/_/g, ' ') %><% if (h.location) { %>, <%= h.location %><% } %></p>
                  <p class="text-secondary text-sm"><%= new Date(h.timestamp).toLocaleString() %></p>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="relative">
              <div class="absolute -left-[30px] w-6 h-6 rounded-full bg-surface-dim flex items-center justify-center ring-4 ring-background">
                <span class="w-2.5 h-2.5 rounded-full bg-secondary"></span>
              </div>
              <div>
                <p class="text-on-surface-variant font-medium">No tracking updates yet</p>
                <p class="text-secondary text-sm">Updates will appear here once the carrier scans your package.</p>
              </div>
            </div>
          <% } %>
        </div>
      </section>

      <div class="flex flex-wrap gap-4 pt-6">
        <a href="/orders" class="px-8 py-3 rounded-md border-2 border-outline-variant font-semibold text-on-surface-variant hover:bg-surface-container-low transition-colors">Back to Order History</a>
        <a href="/contact" class="px-8 py-3 rounded-md border-2 border-outline-variant font-semibold text-on-surface-variant hover:bg-surface-container-low transition-colors">Contact Support</a>
      </div>
    </div>

    <aside class="lg:col-span-4 space-y-8">
      <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/20">
        <h4 class="text-xs uppercase tracking-widest text-on-surface-variant font-bold mb-6">Order Items</h4>
        <div class="space-y-6">
          <% if (items && items.length > 0) { %>
            <% items.forEach(function(item) { %>
              <div class="flex gap-4">
                <div class="w-20 h-20 bg-surface-container rounded-lg overflow-hidden flex-shrink-0">
                  <img alt="<%= item.product_name %>" class="w-full h-full object-cover" src="<%= item.image || '/images/placeholder-product.svg' %>" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"/>
                </div>
                <div class="flex-1">
                  <p class="font-headline font-semibold text-on-surface leading-tight"><%= item.product_name %></p>
                  <p class="text-xs text-secondary mt-1 italic"><%= item.shop_name || 'Artisan' %></p>
                  <div class="flex justify-between items-center mt-2">
                    <span class="text-sm text-on-surface-variant">Qty: <%= item.quantity %></span>
                    <span class="font-bold text-on-surface">$<%= Number(item.total_price || 0).toFixed(2) %></span>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <p class="text-sm text-secondary">No order items found.</p>
          <% } %>
        </div>
      </div>

      <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/20">
        <h4 class="text-xs uppercase tracking-widest text-on-surface-variant font-bold mb-6">Shipping Information</h4>
        <div class="space-y-5">
          <div>
            <p class="text-xs text-secondary font-medium uppercase tracking-tighter mb-1">Carrier</p>
            <p class="font-semibold text-on-surface"><%= shipment ? (shipment.carrier || 'Carrier Assigned Soon') : 'Carrier Assigned Soon' %></p>
          </div>
          <div>
            <p class="text-xs text-secondary font-medium uppercase tracking-tighter mb-1">Tracking Number</p>
            <p class="font-bold text-primary select-all"><%= shipment ? (shipment.tracking_number || 'Pending') : 'Pending' %></p>
          </div>
          <div class="pt-4 border-t border-outline-variant/10">
            <p class="text-xs text-secondary font-medium uppercase tracking-tighter mb-2">Delivery Address</p>
            <address class="not-italic text-on-surface leading-relaxed">
              <span class="block font-semibold"><%= (order.customer_name || (user && user.name)) || 'Customer' %></span>
              <%= order.shipping_address || '' %><br/>
              <%= order.shipping_city || '' %><% if (order.shipping_country) { %>, <%= order.shipping_country %><% } %>
            </address>
          </div>
        </div>
      </div>
    </aside>
  </div>
</main>

<%- include('../partials/footer') %>
