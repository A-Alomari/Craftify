<%- include('../partials/header', { title: 'Order Confirmed | Craftify' }) %>

<main class="pt-28 pb-20 px-4 max-w-4xl mx-auto relative overflow-hidden min-h-screen">
<!-- Success Decorative Background -->
<div class="absolute top-10 left-10 opacity-20 pointer-events-none">
<div class="w-2 h-2 rounded-full bg-primary-container absolute top-5 left-10"></div>
<div class="w-3 h-3 rounded-full bg-tertiary-container absolute top-20 left-24"></div>
<div class="w-1.5 h-1.5 rounded-full bg-secondary-container absolute top-12 left-32"></div>
</div>
<div class="absolute top-20 right-10 opacity-20 pointer-events-none">
<div class="w-2.5 h-2.5 rounded-full bg-primary-container absolute top-10 right-20"></div>
<div class="w-1.5 h-1.5 rounded-full bg-tertiary-container absolute top-24 right-10"></div>
</div>

<!-- Success Banner -->
<section class="text-center mb-16">
<div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 text-emerald-600 mb-6 shadow-sm">
<span class="material-symbols-outlined text-4xl inl-font-var-1fa313">check_circle</span>
</div>
<h1 class="font-headline text-4xl font-bold mb-4 tracking-tight">Order Confirmed!</h1>
<p class="text-secondary text-lg max-w-md mx-auto leading-relaxed">Thank you for your purchase. Your order has been placed successfully.</p>
<div class="mt-8 inline-block px-6 py-3 bg-surface-container-low rounded-xl border border-outline-variant/20 shadow-sm">
<span class="text-xs font-label uppercase tracking-widest text-secondary block mb-1">Order Number</span>
<span class="font-mono text-primary font-bold text-lg">#ORD-<%= order.id.toString().padStart(6, '0') %></span>
</div>
<p class="mt-6 text-sm text-secondary">A confirmation email has been sent to <span class="font-semibold text-on-surface"><%= user ? user.email : 'your email' %></span></p>
</section>

<!-- Main Content Layout -->
<div class="space-y-8">
<!-- Order Summary Card -->
<div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/10">
<h2 class="font-headline text-2xl mb-8 flex items-center">
<span class="material-symbols-outlined mr-3 text-secondary">receipt_long</span>
    Order Summary
</h2>

<div class="space-y-6 mb-8">
<% if (items && items.length > 0) { %>
    <% items.forEach(item => { %>
        <% var images = []; try { images = JSON.parse(item.images || '[]'); } catch(e) {} %>
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-surface-container rounded-lg overflow-hidden flex-shrink-0">
                    <img alt="<%= item.product_name || item.name %>" class="w-full h-full object-cover" src="<%= images[0] || '/images/placeholder-product.jpg' %>" onerror="this.src='/images/placeholder-product.jpg'"/>
                </div>
                <div>
                    <h3 class="font-medium text-on-surface"><%= item.product_name || item.name %></h3>
                    <p class="text-sm text-secondary">Quantity: <%= item.quantity %></p>
                </div>
            </div>
            <span class="font-headline text-on-surface">$<%= (item.unit_price * item.quantity).toFixed(2) %></span>
        </div>
    <% }) %>
<% } else { %>
    <p>No items found for this order.</p>
<% } %>
</div>

<div class="pt-6 border-t border-outline-variant/10 space-y-3">
<div class="flex justify-between text-secondary">
<span>Subtotal</span>
<span>$<%= order.subtotal.toFixed(2) %></span>
</div>
<div class="flex justify-between text-secondary">
<span>Shipping</span>
<span>$<%= (order.shipping_cost || 0).toFixed(2) %></span>
</div>
<% if (order.discount_amount > 0) { %>
<div class="flex justify-between text-secondary text-emerald-600">
<span>Discount</span>
<span>-$<%= order.discount_amount.toFixed(2) %></span>
</div>
<% } %>
<div class="flex justify-between text-xl font-bold pt-4 text-on-surface border-t border-dashed border-outline-variant/30">
<span class="font-headline">Total</span>
<span class="font-headline text-primary">$<%= order.total_amount.toFixed(2) %></span>
</div>
</div>
</div>

<!-- Side-by-Side Detail Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<!-- Shipping Address -->
<div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
<h3 class="font-label text-xs uppercase tracking-widest text-secondary mb-4 flex items-center">
<span class="material-symbols-outlined text-lg mr-2">location_on</span>
    Shipping Address
</h3>
<div class="text-on-surface leading-relaxed">
    <p class="font-bold"><%= user ? user.name : 'Customer' %></p>
    <p><%= order.shipping_address || '' %></p>
    <p><%= order.shipping_city || '' %></p>
    <p><%= order.shipping_postal || '' %></p>
    <p><%= order.shipping_country || '' %></p>
</div>
</div>
<!-- Delivery Info -->
<div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
<h3 class="font-label text-xs uppercase tracking-widest text-secondary mb-4 flex items-center">
<span class="material-symbols-outlined text-lg mr-2">local_shipping</span>
    Estimated Delivery
</h3>
<div class="text-on-surface leading-relaxed">
<% 
    var deliveryDate = new Date();
    deliveryDate.setDate(deliveryDate.getDate() + 5);
%>
<p class="font-bold text-primary"><%= deliveryDate.toDateString() %></p>
<p class="text-sm text-secondary">via Artisan Shipping</p>
<div class="mt-3 inline-flex items-center text-xs bg-emerald-50 text-emerald-700 px-2 py-1 rounded border border-emerald-100">
<span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-2"></span>
    Processing Order
</div>
</div>
</div>
</div>

<!-- Bottom Actions -->
<div class="flex flex-col items-center gap-6 pt-8">
<div class="flex flex-col sm:flex-row gap-4 w-full justify-center">
<a href="/orders/<%= order.id %>/track" class="bg-primary-container text-on-primary-container font-medium px-10 py-4 rounded-xl shadow-md hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center">
    Track Your Order
    <span class="material-symbols-outlined ml-2 text-xl">map</span>
</a>
<a href="/products" class="border-2 border-outline-variant text-on-surface font-medium px-10 py-4 rounded-xl hover:bg-surface-container-low transition-colors flex items-center justify-center shadow-sm">
    Continue Shopping
</a>
</div>
</div>
</div>
</main>

<%- include('../partials/footer') %>
