<%- include('../partials/header', { title: 'Checkout | Craftify' }) %>

<main class="pt-16 pb-24 px-6 max-w-7xl mx-auto">
<header class="mb-12 mt-12">
<a href="/cart" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:gap-3 transition-all mb-4">
<span class="material-symbols-outlined text-base">arrow_back</span>
Back to Cart
</a>
<h1 class="text-4xl font-headline font-bold text-on-surface">Secure Checkout</h1>
<p class="text-on-secondary-container font-label mt-2">Finish your order to support independent artisans.</p>
</header>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
<!-- Left Column: Forms -->
<div class="lg:col-span-8 space-y-8">
<!-- Shipping Address Card -->
<section class="bg-surface-container-lowest p-8 rounded-xl shadow-sm">
<div class="flex items-center gap-3 mb-8">
<span class="material-symbols-outlined text-amber-600" data-icon="local_shipping">local_shipping</span>
<h2 class="text-xl font-headline font-bold">Shipping Address</h2>
</div>
<div class="mb-6 rounded-xl border border-amber-200/70 bg-amber-50/70 px-4 py-3 flex items-center gap-3">
<span class="material-symbols-outlined text-amber-700" data-icon="home_pin">home_pin</span>
<p class="text-sm text-amber-900">Use a complete address for accurate delivery updates and tracking milestones.</p>
</div>
<form action="/orders/checkout" method="POST" id="checkout-form" class="space-y-6">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<input type="hidden" name="checkout_nonce" value="<%= checkoutNonce || '' %>">
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">Full Name</label>
<input name="shipping_name" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="Your full name" type="text" value="<%= user ? user.name : '' %>"/>
</div>
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">Street Address</label>
<input name="shipping_address" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="123 Main Street" type="text" value="<%= user && user.shipping_address ? user.shipping_address : '' %>"/>
</div>
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">Apartment / Suite / Building</label>
<input name="shipping_building" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="Apt 4B, Suite 200, Floor 3..." type="text" value="<%= user && user.building ? user.building : '' %>"/>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">City</label>
<input name="shipping_city" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="Manama" type="text" value="<%= user && user.city ? user.city : '' %>"/>
</div>
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">Postal Code</label>
<input name="shipping_postal" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="321" type="text" value="<%= user && user.postal_code ? user.postal_code : '' %>"/>
</div>
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container">Country</label>
<input name="shipping_country" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-highest transition-colors" placeholder="Bahrain" type="text" value="<%= user && user.country ? user.country : 'Bahrain' %>"/>
</div>
</div>
<input type="hidden" name="payment_method" value="card">
</form>
</section>
<!-- Payment Details Card (Mock) -->
<section class="bg-surface-container-lowest p-8 rounded-xl shadow-sm">
<div class="flex items-center gap-3 mb-8">
<span class="material-symbols-outlined text-amber-600" data-icon="credit_card">credit_card</span>
<h2 class="text-xl font-headline font-bold">Payment Details</h2>
</div>
<div class="bg-blue-50 border border-blue-200 text-blue-800 rounded-lg p-4 mb-6">
    <p class="text-sm flex items-center"><span class="material-symbols-outlined mr-2">info</span> This is a simulated checkout. Your payment will not be actually processed.</p>
</div>
<div class="space-y-6">
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container" for="card_number">Card Number</label>
<div class="relative">
<input id="card_number" name="card_number" form="checkout-form" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 pr-12" placeholder="0000 0000 0000 0000" type="text" value="4242 4242 4242 4242"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container" for="card_expiry">Expiration Date (MM/YY)</label>
<input id="card_expiry" name="card_expiry" form="checkout-form" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3" placeholder="MM/YY" type="text" value="12/25"/>
</div>
<div class="space-y-2">
<label class="text-xs uppercase tracking-widest font-label font-bold text-on-secondary-container" for="card_cvc">CVV</label>
<input id="card_cvc" name="card_cvc" form="checkout-form" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3" placeholder="123" type="password" value="123"/>
</div>
</div>
</div>
</section>
</div>
<!-- Right Column: Summary -->
<aside class="lg:col-span-4">
<div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm lg:sticky lg:top-32">
<h2 class="text-xl font-headline font-bold mb-8">Order Summary</h2>
<!-- Line Items -->
<div class="space-y-6 mb-8">
<% if (items && items.length > 0) { %>
    <% items.forEach(function(item) { %>
        <div class="flex gap-4">
            <div class="w-20 h-20 bg-surface-container rounded-lg overflow-hidden flex-shrink-0">
                <img alt="<%= item.product_name || item.name %>" class="w-full h-full object-cover" src="<%= item.image || '/images/placeholder-product.svg' %>" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"/>
            </div>
            <div class="flex-1 flex flex-col justify-between py-1">
                <div class="flex justify-between items-start">
                    <span class="font-headline font-bold text-on-surface whitespace-nowrap overflow-hidden text-ellipsis mr-2"><%= item.product_name || item.name %></span>
                    <span class="font-serif text-amber-700 whitespace-nowrap">$<%= (item.price * item.quantity).toFixed(2) %></span>
                </div>
                <span class="text-xs text-on-secondary-container font-label uppercase tracking-tighter">Qty: <%= item.quantity %></span>
            </div>
        </div>
    <% }) %>
<% } %>
</div>
<!-- Totals -->
<div class="border-t border-surface-container-highest pt-6 space-y-3 mb-8">
<div class="flex justify-between font-label text-sm text-on-secondary-container">
<span>Subtotal</span>
<span>$<%= (subtotal || 0).toFixed(2) %></span>
</div>
<div class="flex justify-between font-label text-sm text-on-secondary-container">
<span>Shipping</span>
<span><%= shipping === 0 ? 'Free' : '$' + shipping.toFixed(2) %></span>
</div>
<% if (discount > 0) { %>
<div class="flex justify-between font-label text-sm text-emerald-600">
<span>Discount</span>
<span>-$<%= discount.toFixed(2) %></span>
</div>
<% } %>
<div class="flex justify-between font-headline font-bold text-xl pt-3 text-on-surface">
<span>Total</span>
<span class="text-amber-700">$<%= (total || 0).toFixed(2) %></span>
</div>
</div>
<!-- CTA -->
<button type="submit" form="checkout-form" class="w-full bg-primary-container text-on-primary-container font-label font-bold py-4 rounded-xl hover:opacity-90 transition-opacity flex items-center justify-center gap-2 mb-4 group shadow-sm">
<span>Place Simulated Order</span>
<span class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
</button>
<p class="text-[10px] text-center text-slate-400 font-label leading-relaxed">
    By placing this order, you agree to our Terms of Service and Privacy Policy. This is a university project—no actual payments are collected or items shipped.
</p>
</div>
</aside>
</div>
</main>

<%- include('../partials/footer') %>
