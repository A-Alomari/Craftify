<%- include('../partials/header', { title: title }) %>

<main class="flex-grow min-h-screen">

<%
  const orderStatusClass = function(status) {
    if (status === 'delivered') return 'bg-emerald-100 text-emerald-700';
    if (status === 'cancelled' || status === 'refunded') return 'bg-red-100 text-red-700';
    if (status === 'shipped' || status === 'processing') return 'bg-blue-100 text-blue-700';
    return 'bg-amber-100 text-amber-700';
  };
%>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="mb-6">
    <a href="/orders" class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-secondary hover:text-primary">
      <span class="material-symbols-outlined text-base">arrow_back</span>
      Back to Orders
    </a>
    <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
      <h1 class="font-headline text-3xl text-on-surface">Order #ORD-<%= String(order.id).padStart(4, '0') %></h1>
      <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= orderStatusClass(order.status) %>"><%= order.status %></span>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <section class="xl:col-span-2 bg-surface-container-lowest rounded-xl p-6 md:p-8">
      <h2 class="font-headline text-xl text-on-surface mb-4">Order Items</h2>

      <div class="space-y-3">
        <% items.forEach(function(item) { %>
          <article class="flex items-center justify-between gap-4 rounded-xl bg-surface-container-low px-4 py-3">
            <div class="flex items-center gap-3 min-w-0">
              <img src="<%= item.image || '/images/placeholder-product.jpg' %>" alt="<%= item.product_name %>" class="w-12 h-12 rounded-lg object-cover" onerror="this.src='/images/placeholder-product.jpg'">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-on-surface truncate"><%= item.product_name %></p>
                <p class="text-xs text-secondary"><%= item.shop_name || '' %></p>
                <p class="text-xs text-secondary">$<%= Number(item.unit_price || 0).toFixed(2) %> x <%= item.quantity %></p>
                <% if (item.artisan_id) { %>
                  <a href="/user/messages/<%= item.artisan_id %>" class="inline-flex items-center gap-1 mt-1 text-[11px] font-semibold text-primary hover:underline">
                    <span class="material-symbols-outlined text-sm">chat</span>
                    Message Seller
                  </a>
                <% } %>
              </div>
            </div>
            <p class="text-sm font-bold text-on-surface">$<%= Number(item.total_price || 0).toFixed(2) %></p>
          </article>
        <% }); %>
      </div>

      <% if (['pending', 'confirmed'].indexOf(order.status) >= 0) { %>
        <form action="/orders/<%= order.id %>/cancel" method="POST" class="mt-6" data-confirm="Cancel this order?">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="bg-red-100 text-red-700 hover:bg-red-200 px-4 py-2.5 rounded-xl text-sm font-semibold">Cancel Order</button>
        </form>
      <% } %>
    </section>

    <aside class="space-y-6">
      <article class="bg-surface-container-lowest rounded-xl p-6">
        <h2 class="font-headline text-lg text-on-surface mb-3">Order Summary</h2>
        <div class="space-y-2 text-sm text-on-surface">
          <div class="flex justify-between"><span class="text-secondary">Subtotal</span><span>$<%= Number(order.subtotal || 0).toFixed(2) %></span></div>
          <div class="flex justify-between"><span class="text-secondary">Shipping</span><span>$<%= Number(order.shipping_cost || 0).toFixed(2) %></span></div>
          <% if (order.discount_amount > 0) { %>
            <div class="flex justify-between text-emerald-700"><span>Discount</span><span>-$<%= Number(order.discount_amount || 0).toFixed(2) %></span></div>
          <% } %>
        </div>
        <div class="mt-4 pt-4 border-t border-surface-container-high flex justify-between items-center">
          <span class="text-xs uppercase tracking-[0.2em] text-secondary font-bold">Total</span>
          <span class="font-headline text-2xl text-on-surface">$<%= Number(order.total_amount || 0).toFixed(2) %></span>
        </div>
      </article>

      <article class="bg-surface-container-lowest rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-primary">local_shipping</span>
          <h2 class="font-headline text-lg text-on-surface">Shipping</h2>
        </div>
        <div class="rounded-xl bg-surface-container-low p-4 border border-surface-container-high">
          <p class="text-sm font-semibold text-on-surface"><%= order.shipping_address %></p>
          <p class="text-sm text-secondary mt-1"><%= order.shipping_city || '' %> <%= order.shipping_country || '' %></p>
          <% if (order.shipping_postal) { %>
            <p class="text-xs text-secondary mt-1">Postal code: <%= order.shipping_postal %></p>
          <% } %>
        </div>

        <% if (shipment) { %>
          <div class="mt-4 pt-4 border-t border-surface-container-high">
            <p class="text-sm text-on-surface"><span class="font-semibold">Tracking:</span> <%= shipment.tracking_number %></p>
            <p class="text-sm text-on-surface mt-1"><span class="font-semibold">Status:</span> <%= shipment.status %></p>
            <a href="/orders/<%= order.id %>/track" class="inline-block mt-3 bg-primary-container text-on-primary-container px-4 py-2 rounded-lg text-xs font-semibold">Track Order</a>
          </div>
        <% } else { %>
          <p class="text-xs text-secondary mt-4">Tracking details will appear here once the artisan dispatches the package.</p>
        <% } %>
      </article>
    </aside>
  </div>
</section>

</main>

<%- include('../partials/footer') %>
