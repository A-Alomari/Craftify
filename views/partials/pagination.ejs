<% if (typeof pagination !== 'undefined' && pagination.total > 1) { %>
<nav aria-label="Page navigation" class="mt-4">
  <ul class="pagination justify-content-center">
    <% if (pagination.hasPrev) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.current - 1 %><%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>">
          <i class="bi bi-chevron-left"></i>
        </a>
      </li>
    <% } else { %>
      <li class="page-item disabled">
        <span class="page-link"><i class="bi bi-chevron-left"></i></span>
      </li>
    <% } %>
    
    <% 
      let startPage = Math.max(1, pagination.current - 2);
      let endPage = Math.min(pagination.total, pagination.current + 2);
    %>
    
    <% if (startPage > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?page=1<%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>">1</a>
      </li>
      <% if (startPage > 2) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
      <% } %>
    <% } %>
    
    <% for (let i = startPage; i <= endPage; i++) { %>
      <li class="page-item <%= i === pagination.current ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %><%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>"><%= i %></a>
      </li>
    <% } %>
    
    <% if (endPage < pagination.total) { %>
      <% if (endPage < pagination.total - 1) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
      <% } %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.total %><%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>"><%= pagination.total %></a>
      </li>
    <% } %>
    
    <% if (pagination.hasNext) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= pagination.current + 1 %><%= typeof queryString !== 'undefined' ? '&' + queryString : '' %>">
          <i class="bi bi-chevron-right"></i>
        </a>
      </li>
    <% } else { %>
      <li class="page-item disabled">
        <span class="page-link"><i class="bi bi-chevron-right"></i></span>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
