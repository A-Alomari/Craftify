<div class="card product-card h-100">
  <% 
    const images = JSON.parse(product.images || '[]');
    const mainImage = images[0] || '/images/placeholder-product.jpg';
  %>
  <a href="/products/<%= product.id %>">
    <img src="<%= mainImage %>" class="card-img-top product-image" alt="<%= product.name %>" onerror="this.src='/images/placeholder-product.jpg'">
  </a>
  
  <% if (product.featured) { %>
    <span class="badge bg-warning position-absolute top-0 start-0 m-2">Featured</span>
  <% } %>
  
  <% if (typeof user !== 'undefined' && user) { %>
    <button class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 wishlist-btn <%= product.inWishlist ? 'active' : '' %>" 
            data-product-id="<%= product.id %>"
            aria-label="<%= product.inWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>">
      <i class="bi <%= product.inWishlist ? 'bi-heart-fill text-danger' : 'bi-heart' %>"></i>
    </button>
  <% } %>
  
  <div class="card-body d-flex flex-column">
    <h6 class="card-title mb-1">
      <a href="/products/<%= product.id %>" class="text-decoration-none text-dark">
        <%= product.name %>
      </a>
    </h6>
    
    <% if (product.shop_name) { %>
      <small class="text-muted mb-2">
        <a href="/products/artisan/<%= product.artisan_id %>" class="text-decoration-none">
          <%= product.shop_name %>
        </a>
      </small>
    <% } %>
    
    <% if (product.avg_rating) { %>
      <div class="mb-2">
        <% for (let i = 1; i <= 5; i++) { %>
          <i class="bi <%= i <= Math.round(product.avg_rating) ? 'bi-star-fill text-warning' : 'bi-star text-muted' %> small"></i>
        <% } %>
        <small class="text-muted">(<%= product.review_count || 0 %>)</small>
      </div>
    <% } %>
    
    <div class="mt-auto">
      <div class="d-flex justify-content-between align-items-center">
        <span class="fw-bold text-primary">$<%= product.price.toFixed(2) %></span>
        <% if (product.stock > 0) { %>
          <button class="btn btn-primary btn-sm add-to-cart-btn" data-product-id="<%= product.id %>">
            <i class="bi bi-cart-plus"></i>
          </button>
        <% } else { %>
          <span class="badge bg-secondary">Out of Stock</span>
        <% } %>
      </div>
    </div>
  </div>
</div>
