<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold text-primary" href="/">
      <i class="bi bi-brush"></i> Craftify
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarNav">
      <form class="d-flex mx-auto my-2 my-lg-0" action="/products/search" method="GET" style="max-width: 400px; width: 100%;">
        <div class="input-group">
          <input class="form-control" type="search" name="q" placeholder="Search products..." aria-label="Search">
          <button class="btn btn-outline-primary" type="submit">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </form>
      
      <ul class="navbar-nav ms-auto align-items-center">
        <li class="nav-item">
          <a class="nav-link" href="/products">Products</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/auctions">Auctions</a>
        </li>
        
        <% if (user) { %>
          <!-- Notifications -->
          <li class="nav-item dropdown">
            <a class="nav-link position-relative" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-bell fs-5"></i>
              <% if (notificationCount > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                  <%= notificationCount > 9 ? '9+' : notificationCount %>
                </span>
              <% } %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/user/notifications">View All Notifications</a></li>
            </ul>
          </li>
          
          <!-- Cart -->
          <li class="nav-item">
            <a class="nav-link position-relative" href="/cart">
              <i class="bi bi-cart3 fs-5"></i>
              <% if (cartCount > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary cart-count">
                  <%= cartCount %>
                </span>
              <% } %>
            </a>
          </li>
          
          <!-- User Menu -->
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="Avatar" class="rounded-circle me-1" width="28" height="28" onerror="this.src='/images/placeholder-avatar.jpg'">
              <% } else { %>
                <i class="bi bi-person-circle me-1 fs-5"></i>
              <% } %>
              <span class="d-none d-lg-inline"><%= user.name.split(' ')[0] %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><h6 class="dropdown-header"><%= user.name %></h6></li>
              <li><hr class="dropdown-divider"></li>
              
              <% if (user.role === 'admin') { %>
                <li><a class="dropdown-item" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                <li><hr class="dropdown-divider"></li>
              <% } else if (user.role === 'artisan') { %>
                <li><a class="dropdown-item" href="/artisan/dashboard"><i class="bi bi-palette me-2"></i>Artisan Dashboard</a></li>
                <li><hr class="dropdown-divider"></li>
              <% } %>
              
              <li><a class="dropdown-item" href="/user/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
              <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag me-2"></i>My Orders</a></li>
              <li><a class="dropdown-item" href="/user/wishlist"><i class="bi bi-heart me-2"></i>Wishlist</a></li>
              <li><a class="dropdown-item" href="/user/messages"><i class="bi bi-chat me-2"></i>Messages</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/auth/logout" method="POST" class="d-inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <!-- Cart for guests -->
          <li class="nav-item">
            <a class="nav-link position-relative" href="/cart">
              <i class="bi bi-cart3 fs-5"></i>
              <% if (cartCount > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary cart-count">
                  <%= cartCount %>
                </span>
              <% } %>
            </a>
          </li>
          
          <li class="nav-item">
            <a class="nav-link" href="/auth/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-primary btn-sm ms-2" href="/auth/register">Sign Up</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
