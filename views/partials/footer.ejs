<!-- CSRF Token (available for JS injection into forms) -->
<meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<!-- Bottom Navigation Bar (Mobile only) -->
<%
    const mobileNav = typeof currentPath === 'string' ? currentPath : '/';
    const mobileActiveClass = 'flex flex-col items-center justify-center bg-amber-100 text-amber-900 rounded-2xl px-5 py-2';
    const mobileInactiveClass = 'flex flex-col items-center justify-center text-slate-500 px-5 py-2';
    const isShopActive = mobileNav.startsWith('/products');
    const isAuctionsActive = mobileNav.startsWith('/auctions');
    const isCartActive = mobileNav.startsWith('/cart');
    const isProfileActive = mobileNav.startsWith('/user') || mobileNav.startsWith('/auth');
%>
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl shadow-[0px_-10px_40px_rgba(25,28,30,0.04)] rounded-t-3xl">
    <a class="<%= isShopActive ? mobileActiveClass : mobileInactiveClass %>" href="/products">
        <span class="material-symbols-outlined <%= isShopActive ? 'filled-icon' : '' %>">storefront</span>
        <span class="font-['Inter'] text-[10px] uppercase tracking-widest font-bold mt-1">Shop</span>
    </a>
    <a class="<%= isAuctionsActive ? mobileActiveClass : mobileInactiveClass %>" href="/auctions">
        <span class="material-symbols-outlined <%= isAuctionsActive ? 'filled-icon' : '' %>">auto_stories</span>
        <span class="font-['Inter'] text-[10px] uppercase tracking-widest font-bold mt-1">Auctions</span>
    </a>
    <% if (!(typeof user !== 'undefined' && user && (user.role === 'artisan' || user.role === 'admin'))) { %>
    <a class="<%= isCartActive ? mobileActiveClass : mobileInactiveClass %>" href="/cart">
        <span class="material-symbols-outlined <%= isCartActive ? 'filled-icon' : '' %>">shopping_bag</span>
        <span class="font-['Inter'] text-[10px] uppercase tracking-widest font-bold mt-1">Cart</span>
    </a>
    <% } %>
    <% if (typeof user !== 'undefined' && user) { %>
        <a class="<%= isProfileActive ? mobileActiveClass : mobileInactiveClass %>" href="/user/profile">
            <span class="material-symbols-outlined <%= isProfileActive ? 'filled-icon' : '' %>">person</span>
            <span class="font-['Inter'] text-[10px] uppercase tracking-widest font-bold mt-1">Profile</span>
        </a>
    <% } else { %>
        <a class="<%= isProfileActive ? mobileActiveClass : mobileInactiveClass %>" href="/auth/login">
            <span class="material-symbols-outlined <%= isProfileActive ? 'filled-icon' : '' %>">login</span>
            <span class="font-['Inter'] text-[10px] uppercase tracking-widest font-bold mt-1">Login</span>
        </a>
    <% } %>
</nav>

<script>
    (function () {
        var shareButton = document.getElementById('footerShareButton');
        if (!shareButton) return;

        shareButton.addEventListener('click', async function (event) {
            event.preventDefault();
            var shareData = {
                title: 'Craftify',
                text: 'Discover handcrafted products and live artisan auctions on Craftify.',
                url: window.location.origin
            };

            try {
                if (navigator.share) {
                    await navigator.share(shareData);
                    return;
                }

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(shareData.url);
                    if (typeof showToast === 'function') showToast('Craftify link copied to clipboard!', 'success');
                    return;
                }

                window.prompt('Copy this link:', shareData.url);
            } catch (err) {
                // User canceled share or browser blocked clipboard access.
            }
        });
    })();
</script>

<script src="/js/form-validation.js" defer></script>
<script src="/js/form-loading.js" defer></script>
<script src="/js/image-preview.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
<script src="/js/main.js"></script>

<% if (typeof extraScripts !== 'undefined') { %>
    <%- extraScripts %>
<% } %>
</body>
</html>
