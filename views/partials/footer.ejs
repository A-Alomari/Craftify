        </div>
        <!-- Column 3: Support -->
        <div>
            <h4 class="text-on-surface font-semibold uppercase tracking-wider mb-6">Support</h4>
            <ul class="space-y-4">
                <li><a class="opacity-90 hover:opacity-100 hover:text-primary hover:underline underline-offset-8 transition-all" href="/about">About Craftify</a></li>
                <li><a class="opacity-90 hover:opacity-100 hover:text-primary hover:underline underline-offset-8 transition-all" href="/faq">Help Center</a></li>
