<%- include('../partials/header', { title: 'Server Error - Craftify' }) %>

<section class="max-w-3xl mx-auto px-6 py-16">
  <article class="bg-surface-container-lowest rounded-xl p-10 text-center">
    <span class="material-symbols-outlined text-6xl text-red-600">error</span>
    <h1 class="font-headline text-4xl text-on-surface mt-4">500 - Server Error</h1>
    <p class="text-secondary mt-3">Something went wrong. Please try again in a moment.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <pre class="mt-6 text-left bg-surface-container-low p-4 rounded-xl text-xs overflow-x-auto"><%= error %></pre>
    <% } %>

    <a href="/" class="inline-block mt-6 bg-primary-container text-on-primary-container px-6 py-2.5 rounded-xl text-sm font-semibold">Go Home</a>
  </article>
</section>

<%- include('../partials/footer') %>
