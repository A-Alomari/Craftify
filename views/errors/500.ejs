<%- include('../partials/header', { title: 'Server Error - Craftify' }) %>
<div class="container py-5 text-center">
  <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
  <h2 class="mt-3">500 - Server Error</h2>
  <p class="text-muted">Something went wrong. Please try again later.</p>
  <% if (typeof error !== 'undefined' && error) { %>
    <pre class="text-start bg-light p-3 rounded small"><%= error %></pre>
  <% } %>
  <a href="/" class="btn btn-primary">Go Home</a>
</div>
<%- include('../partials/footer') %>
