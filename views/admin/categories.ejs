<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Category Management</h1>
        <p class="text-secondary mt-1">Organize collections and keep product discovery clean.</p>
      </div>
      <p class="text-xs text-secondary uppercase tracking-widest">Categories: <%= categories ? categories.length : 0 %></p>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-5 md:p-6 mb-6">
      <h2 class="font-headline text-xl text-on-surface mb-4">Create Category</h2>
      <form action="/admin/categories" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Name</label>
          <input type="text" name="name" required class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
        </div>
        <div class="md:col-span-2">
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Description</label>
          <input type="text" name="description" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Image</label>
          <input type="file" name="image" accept="image/jpeg,image/png,image/webp" class="w-full bg-surface-container-low border-none rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-primary-container">
        </div>
        <div class="md:col-span-4 flex justify-end">
          <button type="submit" class="bg-primary-container text-on-primary-container px-6 py-2.5 rounded-xl font-semibold text-sm">Add Category</button>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto">
      <% if (categories && categories.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
          <% categories.forEach(function(cat) { %>
            <article class="bg-surface-container-lowest rounded-xl p-6">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                  <h3 class="font-headline text-xl text-on-surface"><%= cat.name %></h3>
                  <p class="text-xs text-secondary mt-1"><%= cat.slug || '' %></p>
                </div>
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-secondary-container text-on-secondary-container"><%= cat.product_count || 0 %> Products</span>
              </div>

              <p class="text-sm text-secondary min-h-[48px]"><%= cat.description || 'No description provided yet.' %></p>

              <div class="mt-5 flex items-center justify-between">
                <span class="text-xs text-secondary">Created <%= new Date(cat.created_at).toLocaleDateString() %></span>
                <form action="/admin/categories/<%= cat.id %>/delete" method="POST" onsubmit="return confirm('Delete this category?');">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Delete</button>
                </form>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="bg-surface-container-lowest rounded-xl py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">category</span>
          <p class="text-secondary mt-3">No categories yet. Create your first one above.</p>
        </div>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
