<%- include('../partials/header', { title: title }) %>
<%
  const statusFilter = filters && filters.status ? filters.status : '';
  const auctionStatusClass = function(status) {
    if (status === 'active') return 'bg-emerald-100 text-emerald-700';
    if (status === 'sold') return 'bg-primary-container text-on-primary-container';
    if (status === 'cancelled') return 'bg-red-100 text-red-700';
    return 'bg-surface-container-high text-on-surface';
  };
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Auction Management</h1>
        <p class="text-secondary mt-1">Monitor live bidding, visibility, and auction lifecycle.</p>
      </div>
      <p class="text-xs text-secondary uppercase tracking-widest">Auctions: <%= auctions ? auctions.length : 0 %></p>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-5 md:p-6 mb-6">
      <form method="GET" action="/admin/auctions" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Status</label>
          <select name="status" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All</option>
            <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="active" <%= statusFilter === 'active' ? 'selected' : '' %>>Active</option>
            <option value="ended" <%= statusFilter === 'ended' ? 'selected' : '' %>>Ended</option>
            <option value="sold" <%= statusFilter === 'sold' ? 'selected' : '' %>>Sold</option>
            <option value="cancelled" <%= statusFilter === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>
        <div class="flex items-end gap-2 md:col-span-2">
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Apply</button>
          <a href="/admin/auctions" class="bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl font-semibold text-sm">Reset</a>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl overflow-hidden">
      <% if (auctions && auctions.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                <th class="px-6 py-4">Product</th>
                <th class="px-6 py-4">Artisan</th>
                <th class="px-6 py-4">Current Bid</th>
                <th class="px-6 py-4">Bid Count</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4">Ends</th>
                <th class="px-6 py-4 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50">
              <% auctions.forEach(function(a) { %>
                <tr class="hover:bg-surface-container-low/20 transition-colors">
                  <td class="px-6 py-5">
                    <div class="flex items-center gap-3">
                      <img src="<%= a.image || '/images/placeholder-product.jpg' %>" alt="<%= a.product_name %>" class="w-11 h-11 rounded-lg object-cover" onerror="this.src='/images/placeholder-product.jpg'">
                      <p class="text-sm font-semibold text-on-surface"><%= a.product_name %></p>
                    </div>
                  </td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= a.shop_name || '-' %></td>
                  <td class="px-6 py-5 text-sm text-on-surface">$<%= Number(a.current_highest_bid || 0).toFixed(2) %></td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= a.bid_count || 0 %></td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= auctionStatusClass(a.status) %>"><%= a.status %></span>
                  </td>
                  <td class="px-6 py-5 text-sm text-secondary"><%= new Date(a.end_time).toLocaleString() %></td>
                  <td class="px-6 py-5 text-right">
                    <% if (a.status === 'active' || a.status === 'pending') { %>
                      <form action="/admin/auctions/<%= a.id %>/cancel" method="POST" class="inline-block" data-confirm="Cancel this auction?">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Cancel</button>
                      </form>
                    <% } else { %>
                      <span class="text-xs text-secondary">No action</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">gavel</span>
          <p class="text-secondary mt-3">No auctions found for this filter.</p>
        </div>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
