<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-box"></i> Products</h3>
  <% if (products && products.length > 0) { %>
  <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Product</th><th>Artisan</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr></thead>
  <tbody><% products.forEach(function(p) { %><tr>
    <td><%= p.name %></td>
    <td><%= p.shop_name || '' %></td>
    <td>$<%= p.price.toFixed(2) %></td>
    <td><%= p.stock %></td>
    <td><span class="badge bg-<%= p.status === 'approved' ? 'success' : p.status === 'pending' ? 'warning' : 'danger' %>"><%= p.status %></span></td>
    <td>
      <% if (p.status === 'pending') { %>
        <form action="/admin/products/<%= p.id %>/approve" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><button class="btn btn-sm btn-success">Approve</button></form>
        <form action="/admin/products/<%= p.id %>/reject" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><button class="btn btn-sm btn-danger">Reject</button></form>
      <% } %>
      <form action="/admin/products/<%= p.id %>/featured" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><button class="btn btn-sm btn-<%= p.featured ? 'warning' : 'outline-warning' %>"><i class="bi bi-star"></i></button></form>
    </td>
  </tr><% }); %></tbody></table></div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-box-seam display-4 text-muted"></i>
      <p class="text-muted mt-3">No products found.</p>
    </div>
  <% } %>
</div></div></div>
<%- include('../partials/footer') %>
