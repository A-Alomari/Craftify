<%- include('../partials/header', { title: title }) %>
<%
  const statusFilter = filters && filters.status ? filters.status : '';
  const categoryFilter = filters && filters.category ? String(filters.category) : '';
  const searchFilter = filters && filters.search ? filters.search : '';
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Product Management</h1>
        <p class="text-secondary mt-1">Moderate listings, approval state, and featured badges.</p>
      </div>
      <p class="text-xs text-secondary uppercase tracking-widest">Listings: <%= products ? products.length : 0 %></p>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-5 md:p-6 mb-6">
      <form method="GET" action="/admin/products" class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Status</label>
          <select name="status" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All</option>
            <option value="approved" <%= statusFilter === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="rejected" <%= statusFilter === 'rejected' ? 'selected' : '' %>>Rejected</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Category</label>
          <select name="category" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All Categories</option>
            <% if (categories) { categories.forEach(function(c) { %>
              <option value="<%= c.id %>" <%= categoryFilter === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
            <% }); } %>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Search</label>
          <input type="text" name="search" value="<%= searchFilter %>" placeholder="Product, description, or shop" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Apply</button>
          <a href="/admin/products" class="bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl font-semibold text-sm">Reset</a>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl overflow-hidden">
      <% if (products && products.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                <th class="px-6 py-4">Product</th>
                <th class="px-6 py-4">Artisan</th>
                <th class="px-6 py-4">Price</th>
                <th class="px-6 py-4">Stock</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50">
              <% products.forEach(function(p) { %>
                <tr class="hover:bg-surface-container-low/20 transition-colors">
                  <td class="px-6 py-5">
                    <p class="text-sm font-semibold text-on-surface"><%= p.name %></p>
                    <p class="text-xs text-secondary">ID: <%= p.id %></p>
                  </td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= p.shop_name || '-' %></td>
                  <td class="px-6 py-5 text-sm text-on-surface">$<%= Number(p.price || 0).toFixed(2) %></td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= p.stock %></td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= p.status === 'approved' ? 'bg-emerald-100 text-emerald-700' : (p.status === 'pending' ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-700') %>"><%= p.status %></span>
                  </td>
                  <td class="px-6 py-5 text-right">
                    <div class="inline-flex gap-2">
                      <% if (p.status === 'pending') { %>
                        <form action="/admin/products/<%= p.id %>/approve" method="POST" class="inline-block">
                          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                          <button class="bg-emerald-100 text-emerald-700 hover:bg-emerald-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Approve</button>
                        </form>
                        <form action="/admin/products/<%= p.id %>/reject" method="POST" class="inline-block">
                          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                          <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Reject</button>
                        </form>
                      <% } %>
                      <form action="/admin/products/<%= p.id %>/featured" method="POST" class="inline-block">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button class="<%= p.featured ? 'bg-primary-container text-on-primary-container' : 'bg-surface-container-high text-secondary hover:text-on-surface' %> px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Featured</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">inventory_2</span>
          <p class="text-secondary mt-3">No products found for this filter.</p>
        </div>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
