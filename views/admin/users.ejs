<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-people"></i> User Management</h3>
  <% if (users && users.length > 0) { %>
  <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th></th></tr></thead>
  <tbody><% users.forEach(function(u) { %><tr>
    <td><%= u.name %></td><td><%= u.email %></td>
    <td><span class="badge bg-<%= u.role === 'admin' ? 'danger' : u.role === 'artisan' ? 'info' : 'secondary' %>"><%= u.role %></span></td>
    <td><span class="badge bg-<%= u.status === 'active' ? 'success' : 'warning' %>"><%= u.status %></span></td>
    <td><%= new Date(u.created_at).toLocaleDateString() %></td>
    <td>
      <% if (u.status === 'active') { %><form action="/admin/users/<%= u.id %>/status" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><input type="hidden" name="status" value="suspended"><button class="btn btn-sm btn-warning">Suspend</button></form><% } else { %><form action="/admin/users/<%= u.id %>/status" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><input type="hidden" name="status" value="active"><button class="btn btn-sm btn-success">Activate</button></form><% } %>
    </td>
  </tr><% }); %></tbody></table></div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-people display-4 text-muted"></i>
      <p class="text-muted mt-3">No users found.</p>
    </div>
  <% } %>
  <%- include('../partials/pagination', { pagination: pagination, baseUrl: '/admin/users', queryString: 'role=' + (filters.role || '') + '&status=' + (filters.status || '') + '&search=' + (filters.search || '') }) %>
</div></div></div>
<%- include('../partials/footer') %>
