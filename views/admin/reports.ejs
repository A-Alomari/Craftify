<%- include('../partials/header', { title: title }) %>
<%
  const selectedPeriod = period || 'month';
  const revenue = Number(totalRevenue || 0);
  const orders = Number(totalOrders || 0);
  const averageOrder = orders > 0 ? revenue / orders : 0;
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Performance Reports</h1>
        <p class="text-secondary mt-1">Track revenue, orders, and best performers across defined windows.</p>
      </div>

      <form method="GET" action="/admin/reports" class="w-full md:w-auto">
        <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Period</label>
        <div class="flex gap-2">
          <select name="period" class="bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container min-w-[180px]">
            <option value="week" <%= selectedPeriod === 'week' ? 'selected' : '' %>>Last 7 Days</option>
            <option value="month" <%= selectedPeriod === 'month' ? 'selected' : '' %>>Last 30 Days</option>
            <option value="year" <%= selectedPeriod === 'year' ? 'selected' : '' %>>Last 365 Days</option>
          </select>
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Apply</button>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Total Revenue</p>
        <p class="font-headline text-3xl text-on-surface mt-3">$<%= revenue.toFixed(2) %></p>
      </article>
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Total Orders</p>
        <p class="font-headline text-3xl text-on-surface mt-3"><%= orders %></p>
      </article>
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Average Order Value</p>
        <p class="font-headline text-3xl text-on-surface mt-3">$<%= averageOrder.toFixed(2) %></p>
      </article>
    </section>

    <section class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-2 gap-6">
      <article class="bg-surface-container-lowest rounded-xl overflow-hidden">
        <header class="px-6 py-4 border-b border-surface-container-high">
          <h2 class="font-headline text-xl text-on-surface">Sales Timeline</h2>
        </header>

        <% if (salesData && salesData.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                  <th class="px-6 py-4">Date</th>
                  <th class="px-6 py-4">Orders</th>
                  <th class="px-6 py-4">Revenue</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-container-high/50">
                <% salesData.forEach(function(s) { %>
                  <tr class="hover:bg-surface-container-low/20 transition-colors">
                    <td class="px-6 py-4 text-sm text-on-surface"><%= new Date(s.date).toLocaleDateString() %></td>
                    <td class="px-6 py-4 text-sm text-on-surface"><%= Number(s.orders || 0) %></td>
                    <td class="px-6 py-4 text-sm text-on-surface">$<%= Number(s.revenue || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-12 text-center text-secondary">
            <span class="material-symbols-outlined text-5xl opacity-60">monitoring</span>
            <p class="mt-2">No sales data for this period.</p>
          </div>
        <% } %>
      </article>

      <article class="bg-surface-container-lowest rounded-xl overflow-hidden">
        <header class="px-6 py-4 border-b border-surface-container-high">
          <h2 class="font-headline text-xl text-on-surface">Top Products</h2>
        </header>

        <% if (topProducts && topProducts.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                  <th class="px-6 py-4">Product</th>
                  <th class="px-6 py-4">Units</th>
                  <th class="px-6 py-4">Revenue</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-container-high/50">
                <% topProducts.forEach(function(p) { %>
                  <tr class="hover:bg-surface-container-low/20 transition-colors">
                    <td class="px-6 py-4 text-sm text-on-surface font-medium"><%= p.name %></td>
                    <td class="px-6 py-4 text-sm text-on-surface"><%= Number(p.sold || 0) %></td>
                    <td class="px-6 py-4 text-sm text-on-surface">$<%= Number(p.revenue || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-12 text-center text-secondary">
            <span class="material-symbols-outlined text-5xl opacity-60">inventory_2</span>
            <p class="mt-2">No top product data for this period.</p>
          </div>
        <% } %>
      </article>

      <article class="xl:col-span-2 bg-surface-container-lowest rounded-xl overflow-hidden">
        <header class="px-6 py-4 border-b border-surface-container-high">
          <h2 class="font-headline text-xl text-on-surface">Top Artisans</h2>
        </header>

        <% if (topArtisans && topArtisans.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                  <th class="px-6 py-4">Artisan</th>
                  <th class="px-6 py-4">Shop</th>
                  <th class="px-6 py-4">Revenue</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-container-high/50">
                <% topArtisans.forEach(function(a) { %>
                  <tr class="hover:bg-surface-container-low/20 transition-colors">
                    <td class="px-6 py-4 text-sm text-on-surface"><%= a.name %></td>
                    <td class="px-6 py-4 text-sm text-on-surface"><%= a.shop_name || 'N/A' %></td>
                    <td class="px-6 py-4 text-sm text-on-surface">$<%= Number(a.revenue || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-12 text-center text-secondary">
            <span class="material-symbols-outlined text-5xl opacity-60">groups</span>
            <p class="mt-2">No artisan performance data for this period.</p>
          </div>
        <% } %>
      </article>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
