<%- include('../partials/header', { title: title }) %>
<%
  const statusFilter = filters && filters.status ? filters.status : '';
  const paymentFilter = filters && filters.payment_status ? filters.payment_status : '';
  const searchFilter = filters && filters.search ? filters.search : '';
  const orderStatusClass = function(status) {
    if (status === 'delivered') return 'bg-emerald-100 text-emerald-700';
    if (status === 'cancelled' || status === 'refunded') return 'bg-red-100 text-red-700';
    if (status === 'shipped' || status === 'processing') return 'bg-blue-100 text-blue-700';
    return 'bg-amber-100 text-amber-700';
  };
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Order Management</h1>
        <p class="text-secondary mt-1">Track payment and fulfillment states across all orders.</p>
      </div>
      <p class="text-xs text-secondary uppercase tracking-widest">Orders: <%= orders ? orders.length : 0 %></p>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-5 md:p-6 mb-6">
      <form method="GET" action="/admin/orders" class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Order Status</label>
          <select name="status" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All</option>
            <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="confirmed" <%= statusFilter === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
            <option value="processing" <%= statusFilter === 'processing' ? 'selected' : '' %>>Processing</option>
            <option value="shipped" <%= statusFilter === 'shipped' ? 'selected' : '' %>>Shipped</option>
            <option value="delivered" <%= statusFilter === 'delivered' ? 'selected' : '' %>>Delivered</option>
            <option value="cancelled" <%= statusFilter === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Payment</label>
          <select name="payment_status" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All</option>
            <option value="paid" <%= paymentFilter === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="pending" <%= paymentFilter === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="failed" <%= paymentFilter === 'failed' ? 'selected' : '' %>>Failed</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Search</label>
          <input type="text" name="search" value="<%= searchFilter %>" placeholder="Order id or customer" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Apply</button>
          <a href="/admin/orders" class="bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl font-semibold text-sm">Reset</a>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl overflow-hidden">
      <% if (orders && orders.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                <th class="px-6 py-4">Order</th>
                <th class="px-6 py-4">Customer</th>
                <th class="px-6 py-4">Total</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4">Payment</th>
                <th class="px-6 py-4">Date</th>
                <th class="px-6 py-4 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50">
              <% orders.forEach(function(o) { %>
                <tr class="hover:bg-surface-container-low/20 transition-colors">
                  <td class="px-6 py-5 text-sm font-semibold text-on-surface">#ORD-<%= String(o.id).padStart(4, '0') %></td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= o.customer_name %></td>
                  <td class="px-6 py-5 text-sm text-on-surface">$<%= Number(o.total_amount || 0).toFixed(2) %></td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= orderStatusClass(o.status) %>"><%= o.status %></span>
                  </td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= o.payment_status === 'paid' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>"><%= o.payment_status %></span>
                  </td>
                  <td class="px-6 py-5 text-sm text-secondary"><%= new Date(o.created_at).toLocaleDateString() %></td>
                  <td class="px-6 py-5 text-right">
                    <a href="/admin/orders/<%= o.id %>" class="bg-surface-container-high text-on-surface hover:bg-surface-container-highest px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">View</a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">receipt_long</span>
          <p class="text-secondary mt-3">No orders found for this filter.</p>
        </div>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
