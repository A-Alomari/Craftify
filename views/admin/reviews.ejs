<%- include('../partials/header', { title: title }) %>
<%
  const statusFilter = filters && filters.status ? filters.status : '';
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Administration</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Review Moderation</h1>
        <p class="text-secondary mt-1">Approve or remove community feedback for quality control.</p>
      </div>
      <p class="text-xs text-secondary uppercase tracking-widest">Reviews: <%= reviews ? reviews.length : 0 %></p>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-5 md:p-6 mb-6">
      <form method="GET" action="/admin/reviews" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Status</label>
          <select name="status" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
            <option value="">All</option>
            <option value="visible" <%= statusFilter === 'visible' ? 'selected' : '' %>>Approved</option>
            <option value="hidden" <%= statusFilter === 'hidden' ? 'selected' : '' %>>Pending/Hidden</option>
          </select>
        </div>
        <div class="flex items-end gap-2 md:col-span-2">
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Apply</button>
          <a href="/admin/reviews" class="bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl font-semibold text-sm">Reset</a>
        </div>
      </form>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl overflow-hidden">
      <% if (reviews && reviews.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                <th class="px-6 py-4">Product</th>
                <th class="px-6 py-4">Customer</th>
                <th class="px-6 py-4">Rating</th>
                <th class="px-6 py-4">Comment</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50">
              <% reviews.forEach(function(r) { %>
                <tr class="hover:bg-surface-container-low/20 transition-colors">
                  <td class="px-6 py-5 text-sm font-semibold text-on-surface"><%= r.product_name %></td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= r.reviewer_name %></td>
                  <td class="px-6 py-5">
                    <div class="flex items-center gap-1 text-amber-500">
                      <% for (let s = 0; s < Number(r.rating || 0); s++) { %>
                        <span class="material-symbols-outlined text-sm">star</span>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-6 py-5 text-sm text-secondary max-w-xs truncate"><%= r.comment || '' %></td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= r.is_approved ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>"><%= r.is_approved ? 'Approved' : 'Pending' %></span>
                  </td>
                  <td class="px-6 py-5 text-right">
                    <div class="inline-flex gap-2">
                      <% if (!r.is_approved) { %>
                        <form action="/admin/reviews/<%= r.id %>/approve" method="POST" class="inline-block">
                          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                          <button class="bg-emerald-100 text-emerald-700 hover:bg-emerald-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Approve</button>
                        </form>
                      <% } %>
                      <form action="/admin/reviews/<%= r.id %>/delete" method="POST" class="inline-block" data-confirm="Delete this review?">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">rate_review</span>
          <p class="text-secondary mt-3">No reviews found for this filter.</p>
        </div>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
