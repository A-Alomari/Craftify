<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4">
  <div class="row">
    <div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
    <div class="col-lg-10">
      <h3 class="mb-4"><i class="bi bi-speedometer2"></i> Admin Dashboard</h3>
      <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card bg-primary text-white shadow-sm"><div class="card-body"><h6>Users</h6><h3><%= userStats.total %></h3></div></div></div>
        <div class="col-md-3"><div class="card bg-success text-white shadow-sm"><div class="card-body"><h6>Products</h6><h3><%= productStats.total %></h3></div></div></div>
        <div class="col-md-3"><div class="card bg-info text-white shadow-sm"><div class="card-body"><h6>Orders</h6><h3><%= orderStats.total %></h3></div></div></div>
        <div class="col-md-3"><div class="card bg-warning text-white shadow-sm"><div class="card-body"><h6>Auctions</h6><h3><%= auctionStats.total %></h3></div></div></div>
      </div>
      <div class="row">
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm border-0"><div class="card-header bg-white"><h5 class="mb-0">Pending Artisans</h5></div><div class="card-body">
            <% if (pendingArtisans.length > 0) { pendingArtisans.forEach(function(a) { %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span><%= a.shop_name || a.name %></span>
                <div>
                  <form action="/admin/artisans/<%= a.user_id || a.id %>/approve" method="POST" class="d-inline"><button class="btn btn-sm btn-success">Approve</button></form>
                  <form action="/admin/artisans/<%= a.user_id || a.id %>/reject" method="POST" class="d-inline"><button class="btn btn-sm btn-danger">Reject</button></form>
                </div>
              </div>
            <% }); } else { %><p class="text-muted">No pending artisans.</p><% } %>
          </div></div>
        </div>
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm border-0"><div class="card-header bg-white"><h5 class="mb-0">Recent Orders</h5></div><div class="card-body">
            <% if (recentOrders.length > 0) { recentOrders.forEach(function(o) { %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span><a href="/admin/orders/<%= o.id %>">#<%= o.id %></a> - $<%= o.total_amount.toFixed(2) %></span>
                <span class="badge bg-<%= o.status === 'delivered' ? 'success' : 'primary' %>"><%= o.status %></span>
              </div>
            <% }); } else { %><p class="text-muted">No recent orders.</p><% } %>
          </div></div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
