<%- include('../partials/header', { title: 'Admin Dashboard | Craftify' }) %>

<div class="flex bg-surface min-h-screen">
    <%- include('./partials/sidebar') %>
    
    <main class="flex-grow pt-12 pb-20 px-8 max-w-7xl mx-auto min-h-screen">
        <!-- Header Section -->
        <header class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
        <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-2 block">System Overview</span>
        <h1 class="text-4xl font-bold text-on-surface">Admin Dashboard</h1>
        </div>
        <div class="flex gap-3">
        <button class="px-6 py-2.5 rounded-xl text-sm font-semibold text-secondary bg-surface-container-high hover:bg-surface-container-highest transition-all">
                            System Health
                        </button>
        </div>
        </header>
        <!-- Stats Bento Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <!-- Stat Card 1 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-sm relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 w-20 h-20 bg-primary/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative z-10">
        <span class="material-symbols-outlined text-primary mb-4 text-3xl">group</span>
        <p class="font-label text-xs uppercase tracking-widest text-on-secondary-container font-medium">Total Users</p>
        <h2 class="text-4xl font-headline font-bold mt-1 text-on-surface"><%= userStats ? userStats.total : 0 %></h2>
        </div>
        </div>
        <!-- Stat Card 2 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-sm relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 w-20 h-20 bg-secondary/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative z-10">
        <span class="material-symbols-outlined text-secondary mb-4 text-3xl">inventory_2</span>
        <p class="font-label text-xs uppercase tracking-widest text-on-secondary-container font-medium">Total Products</p>
        <h2 class="text-4xl font-headline font-bold mt-1 text-on-surface"><%= productStats ? productStats.total : 0 %></h2>
        </div>
        </div>
        <!-- Stat Card 3 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-sm relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 w-20 h-20 bg-tertiary/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative z-10">
        <span class="material-symbols-outlined text-tertiary mb-4 text-3xl">shopping_bag</span>
        <p class="font-label text-xs uppercase tracking-widest text-on-secondary-container font-medium">Total Orders</p>
        <h2 class="text-4xl font-headline font-bold mt-1 text-on-surface"><%= orderStats ? orderStats.total : 0 %></h2>
        </div>
        </div>
        <!-- Stat Card 4 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-sm relative overflow-hidden group">
        <div class="absolute -right-4 -top-4 w-20 h-20 bg-primary-container/10 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative z-10">
        <span class="material-symbols-outlined text-primary mb-4 text-3xl">gavel</span>
        <p class="font-label text-xs uppercase tracking-widest text-on-secondary-container font-medium">Total Auctions</p>
        <h2 class="text-4xl font-headline font-bold mt-1 text-on-surface"><%= auctionStats ? auctionStats.total : 0 %></h2>
        </div>
        </div>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
            <!-- Pending Artisans -->
            <section class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/10">
                <div class="px-8 py-6 flex justify-between items-center bg-surface-container-low/50">
                    <h3 class="text-xl font-serif font-bold">Pending Artisans</h3>
                    <a href="/admin/artisans" class="text-primary text-sm font-semibold hover:underline">View All</a>
                </div>
                <div class="p-6">
                    <% if (pendingArtisans && pendingArtisans.length > 0) { %>
                        <div class="space-y-4">
                        <% pendingArtisans.forEach(function(a) { %>
                            <div class="flex items-center justify-between p-4 bg-surface-container hover:bg-surface-container-high rounded-xl transition-colors">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-primary-container flex justify-center items-center text-primary font-bold"><%= (a.shop_name || a.name || 'A')[0].toUpperCase() %></div>
                                <div>
                                <h4 class="font-bold text-on-surface"><%= a.shop_name || a.name %></h4>
                                <p class="text-xs text-secondary"><%= a.email || 'Artisan Application' %></p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <form action="/admin/artisans/<%= a.user_id || a.id %>/approve" method="POST">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <button class="bg-emerald-100 text-emerald-700 hover:bg-emerald-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Approve</button>
                                </form>
                                <form action="/admin/artisans/<%= a.user_id || a.id %>/reject" method="POST">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Reject</button>
                                </form>
                            </div>
                            </div>
                        <% }); %>
                        </div>
                    <% } else { %>
                        <p class="text-secondary text-center py-8">No pending artisans.</p>
                    <% } %>
                </div>
            </section>

            <!-- Recent Orders -->
            <section class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/10">
                <div class="px-8 py-6 flex justify-between items-center bg-surface-container-low/50">
                    <h3 class="text-xl font-serif font-bold">Recent Orders</h3>
                    <a href="/admin/orders" class="text-primary text-sm font-semibold hover:underline">View All</a>
                </div>
                <div class="p-6">
                    <% if (recentOrders && recentOrders.length > 0) { %>
                        <div class="space-y-4">
                        <% recentOrders.forEach(function(o) { %>
                            <div class="flex items-center justify-between p-4 bg-surface-container hover:bg-surface-container-high rounded-xl transition-colors">
                            <div>
                                <a href="/admin/orders/<%= o.id %>" class="font-bold text-primary hover:underline">#ORD-<%= o.id.toString().padStart(4, '0') %></a>
                                <p class="text-xs text-secondary"><%= new Date(o.created_at).toLocaleDateString() %></p>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-on-surface">$<%= o.total_amount.toFixed(2) %></p>
                                <span class="text-[10px] uppercase tracking-widest px-2 py-0.5 rounded-full font-bold <%= o.status === 'delivered' ? 'bg-emerald-100 text-emerald-700' : (o.status === 'shipped' ? 'bg-blue-100 text-blue-700' : 'bg-amber-100 text-amber-700') %>">
                                    <%= o.status %>
                                </span>
                            </div>
                            </div>
                        <% }); %>
                        </div>
                    <% } else { %>
                        <p class="text-secondary text-center py-8">No recent orders.</p>
                    <% } %>
                </div>
            </section>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
