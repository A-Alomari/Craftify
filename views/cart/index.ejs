<%- include('../partials/header', { title: 'Shopping Cart | Craftify' }) %>

<main class="pt-12 pb-24 px-8 max-w-7xl mx-auto min-h-screen">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
<!-- Left Column: Cart Content -->
<div class="lg:col-span-8 space-y-8">
<h1 class="font-headline text-4xl font-bold text-on-surface mb-10">Shopping Cart</h1>

<% if (items && items.length > 0) { %>
    <div class="space-y-6">
    <% items.forEach(function(item) { %>
        <div class="bg-surface-container-lowest p-6 rounded-xl flex flex-col sm:flex-row items-start sm:items-center gap-6 transition-all hover:shadow-md">
            <div class="w-24 h-24 rounded-lg overflow-hidden flex-shrink-0 bg-surface-container-low">
                <img alt="<%= item.product_name %>" class="w-full h-full object-cover" src="<%= item.image || '/images/placeholder-product.svg' %>" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"/>
            </div>
            <div class="flex-grow space-y-1">
                <h3 class="font-headline text-lg font-bold text-on-surface"><%= item.product_name || item.name %></h3>
                <p class="text-sm text-on-secondary-container">by <%= item.shop_name || 'Artisan' %></p>
                <form action="/cart/remove" method="POST" class="inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="productId" value="<%= item.product_id %>">
                    <button type="submit" class="flex items-center gap-1 text-xs text-error mt-4 hover:underline">
                        <span class="material-symbols-outlined text-sm" data-icon="delete">delete</span>
                        Remove
                    </button>
                </form>
            </div>
            
            <div class="flex items-center gap-4 bg-surface-container-low px-3 py-1 rounded-full border border-outline-variant/20">
                <form action="/cart/update" method="POST" class="flex items-center">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="productId" value="<%= item.product_id %>">
                    <input type="hidden" name="quantity" value="<%= Math.max(0, item.quantity - 1) %>">
                    <button type="submit" class="w-8 h-8 flex items-center justify-center text-on-surface hover:text-primary transition-colors">
                        <span class="material-symbols-outlined text-lg" data-icon="remove">remove</span>
                    </button>
                </form>
                
                <span class="font-bold w-4 text-center"><%= item.quantity %></span>
                
                <form action="/cart/update" method="POST" class="flex items-center">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="productId" value="<%= item.product_id %>">
                    <input type="hidden" name="quantity" value="<%= item.quantity + 1 %>">
                    <button type="submit" class="w-8 h-8 flex items-center justify-center text-on-surface hover:text-primary transition-colors">
                        <span class="material-symbols-outlined text-lg" data-icon="add">add</span>
                    </button>
                </form>
            </div>
            <div class="text-right sm:min-w-[80px]">
                <span class="font-headline text-xl font-bold text-on-surface">$<%= (item.price * item.quantity).toFixed(2) %></span>
            </div>
        </div>
    <% }) %>
    </div>
<% } else { %>
    <div class="bg-surface-container-lowest p-12 rounded-xl text-center shadow-sm">
        <span class="material-symbols-outlined text-6xl text-secondary mb-4">shopping_cart</span>
        <h2 class="text-2xl font-bold font-headline mb-2">Your cart is empty</h2>
        <p class="text-secondary mb-6">Looks like you haven't added any artisanal items to your cart yet.</p>
        <a href="/products" class="inline-block bg-primary-container text-on-primary-container font-bold py-3 px-8 rounded-xl hover:opacity-90 transition-all">
            Start Shopping
        </a>
    </div>
<% } %>

<!-- Continue Shopping -->
<div class="pt-8 flex flex-col sm:flex-row sm:items-center gap-4">
<a class="inline-flex items-center gap-2 font-serif text-amber-700 hover:text-amber-800 transition-colors group" href="/products">
<span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform" data-icon="arrow_back">arrow_back</span>
    Continue Shopping
</a>
</div>
</div>

<!-- Right Column: Order Summary -->
<div class="lg:col-span-4">
<div class="sticky top-32 space-y-6">
<div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/10">
<h2 class="font-headline text-2xl font-bold mb-8 text-on-surface">Order Summary</h2>
<div class="space-y-4 mb-8">
<div class="flex justify-between items-center text-on-secondary-container">
<span class="text-sm font-label uppercase tracking-wider">Subtotal (<%= itemCount || 0 %> items)</span>
<span class="font-serif font-bold">$<%= (subtotal || 0).toFixed(2) %></span>
</div>
<div class="flex justify-between items-center text-on-secondary-container">
<span class="text-sm font-label uppercase tracking-wider">Shipping</span>
<span class="font-serif font-bold"><%= shipping === 0 ? 'Free' : '$' + shipping.toFixed(2) %></span>
</div>
<% if (discount > 0) { %>
<div class="flex justify-between items-center text-emerald-600">
<span class="text-sm font-label uppercase tracking-wider">Discount</span>
<span class="font-serif font-bold">-$<%= discount.toFixed(2) %></span>
</div>
<% } %>
<% if (appliedCoupon) { %>
<div class="rounded-xl bg-emerald-50 px-4 py-4 border border-emerald-200">
    <div class="flex items-start justify-between gap-4">
        <div>
            <p class="text-xs font-label uppercase tracking-widest text-emerald-700 mb-2">Applied Coupon</p>
            <p class="font-bold text-emerald-900"><%= appliedCoupon.code %></p>
            <% if (appliedCoupon.description) { %>
                <p class="text-sm text-emerald-800 mt-1"><%= appliedCoupon.description %></p>
            <% } %>
        </div>
        <form action="/cart/coupon/remove" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <button type="submit" class="text-xs font-semibold text-emerald-700 hover:underline">Remove</button>
        </form>
    </div>
</div>
<% } %>
<div class="h-[1px] bg-outline-variant/30 w-full my-4"></div>
<div class="flex justify-between items-center pt-2">
<span class="text-lg font-bold text-on-surface">Total</span>
<span class="font-headline text-3xl font-bold text-primary">$<%= (total || 0).toFixed(2) %></span>
</div>
</div>

<% if (items && items.length > 0) { %>
    <a href="/orders/checkout" class="w-full bg-primary-container text-on-primary-container py-5 rounded-xl font-bold text-lg hover:shadow-lg hover:opacity-90 transition-all flex items-center justify-center gap-3">
        Proceed to Checkout
        <% if (!(typeof user !== 'undefined' && user)) { %>
        <span class="material-symbols-outlined" data-icon="lock" data-weight="fill">lock</span>
        <% } %>
    </a>
    <form action="/cart/clear" method="POST" data-confirm="Clear your entire cart?" class="mt-3">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 text-sm font-semibold text-error hover:underline py-2">
            <span class="material-symbols-outlined text-base">delete_sweep</span>
            Clear Cart
        </button>
    </form>
<% } else { %>
    <button disabled class="w-full bg-surface-container-high text-on-surface-variant py-5 rounded-xl font-bold text-lg flex items-center justify-center gap-3 cursor-not-allowed">
        Proceed to Checkout
    </button>
<% } %>

<!-- Promo Code -->
<div class="mt-6 bg-tertiary-container/10 p-6 rounded-xl border border-tertiary-container/20">
<label class="block text-xs font-bold uppercase tracking-widest text-tertiary mb-3">Apply Promo Code</label>
<form id="coupon-form" action="/cart/coupon" method="POST" class="flex flex-col sm:flex-row gap-2">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<input id="coupon-input" name="code" value="<%= appliedCoupon ? appliedCoupon.code : '' %>" class="flex-grow min-w-0 bg-surface-container-lowest border-none rounded-lg text-sm px-4 py-3 focus:ring-2 focus:ring-tertiary" placeholder="Enter code" type="text"/>
<button id="coupon-submit" type="submit" class="bg-tertiary text-on-tertiary px-6 py-3 rounded-lg text-sm font-bold uppercase tracking-wider hover:opacity-90 sm:w-auto disabled:opacity-40 disabled:cursor-not-allowed" <%= !appliedCoupon ? 'disabled' : '' %>>Apply</button>
</form>
</div>

<div class="mt-6 flex flex-col items-center gap-3 text-on-secondary-container/70 text-xs tracking-tight">
<div class="flex items-center gap-1.5">
<span class="material-symbols-outlined text-sm" data-icon="verified_user">verified_user</span>
    Secure Checkout · Money-back Guarantee
</div>
</div>
</div>
</div>
</div>
</div>
</main>

<script>
(function() {
  var form = document.getElementById('coupon-form');
  var input = document.getElementById('coupon-input');
  var btn = document.getElementById('coupon-submit');
  if (!form || !input || !btn) return;

  function syncBtn() {
    btn.disabled = !input.value.trim();
  }

  // Sync on load and on input
  syncBtn();
  input.addEventListener('input', syncBtn);

  // Prevent Enter key when empty
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !input.value.trim()) {
      e.preventDefault();
    }
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var code = input.value.trim();
    if (!code) return;
    var csrf = (form.querySelector('input[name="_csrf"]') || {}).value || '';
    var origText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Applying...';
    fetch('/cart/coupon', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        'x-csrf-token': csrf
      },
      body: JSON.stringify({ code: code })
    }).then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success) {
        window.location.reload();
      } else {
        btn.disabled = false;
        btn.textContent = origText;
        if (typeof showToast === 'function') showToast(data.message || 'Invalid coupon code', 'error');
      }
    }).catch(function() {
      btn.disabled = false;
      btn.textContent = origText;
      if (typeof showToast === 'function') showToast('Error applying coupon', 'error');
    });
  }, true);
})();
</script>

<%- include('../partials/footer') %>
