<%- include('../partials/header', { title: title }) %>

<div class="container py-4">
  <h3 class="mb-4"><i class="bi bi-cart3"></i> Shopping Cart</h3>

  <% if (items.length > 0) { %>
    <div class="row">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
          <div class="card-body">
            <% items.forEach(function(item) { %>
              <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                <img src="<%= item.image %>" alt="<%= item.name %>" class="rounded me-3" style="width: 80px; height: 80px; object-fit: cover;">
                <div class="flex-grow-1">
                  <h6 class="mb-0"><%= item.name %></h6>
                  <% if (item.shop_name) { %>
                    <small class="text-muted"><%= item.shop_name %></small>
                  <% } %>
                  <div class="mt-1 fw-bold text-primary">$<%= item.price.toFixed(2) %></div>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <form action="/cart/update" method="POST" class="d-flex align-items-center">
                    <input type="hidden" name="productId" value="<%= item.product_id %>">
                    <div class="input-group input-group-sm" style="width: 120px;">
                      <button type="submit" name="quantity" value="<%= Math.max(1, item.quantity - 1) %>" class="btn btn-outline-secondary">-</button>
                      <input type="text" class="form-control text-center" value="<%= item.quantity %>" readonly>
                      <button type="submit" name="quantity" value="<%= item.quantity + 1 %>" class="btn btn-outline-secondary">+</button>
                    </div>
                  </form>
                  <form action="/cart/remove" method="POST">
                    <input type="hidden" name="productId" value="<%= item.product_id %>">
                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
                <div class="ms-3 text-end" style="min-width: 80px;">
                  <strong>$<%= (item.price * item.quantity).toFixed(2) %></strong>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Coupon -->
        <div class="card shadow-sm border-0 mb-4">
          <div class="card-body">
            <h6>Have a coupon?</h6>
            <% if (appliedCoupon) { %>
              <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-success"><i class="bi bi-tag"></i> <%= appliedCoupon.code %> applied - Saving $<%= discount.toFixed(2) %></span>
                <form action="/cart/coupon/remove" method="POST">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                </form>
              </div>
            <% } else { %>
              <form action="/cart/coupon" method="POST" class="d-flex gap-2">
                <input type="text" name="code" class="form-control" placeholder="Enter coupon code">
                <button type="submit" class="btn btn-outline-primary">Apply</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="d-flex justify-content-between">
          <a href="/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Continue Shopping</a>
          <form action="/cart/clear" method="POST">
            <button type="submit" class="btn btn-outline-danger">Clear Cart</button>
          </form>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h5 class="mb-3">Order Summary</h5>
            <div class="d-flex justify-content-between mb-2">
              <span>Subtotal (<%= itemCount %> items)</span>
              <span>$<%= subtotal.toFixed(2) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Shipping</span>
              <span><%= shipping === 0 ? 'FREE' : '$' + shipping.toFixed(2) %></span>
            </div>
            <% if (discount > 0) { %>
              <div class="d-flex justify-content-between mb-2 text-success">
                <span>Discount</span>
                <span>-$<%= discount.toFixed(2) %></span>
              </div>
            <% } %>
            <hr>
            <div class="d-flex justify-content-between mb-3 fw-bold fs-5">
              <span>Total</span>
              <span class="text-primary">$<%= total.toFixed(2) %></span>
            </div>
            <% if (subtotal < 50 && shipping > 0) { %>
              <p class="small text-muted text-center mb-3">Free shipping on orders over $50!</p>
            <% } %>
            <a href="/orders/checkout" class="btn btn-primary w-100 py-2"><i class="bi bi-lock"></i> Proceed to Checkout</a>
          </div>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-cart-x display-1 text-muted"></i>
      <h4 class="mt-3">Your cart is empty</h4>
      <p class="text-muted">Browse our products and add something you love!</p>
      <a href="/products" class="btn btn-primary"><i class="bi bi-shop"></i> Start Shopping</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
