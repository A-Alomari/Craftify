<%- include('../partials/header', { title: title }) %>
<div class="container py-5 text-center">
  <i class="bi bi-hourglass-split display-1 text-warning"></i>
  <h2 class="mt-3">Pending Approval</h2>
  <p class="text-muted mb-4">Your artisan account is currently under review. Our team will verify your application and notify you once it's approved.</p>
  <p>In the meantime, you can update your profile below:</p>
  <% if (profile) { %>
    <div class="card shadow-sm border-0 mx-auto mt-4"><div class="card-body text-start">
      <p><strong>Shop Name:</strong> <%= profile.shop_name %></p>
      <p><strong>Status:</strong> <span class="badge bg-warning">Pending</span></p>
    </div></div>
  <% } %>
  <a href="/" class="btn btn-outline-primary mt-4">Go Home</a>
</div>
<%- include('../partials/footer') %>
