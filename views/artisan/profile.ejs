<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-5xl mx-auto mt-8 mb-6">
      <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Artisan Studio</span>
      <h1 class="font-headline text-3xl text-on-surface mt-2">Shop Profile</h1>
      <p class="text-secondary mt-1">Present your brand story and policies clearly.</p>
    </section>

    <section class="max-w-5xl mx-auto bg-surface-container-lowest rounded-xl p-6 md:p-8">
      <form action="/artisan/profile" method="POST" enctype="multipart/form-data" class="space-y-5">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Shop Name</label>
          <input type="text" name="shop_name" value="<%= profile && profile.shop_name ? profile.shop_name : '' %>" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container">
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Bio</label>
          <textarea name="bio" rows="5" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container"><%= profile && profile.bio ? profile.bio : '' %></textarea>
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Return Policy</label>
          <textarea name="return_policy" rows="4" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-primary-container"><%= profile && profile.return_policy ? profile.return_policy : '' %></textarea>
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-secondary font-bold mb-2">Profile Image</label>
          <input type="file" name="profile_image" accept="image/jpeg,image/png,image/webp" class="w-full bg-surface-container-low border-none rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-primary-container">
        </div>

        <div class="flex justify-end">
          <button type="submit" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm">Save Profile</button>
        </div>
      </form>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
