<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-person"></i> Shop Profile</h3>
  <div class="card shadow-sm border-0"><div class="card-body">
    <form action="/artisan/profile" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="mb-3"><label class="form-label">Shop Name</label><input type="text" name="shop_name" class="form-control" value="<%= profile.shop_name %>"></div>
      <div class="mb-3"><label class="form-label">Bio</label><textarea name="bio" class="form-control" rows="3"><%= profile.bio || '' %></textarea></div>
      <div class="mb-3"><label class="form-label">Return Policy</label><textarea name="return_policy" class="form-control" rows="2"><%= profile.return_policy || '' %></textarea></div>
      <div class="mb-3"><label class="form-label">Profile Image</label><input type="file" name="profile_image" class="form-control" accept="image/*"></div>
      <button type="submit" class="btn btn-primary">Save Profile</button>
    </form>
  </div></div>
</div></div></div>
<%- include('../partials/footer') %>
