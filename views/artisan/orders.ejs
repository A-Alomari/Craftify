<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-bag"></i> Orders</h3>
  <% if (orders.length > 0) { %>
    <div class="table-responsive"><table class="table table-hover"><thead><tr><th>#</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th><th></th></tr></thead>
    <tbody><% orders.forEach(function(o) { %><tr>
      <td>#<%= o.id %></td><td><%= o.customer_name %></td><td>$<%= o.total_amount.toFixed(2) %></td>
      <td><span class="badge bg-<%= o.status === 'delivered' ? 'success' : 'primary' %>"><%= o.status %></span></td>
      <td><%= new Date(o.created_at).toLocaleDateString() %></td>
      <td>
        <a href="/artisan/orders/<%= o.id %>" class="btn btn-sm btn-outline-primary">View</a>
        <% if (['confirmed', 'processing'].indexOf(o.status) >= 0) { %>
          <form action="/artisan/orders/<%= o.id %>/status" method="POST" class="d-inline"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><input type="hidden" name="status" value="shipped"><button class="btn btn-sm btn-success">Ship</button></form>
        <% } %>
      </td>
    </tr><% }); %></tbody></table></div>
  <% } else { %><div class="text-center py-5"><p class="text-muted">No orders yet.</p></div><% } %>
</div></div></div>
<%- include('../partials/footer') %>
