<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-star"></i> Reviews</h3>
  <% if (reviews.length > 0) { reviews.forEach(function(r) { %>
    <div class="card shadow-sm border-0 mb-2"><div class="card-body d-flex justify-content-between align-items-center">
      <div>
        <strong><%= r.product_name %></strong> - <% for (var s = 0; s < r.rating; s++) { %><i class="bi bi-star-fill text-warning small"></i><% } %>
        <p class="mb-0 small text-muted">By <%= r.reviewer_name %> - "<%= r.comment %>"</p>
      </div>
      <span class="badge bg-<%= r.is_approved ? 'success' : 'warning' %>"><%= r.is_approved ? 'Approved' : 'Pending' %></span>
    </div></div>
  <% }); } else { %><p class="text-muted">No reviews yet.</p><% } %>
</div></div></div>
<%- include('../partials/footer') %>
