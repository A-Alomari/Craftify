<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-6xl mx-auto mt-8 mb-6">
      <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Artisan Studio</span>
      <h1 class="font-headline text-3xl text-on-surface mt-2">Customer Reviews</h1>
      <p class="text-secondary mt-1">Read buyer feedback and sentiment on your products.</p>
    </section>

    <section class="max-w-6xl mx-auto space-y-4">
      <% if (reviews && reviews.length > 0) { %>
        <% reviews.forEach(function(r) { %>
          <article class="bg-surface-container-lowest rounded-xl p-5 md:p-6">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
              <div>
                <h2 class="font-headline text-xl text-on-surface"><%= r.product_name %></h2>
                <div class="mt-2 flex items-center gap-1 text-amber-500">
                  <% for (let s = 0; s < Number(r.rating || 0); s++) { %>
                    <span class="material-symbols-outlined text-sm">star</span>
                  <% } %>
                </div>
                <p class="text-sm text-secondary mt-3">By <%= r.reviewer_name %></p>
                <p class="text-sm text-on-surface mt-2">"<%= r.comment %>"</p>
              </div>
              <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest self-start <%= r.is_approved ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>"><%= r.is_approved ? 'Approved' : 'Pending' %></span>
            </div>
          </article>
        <% }); %>
      <% } else { %>
        <article class="bg-surface-container-lowest rounded-xl py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">rate_review</span>
          <p class="text-secondary mt-3">No reviews yet.</p>
        </article>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
