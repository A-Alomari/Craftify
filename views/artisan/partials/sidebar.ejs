<%
    const currentPathValue = typeof currentPath === 'string' ? currentPath : '';
    const isActive = (href) => currentPathValue === href || currentPathValue.startsWith(`${href}/`);
    const artisanName = user && user.name ? user.name : 'Artisan Workspace';
    const navItems = [
        { href: '/artisan/dashboard', icon: 'dashboard', label: 'Dashboard' },
        { href: '/artisan/products', icon: 'inventory_2', label: 'Products' },
        { href: '/artisan/orders', icon: 'shopping_bag', label: 'Orders' },
        { href: '/artisan/auctions', icon: 'gavel', label: 'Auctions' },
        { href: '/artisan/coupons', icon: 'local_offer', label: 'Promo Codes' },
        { href: '/artisan/reviews', icon: 'rate_review', label: 'Reviews' },
        { href: '/artisan/analytics', icon: 'leaderboard', label: 'Analytics' },
        { href: '/artisan/profile', icon: 'person', label: 'Profile' }
    ];
    const mobileNavItems = [
        { href: '/artisan/dashboard', icon: 'dashboard',   label: 'Home',     exact: true  },
        { href: '/artisan/products',  icon: 'inventory_2', label: 'Products', exact: false },
        { href: '/artisan/orders',    icon: 'shopping_bag',label: 'Orders',   exact: false },
        { href: '/artisan/auctions',  icon: 'gavel',       label: 'Auctions', exact: false },
        { href: '/artisan/profile',   icon: 'person',      label: 'Profile',  exact: false }
    ];
%>

<aside class="hidden md:flex w-64 flex-shrink-0 bg-surface-container-low py-6 px-4 flex-col min-h-screen sticky top-0 h-screen overflow-y-auto">
    <div class="mb-10 px-2 flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container text-3xl">handyman</span>
        <div>
            <h1 class="font-headline text-2xl font-bold text-primary-container leading-tight">Craftify</h1>
            <p class="text-[10px] font-medium tracking-[0.2em] text-secondary uppercase opacity-70">Artisan Studio</p>
        </div>
    </div>

    <nav class="flex-1 space-y-1">
        <% navItems.forEach(function(item) { const active = isActive(item.href); %>
            <a
                href="<%= item.href %>"
                class="flex items-center gap-3 px-4 py-3 transition-colors duration-200 <%= active ? 'text-primary font-bold border-l-4 border-primary-container bg-surface-container-high' : 'text-secondary hover:text-on-surface hover:bg-surface-container-high' %>"
            >
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' <%= active ? 1 : 0 %>"><%= item.icon %></span>
                <span class="font-body text-sm font-medium tracking-wide"><%= item.label %></span>
            </a>
        <% }); %>
    </nav>

    <div class="pt-6 border-t border-surface-container-high space-y-1">
        <a href="/artisan/products/new" class="w-full bg-primary-container text-on-primary-container font-semibold py-3 px-4 rounded-xl mb-4 flex items-center justify-center gap-2 active:opacity-80 transition-all">
            <span class="material-symbols-outlined text-lg">add</span>
            New Product
        </a>

        <a href="/products" class="flex items-center gap-3 px-4 py-2 text-secondary hover:text-on-surface transition-colors">
            <span class="material-symbols-outlined">storefront</span>
            <span class="font-body text-sm font-medium">Marketplace</span>
        </a>

        <form action="/auth/logout" method="POST" class="m-0">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <button type="submit" class="w-full flex items-center gap-3 px-4 py-2 text-secondary hover:text-tertiary transition-colors text-left">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-body text-sm font-medium">Logout</span>
            </button>
        </form>

        <p class="px-4 pt-3 text-[10px] uppercase tracking-widest text-secondary"><%= artisanName %></p>
    </div>
</aside>

<!-- Mobile bottom navigation (shown instead of sidebar on small screens) -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-surface/90 backdrop-blur-xl border-t border-outline-variant/10 flex justify-around items-center px-1 py-2">
  <% mobileNavItems.forEach(function(n) {
    const _a = n.exact ? currentPathValue === n.href : currentPathValue.startsWith(n.href);
  %>
  <a href="<%= n.href %>" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl <%= _a ? 'text-primary' : 'text-secondary' %>">
    <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' <%= _a ? 1 : 0 %>"><%= n.icon %></span>
    <span class="text-[9px] font-label font-bold uppercase tracking-wide"><%= n.label %></span>
  </a>
  <% }); %>
</nav>
