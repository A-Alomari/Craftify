<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Artisan Studio</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Sales Analytics</h1>
        <p class="text-secondary mt-1">Track product performance and monthly revenue trends.</p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Products</p>
        <p class="font-headline text-3xl text-on-surface mt-3"><%= stats ? stats.total_products : 0 %></p>
      </article>
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Orders</p>
        <p class="font-headline text-3xl text-on-surface mt-3"><%= stats ? stats.total_orders : 0 %></p>
      </article>
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Revenue</p>
        <p class="font-headline text-3xl text-on-surface mt-3">$<%= stats ? Number(stats.total_revenue || 0).toFixed(2) : '0.00' %></p>
      </article>
      <article class="bg-surface-container-lowest rounded-xl p-5">
        <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Average Rating</p>
        <p class="font-headline text-3xl text-on-surface mt-3"><%= stats && stats.avg_rating ? Number(stats.avg_rating).toFixed(1) : 'N/A' %></p>
      </article>
    </section>

    <section class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-2 gap-6">
      <article class="bg-surface-container-lowest rounded-xl overflow-hidden">
        <header class="px-6 py-4 border-b border-surface-container-high">
          <h2 class="font-headline text-xl text-on-surface">Monthly Revenue</h2>
        </header>

        <% if (monthlyRevenue && monthlyRevenue.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                  <th class="px-6 py-4">Month</th>
                  <th class="px-6 py-4">Revenue</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-container-high/50">
                <% monthlyRevenue.forEach(function(m) { %>
                  <tr class="hover:bg-surface-container-low/20 transition-colors">
                    <td class="px-6 py-4 text-sm text-on-surface"><%= m.month %></td>
                    <td class="px-6 py-4 text-sm text-on-surface">$<%= Number(m.revenue || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-12 text-center text-secondary">
            <span class="material-symbols-outlined text-5xl opacity-60">insert_chart</span>
            <p class="mt-2">No revenue data available yet.</p>
          </div>
        <% } %>
      </article>

      <article class="bg-surface-container-lowest rounded-xl overflow-hidden">
        <header class="px-6 py-4 border-b border-surface-container-high">
          <h2 class="font-headline text-xl text-on-surface">Top Products</h2>
        </header>

        <% if (topProducts && topProducts.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                  <th class="px-6 py-4">Product</th>
                  <th class="px-6 py-4">Sold</th>
                  <th class="px-6 py-4">Revenue</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-container-high/50">
                <% topProducts.forEach(function(p) { %>
                  <tr class="hover:bg-surface-container-low/20 transition-colors">
                    <td class="px-6 py-4 text-sm text-on-surface"><%= p.name %></td>
                    <td class="px-6 py-4 text-sm text-on-surface"><%= Number(p.sold || 0) %></td>
                    <td class="px-6 py-4 text-sm text-on-surface">$<%= Number(p.revenue || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-12 text-center text-secondary">
            <span class="material-symbols-outlined text-5xl opacity-60">inventory_2</span>
            <p class="mt-2">No product performance data yet.</p>
          </div>
        <% } %>
      </article>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
