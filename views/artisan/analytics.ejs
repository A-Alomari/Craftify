<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><i class="bi bi-graph-up"></i> Analytics</h3>
  <div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body text-center"><h6 class="text-muted">Products</h6><h3><%= stats.total_products %></h3></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body text-center"><h6 class="text-muted">Orders</h6><h3><%= stats.total_orders %></h3></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body text-center"><h6 class="text-muted">Revenue</h6><h3>$<%= (stats.total_revenue || 0).toFixed(2) %></h3></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body text-center"><h6 class="text-muted">Rating</h6><h3><%= stats.avg_rating ? stats.avg_rating.toFixed(1) : 'N/A' %></h3></div></div></div>
  </div>
  <% if (topProducts.length > 0) { %>
    <div class="card shadow-sm border-0 mb-4"><div class="card-header bg-white"><h5>Top Products</h5></div><div class="card-body">
      <table class="table"><thead><tr><th>Product</th><th>Sold</th><th>Revenue</th></tr></thead>
      <tbody><% topProducts.forEach(function(p) { %><tr><td><%= p.name %></td><td><%= p.sold %></td><td>$<%= (p.revenue || 0).toFixed(2) %></td></tr><% }); %></tbody></table>
    </div></div>
  <% } %>
</div></div></div>
<%- include('../partials/footer') %>
