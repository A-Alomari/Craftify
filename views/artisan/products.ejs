<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <div class="d-flex justify-content-between align-items-center mb-4"><h3><i class="bi bi-box"></i> My Products</h3><a href="/artisan/products/new" class="btn btn-primary"><i class="bi bi-plus"></i> Add Product</a></div>
  <% if (products.length > 0) { %>
    <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Product</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr></thead>
    <tbody><% products.forEach(function(p) { %><tr>
      <td><%= p.name %></td><td>$<%= p.price.toFixed(2) %></td><td><%= p.stock %></td>
      <td><span class="badge bg-<%= p.status === 'approved' ? 'success' : p.status === 'pending' ? 'warning' : 'danger' %>"><%= p.status %></span></td>
      <td><a href="/artisan/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
      <form action="/artisan/products/<%= p.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?')"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></td>
    </tr><% }); %></tbody></table></div>
  <% } else { %><div class="text-center py-5"><p class="text-muted">No products yet. <a href="/artisan/products/new">Add your first product!</a></p></div><% } %>
</div></div></div>
<%- include('../partials/footer') %>
