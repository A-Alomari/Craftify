<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="font-label text-xs tracking-[0.2em] text-primary font-semibold uppercase">Artisan Studio</span>
        <h1 class="font-headline text-3xl text-on-surface mt-2">My Products</h1>
        <p class="text-secondary mt-1">Maintain catalog, stock, and moderation status.</p>
      </div>
      <a href="/artisan/products/new" class="bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl font-semibold text-sm inline-flex items-center gap-2">
        <span class="material-symbols-outlined text-base">add</span>
        Add Product
      </a>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl overflow-hidden">
      <% if (products && products.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[10px] font-bold text-secondary uppercase tracking-widest border-b border-surface-container-high">
                <th class="px-6 py-4">Product</th>
                <th class="px-6 py-4">Price</th>
                <th class="px-6 py-4">Stock</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50">
              <% products.forEach(function(p) { %>
                <tr class="hover:bg-surface-container-low/20 transition-colors">
                  <td class="px-6 py-5 text-sm font-semibold text-on-surface"><%= p.name %></td>
                  <td class="px-6 py-5 text-sm text-on-surface">$<%= Number(p.price || 0).toFixed(2) %></td>
                  <td class="px-6 py-5 text-sm text-on-surface"><%= p.stock %></td>
                  <td class="px-6 py-5">
                    <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= p.status === 'approved' ? 'bg-emerald-100 text-emerald-700' : (p.status === 'pending' ? 'bg-amber-100 text-amber-700' : 'bg-red-100 text-red-700') %>"><%= p.status %></span>
                  </td>
                  <td class="px-6 py-5 text-right">
                    <div class="inline-flex gap-2">
                      <a href="/artisan/products/<%= p.id %>/edit" class="bg-surface-container-high text-on-surface hover:bg-surface-container-highest px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Edit</a>
                      <form action="/artisan/products/<%= p.id %>/delete" method="POST" class="inline-block" onsubmit="return confirm('Delete this product?');">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-lg text-xs font-bold transition-colors">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-14 text-center">
          <span class="material-symbols-outlined text-5xl text-secondary/60">inventory_2</span>
          <p class="text-secondary mt-3">No products yet. Add your first listing.</p>
        </div>
      <% } %>
    </section>

    <%- include('../partials/pagination', { pagination: pagination, baseUrl: '/artisan/products', queryString: '' }) %>
  </main>
</div>

<%- include('../partials/footer') %>
