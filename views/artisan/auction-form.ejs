<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4">Create Auction</h3>
  <div class="card shadow-sm border-0"><div class="card-body">
    <form action="/artisan/auctions" method="POST">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="mb-3"><label class="form-label">Select Product *</label>
        <select name="product_id" class="form-select" required><option value="">Choose a product...</option>
          <% products.forEach(function(p) { %><option value="<%= p.id %>"><%= p.name %> ($<%= p.price.toFixed(2) %>)</option><% }); %>
        </select>
      </div>
      <div class="mb-3"><label class="form-label">Auction Title</label><input type="text" name="title" class="form-control"></div>
      <div class="mb-3"><label class="form-label">Description</label><textarea name="description" class="form-control" rows="3"></textarea></div>
      <div class="row">
        <div class="col-md-4 mb-3"><label class="form-label">Starting Bid ($) *</label><input type="number" name="starting_bid" class="form-control" step="0.01" required></div>
        <div class="col-md-4 mb-3"><label class="form-label">Reserve Price ($)</label><input type="number" name="reserve_price" class="form-control" step="0.01"></div>
        <div class="col-md-4 mb-3"><label class="form-label">Bid Increment ($)</label><input type="number" name="bid_increment" class="form-control" step="0.01" value="1.00"></div>
      </div>
      <div class="row">
        <div class="col-md-6 mb-3"><label class="form-label">Start Time *</label><input type="datetime-local" name="start_time" class="form-control" required></div>
        <div class="col-md-6 mb-3"><label class="form-label">End Time *</label><input type="datetime-local" name="end_time" class="form-control" required></div>
      </div>
      <button type="submit" class="btn btn-primary">Create Auction</button>
    </form>
  </div></div>
</div></div></div>
<%- include('../partials/footer') %>
