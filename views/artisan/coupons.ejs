<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-w-0 pb-24 md:pb-0 p-6 md:p-8">

    <!-- Header -->
    <div class="mb-8">
      <span class="font-label text-xs uppercase tracking-[0.2em] text-secondary font-bold mb-1 block">Artisan Tools</span>
      <h1 class="text-3xl font-headline font-bold text-on-surface">Promo Codes</h1>
      <p class="text-secondary text-sm font-body mt-1">Create and manage discount codes for your shop.</p>
    </div>

    <!-- Flash messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg) { %>
      <div class="mb-6 bg-green-50 text-green-800 px-5 py-3 rounded-xl text-sm font-body">
        <%= success_msg %>
      </div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
      <div class="mb-6 bg-red-50 text-error px-5 py-3 rounded-xl text-sm font-body flex items-center gap-3">
        <span class="material-symbols-outlined text-error text-xl">error</span><%= error_msg %>
      </div>
    <% } %>

    <!-- 12-col Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-8">

      <!-- Coupons Table (8 cols) -->
      <div class="lg:col-span-8 bg-surface-container-lowest rounded-2xl overflow-hidden">
        <div class="px-6 py-5 flex items-center justify-between">
          <h2 class="font-headline text-lg font-bold text-on-surface">Your Codes</h2>
          <span class="text-xs font-bold text-secondary font-label"><%= coupons.length %> code<%= coupons.length !== 1 ? 's' : '' %></span>
        </div>

        <% if (coupons && coupons.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm font-body">
              <thead>
                <tr class="bg-surface-container-low">
                  <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-widest text-secondary">Code</th>
                  <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-widest text-secondary">Discount</th>
                  <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-widest text-secondary">Status</th>
                  <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-widest text-secondary">Usage</th>
                  <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-widest text-secondary">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% coupons.forEach(c => { %>
                  <tr class="border-t border-surface-container-low hover:bg-surface-container-low/40 transition-colors">
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-primary-container/20 flex items-center justify-center flex-shrink-0">
                          <span class="material-symbols-outlined text-primary text-sm">confirmation_number</span>
                        </div>
                        <div>
                          <p class="font-bold text-on-surface font-label tracking-wider"><%= c.code %></p>
                          <% if (c.description) { %>
                            <p class="text-secondary text-xs mt-0.5 max-w-[160px] truncate"><%= c.description %></p>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <p class="font-bold text-on-surface">
                        <% if (c.discount_type === 'percentage') { %>
                          <%= c.discount_value %>%
                        <% } else { %>
                          BD <%= parseFloat(c.discount_value).toFixed(2) %>
                        <% } %>
                      </p>
                      <% if (c.min_purchase > 0) { %>
                        <p class="text-secondary text-xs">min BD <%= parseFloat(c.min_purchase).toFixed(2) %></p>
                      <% } %>
                    </td>
                    <td class="px-4 py-4">
                      <form action="/artisan/coupons/<%= c.id %>/toggle" method="POST" class="inline">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button type="submit"
                          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold transition-colors
                            <%= c.is_active ? 'bg-green-100 text-green-800 hover:bg-green-200' : 'bg-surface-container-low text-secondary hover:bg-surface-container-high' %>">
                          <span class="w-1.5 h-1.5 rounded-full inline-block <%= c.is_active ? 'bg-green-500' : 'bg-secondary/50' %>"></span>
                          <%= c.is_active ? 'Active' : 'Inactive' %>
                        </button>
                      </form>
                    </td>
                    <td class="px-4 py-4 text-secondary">
                      <%= c.used_count || 0 %><% if (c.usage_limit) { %>/<%= c.usage_limit %><% } %>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <form action="/artisan/coupons/<%= c.id %>/delete" method="POST" class="inline" data-confirm="Delete promo code '<%= c.code %>'?">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button type="submit" class="text-secondary hover:text-error transition-colors p-1.5 rounded-lg hover:bg-red-50">
                          <span class="material-symbols-outlined text-sm">delete</span>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="px-6 py-16 text-center">
            <span class="material-symbols-outlined text-4xl text-secondary/20 block mb-3">confirmation_number</span>
            <p class="text-secondary font-body text-sm">No promo codes yet. Create your first one →</p>
          </div>
        <% } %>
      </div>

      <!-- Right Panel (4 cols) -->
      <div class="lg:col-span-4 space-y-5">

        <!-- Performance Insights -->
        <div class="bg-primary-container rounded-2xl p-6">
          <h3 class="font-headline text-base font-bold text-on-primary-container mb-4">Performance</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-on-primary-container/70 text-sm font-body">Total codes</span>
              <span class="font-bold text-on-primary-container"><%= coupons.length %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-primary-container/70 text-sm font-body">Active</span>
              <span class="font-bold text-on-primary-container"><%= coupons.filter(c => c.is_active).length %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-on-primary-container/70 text-sm font-body">Total uses</span>
              <span class="font-bold text-on-primary-container"><%= coupons.reduce((s, c) => s + (c.used_count || 0), 0) %></span>
            </div>
            <% if (coupons.length > 0) { %>
              <%
                var topCoupon = coupons.slice().sort((a, b) => (b.used_count || 0) - (a.used_count || 0))[0];
              %>
              <% if (topCoupon && (topCoupon.used_count || 0) > 0) { %>
                <div class="pt-3 mt-3 border-t border-on-primary-container/10">
                  <p class="text-xs text-on-primary-container/60 font-label uppercase tracking-widest mb-1">Top code</p>
                  <p class="font-bold text-on-primary-container font-label tracking-wider"><%= topCoupon.code %></p>
                  <p class="text-on-primary-container/60 text-xs"><%= topCoupon.used_count %> uses</p>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>

        <!-- Create Form -->
        <div class="bg-surface-container-lowest rounded-2xl p-6">
          <h3 class="font-headline text-base font-bold text-on-surface mb-5">Create New Code</h3>

          <form action="/artisan/coupons" method="POST" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Code <span class="text-error">*</span></label>
              <input type="text" name="code" required placeholder="e.g. SUMMER20"
                class="w-full bg-surface-container-low rounded-xl px-4 py-2.5 text-on-surface placeholder:text-secondary/40 focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-label tracking-wider uppercase text-sm">
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Description</label>
              <input type="text" name="description" placeholder="e.g. Summer sale"
                class="w-full bg-surface-container-low rounded-xl px-4 py-2.5 text-on-surface placeholder:text-secondary/40 focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Type <span class="text-error">*</span></label>
                <select name="discount_type" required
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm appearance-none">
                  <option value="percentage">Percentage</option>
                  <option value="fixed">Fixed (BD)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Value <span class="text-error">*</span></label>
                <input type="number" name="discount_value" required min="0.01" step="0.01" placeholder="20"
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface placeholder:text-secondary/40 focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Min Order</label>
                <input type="number" name="min_purchase" min="0" step="0.01" placeholder="0.00"
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface placeholder:text-secondary/40 focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Max Uses</label>
                <input type="number" name="usage_limit" min="1" step="1" placeholder="∞"
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface placeholder:text-secondary/40 focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Valid From</label>
                <input type="date" name="valid_from"
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-secondary mb-1.5 ml-1">Valid Until</label>
                <input type="date" name="valid_until"
                  class="w-full bg-surface-container-low rounded-xl px-3 py-2.5 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary-container transition-all font-body text-sm">
              </div>
            </div>

            <button type="submit"
              class="w-full bg-primary-container text-on-primary-container font-bold py-3 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-sm">
              <span class="material-symbols-outlined text-sm">add</span>
              Create Promo Code
            </button>
          </form>
        </div>

      </div>
    </div>

    <!-- Editorial Bottom Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Maker Tips -->
      <div class="bg-surface-container-lowest rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-primary-container/20 flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-primary text-2xl">lightbulb</span>
          </div>
          <div>
            <h3 class="font-headline text-base font-bold text-on-surface mb-2">Promo Code Tips</h3>
            <ul class="space-y-2 text-sm text-secondary font-body">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5">•</span>
                Short, memorable codes (e.g. <span class="font-label font-bold text-on-surface">CRAFT20</span>) convert best.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5">•</span>
                Set a minimum order to protect margins on small purchases.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5">•</span>
                Seasonal codes around Eid and National Day drive significant traffic.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5">•</span>
                Limit uses to create urgency — "first 50 orders" outperforms unlimited codes.
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Top Performer Highlight -->
      <% if (coupons.length > 0) { %>
        <%
          var topCode = coupons.slice().sort((a, b) => (b.used_count || 0) - (a.used_count || 0))[0];
        %>
        <div class="bg-surface-container-lowest rounded-2xl p-6 flex flex-col justify-between">
          <div>
            <span class="font-label text-xs uppercase tracking-widest text-secondary font-bold block mb-3">Top Performing Code</span>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-xl bg-primary-container/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary text-3xl">workspace_premium</span>
              </div>
              <div>
                <p class="font-headline text-2xl font-bold text-on-surface font-label tracking-wider"><%= topCode.code %></p>
                <p class="text-secondary text-sm font-body">
                  <% if (topCode.discount_type === 'percentage') { %>
                    <%= topCode.discount_value %>% off
                  <% } else { %>
                    BD <%= parseFloat(topCode.discount_value).toFixed(2) %> off
                  <% } %>
                </p>
              </div>
            </div>
            <div class="flex gap-6">
              <div>
                <p class="text-2xl font-headline font-bold text-on-surface"><%= topCode.used_count || 0 %></p>
                <p class="text-secondary text-xs font-label uppercase tracking-widest">Total Uses</p>
              </div>
              <div>
                <p class="text-2xl font-headline font-bold text-on-surface">
                  <%= topCode.is_active ? '✓' : '✗' %>
                </p>
                <p class="text-secondary text-xs font-label uppercase tracking-widest"><%= topCode.is_active ? 'Active' : 'Inactive' %></p>
              </div>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="bg-surface-container-lowest rounded-2xl p-6 flex items-center justify-center">
          <div class="text-center">
            <span class="material-symbols-outlined text-4xl text-secondary/20 block mb-3">workspace_premium</span>
            <p class="text-secondary text-sm font-body">Your top-performing code will appear here.</p>
          </div>
        </div>
      <% } %>

    </div>

  </main>
</div>

<%- include('../partials/footer') %>
