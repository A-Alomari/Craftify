<%- include('../partials/header', { title: title }) %>

<%
  const orderStatusClass = function(status) {
    if (status === 'delivered') return 'bg-emerald-100 text-emerald-700';
    if (status === 'cancelled' || status === 'refunded') return 'bg-red-100 text-red-700';
    if (status === 'shipped' || status === 'processing') return 'bg-blue-100 text-blue-700';
    return 'bg-amber-100 text-amber-700';
  };
%>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen px-6 lg:px-8 py-8">
    <%- include('./partials/topbar') %>

    <section class="max-w-7xl mx-auto mt-8 mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <a href="/artisan/orders" class="text-xs uppercase tracking-[0.2em] text-secondary hover:text-primary">Back to Orders</a>
        <h1 class="font-headline text-3xl text-on-surface mt-2">Order #ORD-<%= String(order.id).padStart(4, '0') %></h1>
        <p class="text-secondary mt-1"><%= order.customer_name %> • <%= new Date(order.created_at).toLocaleString() %></p>
      </div>
      <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= orderStatusClass(order.status) %>"><%= order.status %></span>
    </section>

    <section class="max-w-7xl mx-auto bg-surface-container-lowest rounded-xl p-6 md:p-8">
      <h2 class="font-headline text-xl text-on-surface mb-4">Order Items</h2>

      <div class="space-y-3">
        <% items.forEach(function(item) { %>
          <article class="flex items-center justify-between gap-4 rounded-xl bg-surface-container-low px-4 py-3">
            <div class="flex items-center gap-3 min-w-0">
              <img src="<%= item.image || '/images/placeholder-product.svg' %>" alt="<%= item.product_name %>" class="w-11 h-11 rounded-lg object-cover" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-on-surface truncate"><%= item.product_name %></p>
                <p class="text-xs text-secondary">Qty <%= item.quantity %> x $<%= Number(item.unit_price || 0).toFixed(2) %></p>
              </div>
            </div>
            <p class="text-sm font-bold text-on-surface">$<%= Number(item.total_price || 0).toFixed(2) %></p>
          </article>
        <% }); %>
      </div>

      <div class="mt-6 pt-5 border-t border-surface-container-high flex items-center justify-between">
        <span class="text-xs uppercase tracking-[0.2em] text-secondary font-bold">Total</span>
        <span class="font-headline text-2xl text-on-surface">$<%= Number(order.total_amount || 0).toFixed(2) %></span>
      </div>

      <% if (['confirmed', 'processing'].indexOf(order.status) >= 0) { %>
        <form action="/artisan/orders/<%= order.id %>/status" method="POST" class="mt-6">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <input type="hidden" name="status" value="shipped">
          <button class="bg-emerald-100 text-emerald-700 hover:bg-emerald-200 px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors">Mark as Shipped</button>
        </form>
      <% } %>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
