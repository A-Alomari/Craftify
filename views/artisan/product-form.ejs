<%- include('../partials/header', { title: title }) %>

<div class="flex bg-surface min-h-screen">
  <%- include('./partials/sidebar') %>

  <main class="flex-1 min-h-screen">
    <div class="max-w-6xl mx-auto px-6 py-10 lg:px-10">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-8 text-sm text-secondary">
        <a href="/artisan/dashboard" class="hover:text-primary transition-colors">Dashboard</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <a href="/artisan/products" class="hover:text-primary transition-colors">Products</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-on-surface font-semibold"><%= product ? 'Edit "' + product.name + '"' : 'Add New Product' %></span>
      </nav>

      <div class="mb-10">
        <h1 class="font-headline text-4xl font-bold text-on-surface mb-1"><%= product ? 'Edit Product' : 'Add New Product' %></h1>
        <p class="text-secondary italic"><%= product ? 'Update the details and listing for your handcrafted piece.' : 'List your unique creation for the marketplace.' %></p>
      </div>

      <form id="product-form" action="<%= product ? '/artisan/products/' + product.id : '/artisan/products' %>?_csrf=<%= typeof csrfToken !== 'undefined' ? encodeURIComponent(csrfToken) : '' %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

          <!-- Left: Form Sections -->
          <div class="lg:col-span-8 space-y-8">

            <!-- Product Media -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
              <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-6">Product Media</h3>

              <% if (product && product.imageArray && product.imageArray.length > 0) { %>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                  <% product.imageArray.forEach(function(img, idx) { %>
                    <div class="aspect-square rounded-xl bg-surface-container-lowest overflow-hidden relative group">
                      <img src="<%= img %>" alt="Product image <%= idx + 1 %>" class="w-full h-full object-cover" onerror="this.src='/images/placeholder-product.jpg'">
                      <% if (idx === 0) { %>
                        <div class="absolute top-2 left-2">
                          <span class="bg-primary-container text-on-primary-container text-[10px] font-bold px-2 py-0.5 rounded shadow-sm">COVER</span>
                        </div>
                      <% } %>
                    </div>
                  <% }); %>
                  <label class="aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-secondary hover:border-primary hover:text-primary transition-all gap-2 bg-surface-container-low cursor-pointer">
                    <span class="material-symbols-outlined">add_a_photo</span>
                    <span class="text-xs font-semibold">Replace</span>
                    <input type="file" name="images" multiple accept="image/jpeg,image/png,image/webp" class="hidden" id="img-input">
                  </label>
                </div>
              <% } else { %>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                  <label class="col-span-2 aspect-square rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center text-secondary hover:border-primary hover:text-primary transition-all gap-3 bg-surface-container-low cursor-pointer">
                    <span class="material-symbols-outlined text-4xl">add_a_photo</span>
                    <p class="text-sm font-semibold">Upload Images</p>
                    <p class="text-xs text-outline">JPEG, PNG, WebP · up to 30MB</p>
                    <input type="file" name="images" multiple accept="image/jpeg,image/png,image/webp" class="hidden" id="img-input">
                  </label>
                  <div class="aspect-square rounded-xl border-2 border-dashed border-outline-variant flex items-center justify-center bg-surface-container-low opacity-30">
                    <span class="material-symbols-outlined text-secondary">image</span>
                  </div>
                  <div class="aspect-square rounded-xl border-2 border-dashed border-outline-variant flex items-center justify-center bg-surface-container-low opacity-30">
                    <span class="material-symbols-outlined text-secondary">image</span>
                  </div>
                </div>
              <% } %>
            </section>

            <!-- General Information -->
            <section class="space-y-6">
              <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary">General Information</h3>

              <div>
                <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Product Name *</label>
                <input type="text" name="name" id="input-name" required value="<%= product ? product.name : '' %>" placeholder="e.g. Hand-Thrown Stoneware Vase" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all font-headline text-lg text-primary">
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Category</label>
                  <select name="category_id" id="input-category" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all appearance-none">
                    <option value="">Select Category</option>
                    <% categories.forEach(function(cat) { %>
                      <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Base Price (USD) *</label>
                  <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-secondary font-headline">$</span>
                    <input type="number" name="price" id="input-price" step="0.01" min="0" required value="<%= product ? product.price : '' %>" placeholder="0.00" class="w-full bg-surface-container-low border-none rounded-xl pl-8 pr-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all font-headline text-lg">
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Product Description *</label>
                <textarea name="description" rows="6" required placeholder="Tell the story of your creation — materials, process, dimensions, care instructions..." class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all font-body leading-relaxed text-on-surface-variant"><%= product ? product.description : '' %></textarea>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Weight (grams)</label>
                  <input type="number" name="weight" step="1" min="0" value="<%= product && product.weight ? product.weight : '' %>" placeholder="e.g. 350" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                </div>
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Materials / Tags</label>
                  <input type="text" name="tags" value="<%= product && product.tags ? product.tags : '' %>" placeholder="e.g. clay, kiln-fired, glaze" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                  <p class="mt-1 text-[11px] text-secondary">Comma-separated (clay, wood, silver…)</p>
                </div>
              </div>

              <div class="grid grid-cols-3 gap-6">
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Length (cm)</label>
                  <input type="number" name="length_cm" step="0.1" min="0" value="<%= product && product.length_cm ? product.length_cm : '' %>" placeholder="e.g. 20" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                </div>
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Width (cm)</label>
                  <input type="number" name="width_cm" step="0.1" min="0" value="<%= product && product.width_cm ? product.width_cm : '' %>" placeholder="e.g. 10" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                </div>
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Height (cm)</label>
                  <input type="number" name="height_cm" step="0.1" min="0" value="<%= product && product.height_cm ? product.height_cm : '' %>" placeholder="e.g. 15" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                </div>
              </div>
            </section>

            <!-- Inventory -->
            <section class="space-y-6">
              <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary">Inventory &amp; Logistics</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold text-on-surface-variant mb-2 font-label uppercase tracking-tighter">Stock Quantity *</label>
                  <input type="number" name="stock" id="input-stock" min="0" required value="<%= product ? product.stock : '0' %>" placeholder="10" class="w-full bg-surface-container-low border-none rounded-xl px-4 py-3 focus:ring-0 focus:bg-surface-container-high transition-all">
                </div>
              </div>
            </section>

            <!-- Delete (edit mode only) -->
            <% if (product) { %>
              <footer class="pt-6 border-t border-surface-container flex justify-between items-center">
                <form action="/artisan/products/<%= product.id %>/delete?_csrf=<%= typeof csrfToken !== 'undefined' ? encodeURIComponent(csrfToken) : '' %>" method="POST" data-confirm="Are you sure you want to delete this product? This action cannot be undone.">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="text-error font-semibold flex items-center gap-2 hover:opacity-70 transition-opacity">
                    <span class="material-symbols-outlined text-lg">delete_forever</span>
                    Delete Product
                  </button>
                </form>
                <button type="button" class="font-headline italic text-on-surface hover:text-primary transition-all text-sm">Save as Draft</button>
              </footer>
            <% } %>
          </div>

          <!-- Right: Sticky Sidebar -->
          <aside class="lg:col-span-4 sticky top-6">
            <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm ring-1 ring-on-surface/5">
              <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-6">Live Preview</h3>

              <div class="group relative mb-6">
                <div class="aspect-[4/5] rounded-lg overflow-hidden mb-4 bg-surface-container-low flex items-center justify-center" id="preview-img-wrap">
                  <% if (product && product.imageArray && product.imageArray.length > 0) { %>
                    <img src="<%= product.imageArray[0] %>" alt="Preview" class="w-full h-full object-cover" onerror="this.src='/images/placeholder-product.jpg'" id="preview-img">
                  <% } else { %>
                    <span class="material-symbols-outlined text-4xl text-outline">image</span>
                  <% } %>
                </div>
                <div class="inline-block px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold uppercase tracking-wider mb-2" id="preview-category">
                  <%= (product && categories.find(function(c){ return c.id == product.category_id; })) ? categories.find(function(c){ return c.id == product.category_id; }).name : 'Category' %>
                </div>
                <h4 class="font-headline text-2xl font-bold text-on-surface mb-1" id="preview-name"><%= product ? product.name : 'Product Name' %></h4>
                <p class="font-headline text-xl text-primary" id="preview-price"><%= product ? '$' + Number(product.price).toFixed(2) : '$0.00' %></p>
              </div>

              <div class="space-y-3 pt-4 border-t border-surface-container">
                <div class="flex justify-between text-xs font-medium">
                  <span class="text-secondary">Status</span>
                  <span class="text-on-surface flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full <%= product && product.status === 'approved' ? 'bg-green-500' : 'bg-yellow-500' %>"></span>
                    <%= product ? (product.status === 'approved' ? 'Approved' : product.status) : 'Pending Review' %>
                  </span>
                </div>
                <div class="flex justify-between text-xs font-medium">
                  <span class="text-secondary">Stock</span>
                  <span class="text-on-surface" id="preview-stock"><%= product ? product.stock + ' units' : '0 units' %></span>
                </div>
              </div>

              <div class="mt-6 flex flex-col gap-3">
                <button type="submit" class="w-full bg-primary-container text-on-primary-container font-bold py-4 rounded-xl shadow-sm hover:brightness-110 active:scale-95 transition-all flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-xl">check_circle</span>
                  <%= product ? 'Save Changes' : 'Publish Product' %>
                </button>
                <a href="/artisan/products" class="w-full bg-surface-container text-on-surface-variant font-semibold py-4 rounded-xl hover:bg-surface-container-high active:scale-95 transition-all flex items-center justify-center gap-2 text-center">
                  <span class="material-symbols-outlined text-xl">arrow_back</span>
                  Back to Products
                </a>
              </div>
            </div>

            <div class="mt-6 bg-surface-container-low rounded-xl p-6 border border-outline-variant/20">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1;">auto_awesome</span>
                <h4 class="font-headline text-sm font-bold">Maker Insight</h4>
              </div>
              <p class="text-xs text-secondary leading-relaxed italic">Items with descriptions over 200 characters and 3+ clear images see 40% more engagement. Tell your crafting story.</p>
            </div>
          </aside>
        </div>
      </form>
    </div>
  </main>
</div>

<script>
(function() {
  // Live preview: name
  var nameInput = document.getElementById('input-name');
  var previewName = document.getElementById('preview-name');
  if (nameInput && previewName) {
    nameInput.addEventListener('input', function() {
      previewName.textContent = nameInput.value || 'Product Name';
    });
  }
  // Live preview: price
  var priceInput = document.getElementById('input-price');
  var previewPrice = document.getElementById('preview-price');
  if (priceInput && previewPrice) {
    priceInput.addEventListener('input', function() {
      previewPrice.textContent = priceInput.value ? '$' + Number(priceInput.value).toFixed(2) : '$0.00';
    });
  }
  // Live preview: stock
  var stockInput = document.getElementById('input-stock');
  var previewStock = document.getElementById('preview-stock');
  if (stockInput && previewStock) {
    stockInput.addEventListener('input', function() {
      previewStock.textContent = stockInput.value + ' units';
    });
  }
  // Live preview: category
  var categorySelect = document.getElementById('input-category');
  var previewCategory = document.getElementById('preview-category');
  if (categorySelect && previewCategory) {
    categorySelect.addEventListener('change', function() {
      var opt = categorySelect.options[categorySelect.selectedIndex];
      previewCategory.textContent = opt && opt.value ? opt.text : 'Category';
    });
  }
  // Live preview: image from file input
  var imgInput = document.getElementById('img-input');
  var previewImgWrap = document.getElementById('preview-img-wrap');
  if (imgInput && previewImgWrap) {
    imgInput.addEventListener('change', function() {
      var file = imgInput.files[0];
      if (file) {
        var reader = new FileReader();
        reader.onload = function(e) {
          previewImgWrap.innerHTML = '<img src="' + e.target.result + '" alt="Preview" class="w-full h-full object-cover">';
        };
        reader.readAsDataURL(file);
      }
    });
  }
})();
</script>

<%- include('../partials/footer') %>
