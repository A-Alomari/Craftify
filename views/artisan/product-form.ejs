<%- include('../partials/header', { title: title }) %>
<div class="container-fluid py-4"><div class="row"><div class="col-lg-2 mb-4"><%- include('./partials/sidebar') %></div>
<div class="col-lg-10">
  <h3 class="mb-4"><%= product ? 'Edit Product' : 'Add New Product' %></h3>
  <div class="card shadow-sm border-0"><div class="card-body">
    <form action="<%= product ? '/artisan/products/' + product.id : '/artisan/products' %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="mb-3"><label class="form-label">Product Name *</label><input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required></div>
      <div class="mb-3"><label class="form-label">Description *</label><textarea name="description" class="form-control" rows="4" required><%= product ? product.description : '' %></textarea></div>
      <div class="row">
        <div class="col-md-4 mb-3"><label class="form-label">Price ($) *</label><input type="number" name="price" class="form-control" step="0.01" value="<%= product ? product.price : '' %>" required></div>
        <div class="col-md-4 mb-3"><label class="form-label">Stock *</label><input type="number" name="stock" class="form-control" value="<%= product ? product.stock : '0' %>" required></div>
        <div class="col-md-4 mb-3"><label class="form-label">Category</label>
          <select name="category_id" class="form-select"><option value="">Select Category</option>
            <% categories.forEach(function(cat) { %><option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option><% }); %>
          </select>
        </div>
      </div>
      <div class="mb-3"><label class="form-label">Product Images</label><input type="file" name="images" class="form-control" multiple accept="image/*"></div>
      <% if (product && product.imageArray && product.imageArray.length > 0) { %>
        <div class="mb-3"><label class="form-label">Current Images</label><div class="d-flex gap-2">
          <% product.imageArray.forEach(function(img) { %><img src="<%= img %>" class="rounded" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='/images/placeholder-product.jpg'"><% }); %>
        </div></div>
      <% } %>
      <button type="submit" class="btn btn-primary"><%= product ? 'Update Product' : 'Create Product' %></button>
      <a href="/artisan/products" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
  </div></div>
</div></div></div>
<%- include('../partials/footer') %>
