<%- include('../partials/header', { title: 'Browse Products | Craftify' }) %>

<%
const activeFilters = typeof filters !== 'undefined' && filters ? filters : {};
const categoryList = Array.isArray(categories) ? categories : [];
const paginationQuery = [];
if (activeFilters.search) paginationQuery.push(`search=${encodeURIComponent(activeFilters.search)}`);
if (activeFilters.category) paginationQuery.push(`category=${encodeURIComponent(activeFilters.category)}`);
if (activeFilters.sort) paginationQuery.push(`sort=${encodeURIComponent(activeFilters.sort)}`);
if (activeFilters.min_price) paginationQuery.push(`min_price=${encodeURIComponent(activeFilters.min_price)}`);
if (activeFilters.max_price) paginationQuery.push(`max_price=${encodeURIComponent(activeFilters.max_price)}`);
if (activeFilters.featured) paginationQuery.push(`featured=${encodeURIComponent(activeFilters.featured)}`);
const paginationQueryString = paginationQuery.join('&');
%>

<main class="pt-8 pb-20 max-w-screen-2xl mx-auto px-6">
    <section class="relative overflow-hidden rounded-3xl bg-surface-container-lowest p-8 md:p-10 mb-10">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-primary-container/25 blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-16 -left-16 w-64 h-64 rounded-full bg-tertiary-container/20 blur-3xl pointer-events-none"></div>

        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
            <div class="lg:col-span-7">
                <p class="font-label text-xs tracking-[0.2em] uppercase text-secondary mb-3">The Digital Atelier</p>
                <h1 class="font-headline text-4xl md:text-5xl text-on-surface leading-tight">Shop Handcrafted Pieces With Story, Texture, and Soul</h1>
                <p class="text-secondary mt-4 max-w-2xl">Discover independent makers, filter by craft, and search across products, categories, and artisan shops in one place.</p>
            </div>
            <div class="lg:col-span-5">
                <form action="/products" method="GET" class="bg-surface-container-high/70 rounded-2xl p-4 space-y-3">
                    <label for="searchInput" class="text-[10px] uppercase tracking-[0.2em] font-bold text-secondary">Search The Shop</label>
                    <div class="relative">
                        <input
                            id="searchInput"
                            name="search"
                            type="search"
                            value="<%= activeFilters.search || '' %>"
                            placeholder="Search products, categories, or artisans"
                            autocomplete="off"
                            class="w-full rounded-xl bg-white px-4 py-3 pr-12 text-sm text-on-surface border-none focus:ring-2 focus:ring-primary-container"
                        />
                        <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 rounded-lg p-2 text-secondary hover:text-primary transition-colors" aria-label="Search shop">
                            <span class="material-symbols-outlined">search</span>
                        </button>
                    </div>
                    <div id="searchResults" class="list-group hidden overflow-hidden rounded-xl border border-surface-container-high bg-white shadow-xl" style="display:none;"></div>
                    <% if (activeFilters.category) { %><input type="hidden" name="category" value="<%= activeFilters.category %>"><% } %>
                    <% if (activeFilters.sort) { %><input type="hidden" name="sort" value="<%= activeFilters.sort %>"><% } %>
                    <% if (activeFilters.min_price) { %><input type="hidden" name="min_price" value="<%= activeFilters.min_price %>"><% } %>
                    <% if (activeFilters.max_price) { %><input type="hidden" name="max_price" value="<%= activeFilters.max_price %>"><% } %>
                    <% if (activeFilters.featured) { %><input type="hidden" name="featured" value="<%= activeFilters.featured %>"><% } %>
                </form>
            </div>
        </div>
    </section>

    <% if (categoryList.length > 0) { %>
        <section class="mb-10">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-headline text-2xl text-on-surface">Browse By Craft</h2>
                <a href="/products" class="text-xs uppercase tracking-[0.2em] text-secondary hover:text-primary">Clear Filters</a>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-6 gap-4">
                <% categoryList.slice(0, 6).forEach(function(cat) { %>
                    <a href="/products?category=<%= cat.id %>" class="group rounded-2xl overflow-hidden bg-surface-container-lowest shadow-sm hover:shadow-md transition-all">
                        <div class="aspect-[4/3] bg-surface-container-low overflow-hidden">
                            <img src="<%= cat.image || '/images/placeholder-product.jpg' %>" alt="<%= cat.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='/images/placeholder-product.jpg'">
                        </div>
                        <div class="px-3 py-3">
                            <p class="text-sm font-semibold text-on-surface"><%= cat.name %></p>
                            <p class="text-xs text-secondary"><%= cat.product_count || 0 %> products</p>
                        </div>
                    </a>
                <% }); %>
            </div>
        </section>
    <% } %>

    <section class="grid grid-cols-1 xl:grid-cols-12 gap-8">
        <aside class="xl:col-span-3">
            <div class="sticky top-24 bg-surface-container-lowest rounded-2xl p-5 space-y-5">
                <h3 class="text-xs uppercase tracking-[0.2em] font-bold text-secondary">Filter by Craft</h3>
                <div class="space-y-2">
                    <a href="/products" class="block text-sm <%= !activeFilters.category ? 'text-primary font-semibold' : 'text-secondary hover:text-on-surface' %>">All Categories</a>
                    <% categoryList.forEach(function(cat) { %>
                        <a href="/products?category=<%= cat.id %>" class="block text-sm <%= String(activeFilters.category) === String(cat.id) ? 'text-primary font-semibold' : 'text-secondary hover:text-on-surface' %>"><%= cat.name %></a>
                    <% }); %>
                </div>

                <form action="/products" method="GET" class="space-y-3 pt-2 border-t border-surface-container-high">
                    <label class="text-[10px] uppercase tracking-[0.2em] font-bold text-secondary block">Sort</label>
                    <select name="sort" onchange="this.form.submit()" class="w-full bg-surface-container-low border-none rounded-xl px-3 py-2 text-sm focus:ring-2 focus:ring-primary-container">
                        <option value="newest" <%= !activeFilters.sort || activeFilters.sort === 'newest' ? 'selected' : '' %>>Newest Arrivals</option>
                        <option value="price_low" <%= activeFilters.sort === 'price_low' ? 'selected' : '' %>>Price: Low to High</option>
                        <option value="price_high" <%= activeFilters.sort === 'price_high' ? 'selected' : '' %>>Price: High to Low</option>
                    </select>
                    <% if (activeFilters.search) { %><input type="hidden" name="search" value="<%= activeFilters.search %>"><% } %>
                    <% if (activeFilters.category) { %><input type="hidden" name="category" value="<%= activeFilters.category %>"><% } %>
                    <% if (activeFilters.min_price) { %><input type="hidden" name="min_price" value="<%= activeFilters.min_price %>"><% } %>
                    <% if (activeFilters.max_price) { %><input type="hidden" name="max_price" value="<%= activeFilters.max_price %>"><% } %>
                    <% if (activeFilters.featured) { %><input type="hidden" name="featured" value="<%= activeFilters.featured %>"><% } %>
                </form>
            </div>
        </aside>

        <section class="xl:col-span-9">
            <header class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
                <div>
                    <h2 class="font-headline text-3xl text-on-surface">All Products</h2>
                    <p class="text-secondary mt-1">Curated collection: <span class="font-bold text-on-surface"><%= products ? products.length : 0 %> pieces</span> currently in the atelier.</p>
                </div>
                <% if (activeFilters.search) { %>
                    <p class="text-sm text-secondary">Search term: <span class="font-semibold text-on-surface"><%= activeFilters.search %></span></p>
                <% } %>
            </header>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-x-6 gap-y-10">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(function(product) { %>
                        <% var images = []; try { images = JSON.parse(product.images || '[]'); } catch(e) {} %>
                        <article class="group relative bg-surface-container-lowest p-4 rounded-xl shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 flex flex-col">
                            <div class="aspect-[4/5] w-full overflow-hidden rounded-lg mb-4 relative">
                                <a href="/products/<%= product.id %>">
                                    <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="<%= images[0] || '/images/placeholder-product.jpg' %>" alt="<%= product.name %>" loading="lazy" onerror="this.src='/images/placeholder-product.jpg'"/>
                                </a>
                                <form action="/user/wishlist/toggle" method="POST" class="absolute top-3 right-3">
                                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <button
                                        type="submit"
                                        class="p-2 bg-white/80 backdrop-blur-md rounded-full transition-colors shadow-sm <%= product.inWishlist ? 'text-tertiary' : 'text-secondary hover:text-tertiary' %>"
                                        aria-label="<%= product.inWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>"
                                    >
                                        <span class="material-symbols-outlined" data-icon="favorite"><%= product.inWishlist ? 'favorite' : 'favorite_border' %></span>
                                    </button>
                                </form>
                                <% if (product.stock <= 0) { %>
                                    <div class="absolute bottom-3 left-3 bg-red-100/90 backdrop-blur-md px-3 py-1 rounded-full shadow-sm">
                                        <span class="text-[10px] font-bold tracking-widest text-red-600 uppercase">Out of Stock</span>
                                    </div>
                                <% } %>
                            </div>
                            <div class="space-y-1 flex-1 flex flex-col">
                                <h3 class="text-lg font-bold text-on-surface group-hover:text-primary transition-colors whitespace-nowrap overflow-hidden text-ellipsis"><%= product.name %></h3>
                                <p class="text-sm text-secondary font-medium mb-3">by <a href="/products/artisan/<%= product.artisan_id %>" class="underline decoration-outline-variant/50 underline-offset-4"><%= product.shop_name || 'Artisan' %></a></p>

                                <div class="flex items-center justify-between mt-auto pt-4">
                                    <div class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-primary text-sm">star</span>
                                        <span class="text-xs font-bold text-on-surface"><%= product.avg_rating ? product.avg_rating.toFixed(1) : 'New' %></span>
                                        <% if (product.review_count > 0) { %>
                                        <span class="text-xs text-secondary">(<%= product.review_count %>)</span>
                                        <% } %>
                                    </div>
                                    <span class="text-xl font-headline font-bold text-on-surface">$<%= product.price.toFixed(2) %></span>
                                </div>

                                <form action="/cart/add" method="POST" class="mt-4">
                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <input type="hidden" name="quantity" value="1">
                                    <button type="submit" class="w-full flex items-center justify-center gap-2 bg-primary-container text-on-primary-container py-3 rounded-lg font-bold text-sm transition-all active:scale-95">
                                        <span class="material-symbols-outlined text-sm" data-icon="add_shopping_cart">add_shopping_cart</span>
                                        Add to Cart
                                    </button>
                                </form>
                            </div>
                        </article>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-full text-center py-16">
                        <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">search_off</span>
                        <h3 class="text-xl font-bold text-on-surface mb-2">No products found</h3>
                        <% if (typeof filters !== 'undefined' && filters.search) { %>
                            <p class="text-secondary mb-6">No products found for '<%= filters.search %>'.</p>
                        <% } else { %>
                            <p class="text-secondary mb-6">No products available at the moment.</p>
                        <% } %>
                        <a href="/products" class="inline-flex items-center gap-2 bg-primary-container text-on-primary-container px-6 py-3 rounded-lg font-bold text-sm transition-all">
                            <span class="material-symbols-outlined text-sm">storefront</span>
                            Browse all products
                        </a>
                    </div>
                <% } %>
            </div>

            <% if (typeof pagination !== 'undefined' && pagination) { %>
                <%- include('../partials/pagination', { pagination: pagination, queryString: paginationQueryString }) %>
            <% } %>
        </section>
    </section>
</main>

<%- include('../partials/footer') %>
