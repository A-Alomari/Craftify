<%- include('../partials/header', { title: title }) %>
<div class="container py-4">
  <% if (artisan) { %>
    <div class="text-center mb-5">
      <img src="<%= artisan.profile_image || '/images/default-avatar.png' %>" class="rounded-circle mb-3" style="width: 120px; height: 120px; object-fit: cover;" onerror="this.src='/images/default-avatar.png'">
      <h2><%= artisan.shop_name %></h2>
      <p class="text-muted"><%= artisan.user_name %></p>
      <% if (artisan.bio) { %><p><%= artisan.bio %></p><% } %>
      <% if (stats) { %>
        <div class="d-flex justify-content-center gap-4 mb-3">
          <div><strong><%= stats.total_products %></strong><br><small class="text-muted">Products</small></div>
          <div><strong><%= stats.total_orders %></strong><br><small class="text-muted">Orders</small></div>
        </div>
      <% } %>
    </div>
  <% } %>
  
  <h4 class="mb-4">Products</h4>
  <div class="row g-4">
    <% if (products && products.length > 0) { %>
      <% products.forEach(function(p) { %>
        <% var images = JSON.parse(p.images || '[]'); var img = images[0] || '/images/placeholder-product.jpg'; %>
        <div class="col-6 col-md-3">
          <div class="card h-100 border-0 shadow-sm">
            <a href="/products/<%= p.id %>"><img src="<%= img %>" class="card-img-top" style="height: 160px; object-fit: cover;" onerror="this.src='/images/placeholder-product.jpg'"></a>
            <div class="card-body"><h6><a href="/products/<%= p.id %>" class="text-decoration-none text-dark"><%= p.name %></a></h6><span class="fw-bold text-primary">$<%= p.price.toFixed(2) %></span></div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-inbox display-4 text-muted"></i>
        <p class="text-muted mt-3">No products yet. Check back later!</p>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
