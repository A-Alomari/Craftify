<%- include('../partials/header', { title: title }) %>

<main class="flex-grow min-h-screen">

<section class="max-w-7xl mx-auto px-6 py-10">
  <% if (artisan) { %>
    <article class="bg-surface-container-lowest rounded-xl p-8 md:p-10 mb-8 text-center">
      <img src="<%= artisan.profile_image || '/images/default-avatar.png' %>" alt="<%= artisan.shop_name %>" class="w-28 h-28 mx-auto rounded-full object-cover ring-4 ring-primary-container/20" onerror="this.onerror=null;this.src='/images/default-avatar.png'">
      <h1 class="font-headline text-4xl text-on-surface mt-4"><%= artisan.shop_name %></h1>
      <p class="text-secondary mt-1"><%= artisan.user_name %></p>

      <% if (artisan.bio) { %>
        <p class="text-on-surface max-w-2xl mx-auto mt-4"><%= artisan.bio %></p>
      <% } %>

      <% if (stats) { %>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-lg mx-auto">
          <div class="bg-surface-container-low rounded-xl p-4">
            <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Products</p>
            <p class="font-headline text-2xl text-on-surface mt-2"><%= Number(stats.total_products || 0) %></p>
          </div>
          <div class="bg-surface-container-low rounded-xl p-4">
            <p class="text-[10px] uppercase tracking-[0.2em] text-secondary font-bold">Orders</p>
            <p class="font-headline text-2xl text-on-surface mt-2"><%= Number(stats.total_orders || 0) %></p>
          </div>
        </div>
      <% } %>
    </article>
  <% } %>

  <div class="mb-4 flex items-end justify-between gap-3">
    <h2 class="font-headline text-2xl text-on-surface">Products</h2>
    <span class="text-xs text-secondary uppercase tracking-widest">Count: <%= products ? products.length : 0 %></span>
  </div>

  <% if (products && products.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <% products.forEach(function(p) { %>
        <% var images = JSON.parse(p.images || '[]'); var img = images[0] || '/images/placeholder-product.svg'; %>
        <article class="group bg-surface-container-lowest rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col">
          <div class="relative aspect-[4/5] overflow-hidden">
            <a href="/products/<%= p.id %>"><img src="<%= img %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"></a>
            <div class="absolute top-3 left-3">
              <span class="bg-primary-container text-on-primary-container text-xs font-bold px-3 py-1 rounded-lg font-headline">$<%= Number(p.price || 0).toFixed(2) %></span>
            </div>
            <% if (p.stock <= 0) { %>
              <div class="absolute inset-0 bg-black/25 flex items-end justify-center pb-10">
                <span class="bg-red-600/90 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full">Out of Stock</span>
              </div>
            <% } %>
          </div>
          <div class="p-4 flex flex-col flex-grow">
            <% if (p.category_name) { %>
              <span class="text-[10px] font-bold tracking-[0.2em] text-secondary uppercase mb-1"><%= p.category_name %></span>
            <% } %>
            <h3 class="text-sm font-semibold text-on-surface line-clamp-2 min-h-[40px] group-hover:text-primary transition-colors"><a href="/products/<%= p.id %>" class="hover:text-primary"><%= p.name %></a></h3>
            <div class="mt-auto pt-3">
              <% if (typeof user === 'undefined' || !user || user.role === 'customer') { %>
                <% if (p.stock > 0) { %>
                  <form action="/cart/add" method="POST" data-no-loading>
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="productId" value="<%= p.id %>">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="w-full flex items-center justify-center gap-1 bg-primary-container text-on-primary-container py-2 rounded-xl font-bold text-xs tracking-wide hover:opacity-90 transition-colors active:scale-95">
                      <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                      Add to Cart
                    </button>
                  </form>
                <% } else { %>
                  <button class="w-full py-2 rounded-xl border border-outline text-secondary text-xs font-bold cursor-not-allowed opacity-60" disabled>Out of Stock</button>
                <% } %>
              <% } else { %>
                <a href="/products/<%= p.id %>" class="block text-center w-full py-2 rounded-xl bg-surface-container-low text-on-surface text-xs font-semibold hover:bg-surface-container transition-colors">View Details</a>
              <% } %>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  <% } else { %>
    <div class="bg-surface-container-lowest rounded-xl py-14 text-center">
      <span class="material-symbols-outlined text-5xl text-secondary/60">inbox</span>
      <p class="text-secondary mt-3">No products yet. Check back later.</p>
    </div>
  <% } %>
</section>

</main>

<%- include('../partials/footer') %>
