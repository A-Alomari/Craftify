<%- include('../partials/header', { title: product ? product.name + ' | Craftify' : 'Product Details' }) %>

<main class="max-w-7xl mx-auto px-6 pt-12 pb-20">
<!-- Breadcrumb -->
<nav class="mb-12 flex items-center gap-2 text-sm font-label text-on-secondary-container">
<a class="hover:text-primary-container transition-colors" href="/">Home</a>
<span class="material-symbols-outlined text-xs">chevron_right</span>
<a class="hover:text-primary-container transition-colors" href="/products">Shop</a>
<span class="material-symbols-outlined text-xs">chevron_right</span>
<span class="text-on-surface font-semibold"><%= product ? product.name : 'Unknown' %></span>
</nav>

<% if (!product) { %>
    <div class="text-center py-20">
        <h1 class="text-3xl font-bold text-on-surface">Product Not Found</h1>
        <a href="/products" class="inline-block mt-6 text-primary hover:underline group"><span class="material-symbols-outlined align-middle mr-1 group-hover:-translate-x-1 transition-transform">arrow_back</span>Back to Shop</a>
    </div>
<% } else { %>
    <% var images = []; try { images = JSON.parse(product.images || '[]'); } catch(e) {} %>
    <% if (images.length === 0) images.push('/images/placeholder-product.svg'); %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
<!-- Left Column: Product Gallery -->
<div class="space-y-6">
<div class="bg-surface-container-lowest rounded-xl overflow-hidden aspect-square shadow-sm">
<img id="mainProductImg" alt="<%= product.name %>" class="w-full h-full object-cover transition-opacity duration-200" src="<%= images[0] %>" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"/>
</div>
<% if (images.length > 1) { %>
<div class="grid grid-cols-4 gap-4" id="productThumbnails">
    <% images.forEach(function(img, index) { %>
        <button class="product-thumb aspect-square rounded-lg overflow-hidden border-2 <%= index === 0 ? 'border-primary-container ring-2 ring-primary-container/20' : 'border-transparent hover:border-primary-container/50' %> transition-all" data-src="<%= img %>">
        <img alt="Thumbnail <%= index + 1 %>" class="w-full h-full object-cover" src="<%= img %>" onerror="this.onerror=null;this.src='/images/placeholder-product.svg'"/>
        </button>
    <% }); %>
</div>
<% } %>
</div>

<!-- Right Column: Product Details -->
<div class="flex flex-col">
<span class="inline-block px-3 py-1 bg-primary-container/10 text-primary-container text-xs font-bold rounded-full w-fit mb-4 tracking-widest uppercase">
    <%= product.category_name || 'PRODUCT' %>
</span>
<h1 class="font-headline text-4xl lg:text-5xl font-bold mb-4 text-on-surface"><%= product.name %></h1>
<div class="flex items-center gap-3 mb-6">
<div class="flex items-center gap-1 text-primary-container">
<span class="material-symbols-outlined filled-icon">star</span>
<span class="font-bold"><%= ratingStats && ratingStats.avg_rating ? Number(ratingStats.avg_rating).toFixed(1) : 'New' %></span>
<% if (ratingStats && ratingStats.count > 0) { %>
<span class="text-on-secondary-container text-sm">(<%= ratingStats.count %> reviews)</span>
<% } %>
</div>
</div>
<div class="text-3xl font-headline font-bold text-primary mb-8">$<%= product.price.toFixed(2) %></div>
<p class="text-on-secondary-container leading-relaxed mb-10 font-body">
    <%= product.description || 'No description available for this handcrafted item.' %>
</p>

<!-- Stock check -->
<% if (!user || user.role === 'customer') { %>
<% if (product.stock > 0) { %>
    <p class="text-sm font-bold text-green-600 mb-6"><%= product.stock %> in stock<% if (typeof availableStock !== 'undefined' && availableStock < product.stock) { %> &middot; <span class="text-amber-600"><%= availableStock %> available (you have <%= product.stock - availableStock %> in cart)</span><% } %></p>

    <div class="flex flex-col gap-6 mb-12">
        <div class="flex items-center gap-4">
            <form action="/cart/add" method="POST" class="flex items-center gap-4 flex-1" data-no-loading>
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <div class="flex items-center bg-surface-container-low rounded-xl px-1 gap-1">
                    <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-container-high transition-colors font-bold text-lg" data-action="decrease">−</button>
                    <input type="number" name="quantity" value="1" min="1" max="<%= typeof availableStock !== 'undefined' ? availableStock : product.stock %>" class="qty-input w-12 text-center bg-transparent border-none text-lg font-bold focus:ring-0">
                    <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-container-high transition-colors font-bold text-lg" data-action="increase">+</button>
                </div>
                <button type="submit" class="flex-1 bg-primary-container text-on-primary-container font-bold py-4 px-8 rounded-xl flex items-center justify-center gap-2 hover:opacity-90 transition-all active:scale-95">
                    <span class="material-symbols-outlined">shopping_bag</span>
                    Add to Cart
                </button>
            </form>
            <form action="/user/wishlist/toggle" method="POST" data-no-loading>
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <button type="submit" class="p-4 border border-outline-variant rounded-xl hover:bg-surface-container-low transition-colors <%= inWishlist ? 'text-red-500' : 'text-on-surface' %>" aria-label="<%= inWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>">
                    <span class="material-symbols-outlined <%= inWishlist ? 'filled-icon' : '' %>" data-icon="favorite">favorite</span>
                </button>
            </form>
        </div>
    </div>
<% } else { %>
    <div class="bg-red-100 text-red-700 p-4 rounded-xl font-bold mb-12 inline-block">
        Currently Out of Stock
    </div>
<% } %>
<% } /* end customer-only block */ %>

<div class="flex items-start gap-4 p-5 bg-surface-container-low rounded-xl">
    <span class="material-symbols-outlined text-primary-container">local_shipping</span>
    <div>
        <div class="font-bold text-sm">Standard Shipping included for VIPs</div>
        <div class="text-xs text-on-secondary-container mt-1">Artisan crafted with care.</div>
    </div>
</div>
</div>
</div>

<!-- Secondary Information Grid -->
<div class="mt-32 grid grid-cols-1 md:grid-cols-2 gap-20">
<!-- About the Artisan -->
<section>
<h3 class="font-headline text-2xl font-bold mb-8">About the Artisan</h3>
<div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm border border-outline-variant/10">
<div class="flex items-center gap-6 mb-6">
<div class="w-20 h-20 rounded-full overflow-hidden border-2 border-primary-container/20 flex items-center justify-center bg-amber-100 text-amber-700 text-3xl font-bold">
<% if (artisan && (artisan.profile_image || artisan.avatar)) { %>
    <img src="<%= artisan.profile_image || artisan.avatar %>" alt="<%= product.shop_name || 'Artisan' %>" class="w-full h-full object-cover" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
    <span style="display:none" class="w-full h-full flex items-center justify-center"><%= (product.shop_name || 'A')[0].toUpperCase() %></span>
<% } else { %>
    <%= (product.shop_name || 'A')[0].toUpperCase() %>
<% } %>
</div>
<div>
<h4 class="font-headline text-xl font-bold"><%= product.shop_name || 'Artisan' %></h4>
<div class="flex items-center gap-1 text-on-secondary-container text-sm">
    <span class="material-symbols-outlined text-sm">verified</span> Verified Seller
</div>
</div>
</div>
<p class="text-on-secondary-container leading-relaxed mb-6 font-body">
    <%= (artisan && artisan.bio) ? artisan.bio : 'Discover more amazing handcrafted products from this artisan.' %>
</p>
<div class="flex gap-4">
<a class="text-primary font-bold font-headline underline underline-offset-4 hover:opacity-80 transition-opacity" href="/user/artisan/<%= product.artisan_id %>">View Artist Shop</a>
<% if (user && user.id !== product.artisan_id) { %>
<a class="inline-flex items-center gap-2 text-primary font-bold font-headline underline underline-offset-4 hover:opacity-80 transition-opacity" href="/user/messages/<%= product.artisan_id %>">
<span class="material-symbols-outlined text-sm">chat</span>
Send Message
</a>
<% } %>
</div>
</div>
</section>
<!-- Product Details -->
<section>
<h3 class="font-headline text-2xl font-bold mb-8">Product Details</h3>
<div class="space-y-6">
<div class="flex justify-between py-4 border-b border-outline-variant/20">
<span class="text-on-secondary-container font-medium">Category</span>
<span class="text-on-surface font-semibold text-right"><%= product.category_name || 'General' %></span>
</div>
<% if (product.weight) { %>
<div class="flex justify-between py-4 border-b border-outline-variant/20">
<span class="text-on-secondary-container font-medium">Weight</span>
<span class="text-on-surface font-semibold text-right"><%= product.weight %>g</span>
</div>
<% } %>
<% if (product.tags) { %>
<div class="flex justify-between py-4 border-b border-outline-variant/20">
<span class="text-on-secondary-container font-medium">Materials</span>
<span class="text-on-surface font-semibold text-right"><%= product.tags.split(',').map(function(t){return t.trim();}).join(', ') %></span>
</div>
<% } %>
<div class="flex justify-between py-4 border-b border-outline-variant/20">
<span class="text-on-secondary-container font-medium">Listed</span>
<span class="text-on-surface font-semibold text-right"><%= new Date(product.created_at).toLocaleDateString() %></span>
</div>
</div>
</section>
</div>

<%
const distributionMap = {};
(ratingDistribution || []).forEach(function(entry) {
    distributionMap[entry.rating] = entry.count;
});
%>

<section class="mt-24 grid grid-cols-1 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-12">
    <div class="space-y-8">
        <div>
            <p class="text-xs uppercase tracking-[0.2em] text-secondary font-semibold mb-3">Customer Feedback</p>
            <h3 class="font-headline text-3xl text-on-surface">Reviews & Ratings</h3>
        </div>

        <div class="bg-surface-container-lowest rounded-2xl p-8 shadow-sm">
            <div class="flex items-end gap-4 mb-8">
                <div class="text-5xl font-headline font-bold text-on-surface"><%= ratingStats && ratingStats.avg_rating ? Number(ratingStats.avg_rating).toFixed(1) : 'New' %></div>
                <div class="pb-1">
                    <div class="flex items-center gap-1 text-primary">
                        <% const roundedAverage = ratingStats && ratingStats.avg_rating ? Math.round(Number(ratingStats.avg_rating)) : 0; %>
                        <% for (let star = 1; star <= 5; star++) { %>
                            <span class="material-symbols-outlined text-sm"><%= star <= roundedAverage ? 'star' : 'star_outline' %></span>
                        <% } %>
                    </div>
                    <p class="text-sm text-secondary mt-2">Based on <%= ratingStats && ratingStats.count ? ratingStats.count : 0 %> verified reviews</p>
                </div>
            </div>

            <div class="space-y-4">
                <% for (let rating = 5; rating >= 1; rating--) { %>
                    <% const totalReviews = ratingStats && ratingStats.count ? Number(ratingStats.count) : 0; %>
                    <% const count = Number(distributionMap[rating] || 0); %>
                    <% const width = totalReviews > 0 ? (count / totalReviews) * 100 : 0; %>
                    <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 text-sm">
                        <span class="font-semibold text-on-surface"><%= rating %>★</span>
                        <div class="h-2.5 rounded-full bg-surface-container-low overflow-hidden">
                            <div class="h-full rounded-full bg-primary" style="width: <%= width %>%;"></div>
                        </div>
                        <span class="text-secondary"><%= count %></span>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="bg-surface-container-low rounded-2xl p-8">
            <h4 class="font-headline text-xl text-on-surface mb-4">Write a Review</h4>
            <% if (!user) { %>
                <p class="text-secondary mb-4">Sign in to leave a review once your order has been delivered.</p>
                <a href="/auth/login" class="inline-flex items-center gap-2 bg-primary-container text-on-primary-container px-5 py-3 rounded-xl font-semibold">
                    <span class="material-symbols-outlined text-base">login</span>
                    Log in to review
                </a>
            <% } else if (canReview && canReview.canReview) { %>
                <form action="/user/reviews" method="POST" class="space-y-4">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="product_id" value="<%= product.id %>">
                    <div>
                        <label for="review-rating" class="block text-sm font-semibold text-on-surface mb-2">Rating</label>
                        <select id="review-rating" name="rating" required class="w-full rounded-xl border border-outline-variant/20 bg-white px-4 py-3 text-sm text-on-surface">
                            <option value="">Choose a rating</option>
                            <option value="5">5 stars</option>
                            <option value="4">4 stars</option>
                            <option value="3">3 stars</option>
                            <option value="2">2 stars</option>
                            <option value="1">1 star</option>
                        </select>
                    </div>
                    <div>
                        <label for="review-title" class="block text-sm font-semibold text-on-surface mb-2">Title</label>
                        <input id="review-title" name="title" type="text" maxlength="200" class="w-full rounded-xl border border-outline-variant/20 bg-white px-4 py-3 text-sm text-on-surface" placeholder="Summarize your experience">
                    </div>
                    <div>
                        <label for="review-comment" class="block text-sm font-semibold text-on-surface mb-2">Comment</label>
                        <textarea id="review-comment" name="comment" rows="4" required maxlength="1000" class="w-full rounded-xl border border-outline-variant/20 bg-white px-4 py-3 text-sm text-on-surface" placeholder="Share what you loved about this piece"></textarea>
                    </div>
                    <button type="submit" class="inline-flex items-center gap-2 bg-primary-container text-on-primary-container px-5 py-3 rounded-xl font-semibold">
                        <span class="material-symbols-outlined text-base">rate_review</span>
                        Submit review
                    </button>
                </form>
            <% } else if (canReview && canReview.hasReviewed) { %>
                <p class="text-secondary">You have already reviewed this product. Thanks for sharing your feedback.</p>
            <% } else { %>
                <p class="text-secondary">Reviews open after a delivered order so feedback stays tied to real purchases.</p>
            <% } %>
        </div>
    </div>

    <div class="space-y-5">
        <div class="flex items-center justify-between gap-4">
            <div>
                <p class="text-xs uppercase tracking-[0.2em] text-secondary font-semibold mb-2">Latest Feedback</p>
                <h4 class="font-headline text-2xl text-on-surface">What buyers are saying</h4>
            </div>
            <% if (reviews && reviews.length > 0) { %>
                <span class="text-sm text-secondary"><%= reviews.length %> visible review<%= reviews.length === 1 ? '' : 's' %></span>
            <% } %>
        </div>

        <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(function(review) { %>
                <article class="bg-surface-container-lowest rounded-2xl p-6 shadow-sm">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-center gap-4">
                            <img class="w-12 h-12 rounded-full object-cover" src="<%= review.reviewer_avatar || '/images/default-avatar.png' %>" alt="<%= review.reviewer_name %>" onerror="this.onerror=null;this.src='/images/default-avatar.png'"/>
                            <div>
                                <p class="font-semibold text-on-surface"><%= review.reviewer_name %></p>
                                <p class="text-xs text-secondary"><%= new Date(review.created_at).toLocaleDateString() %></p>
                            </div>
                        </div>
                        <div class="flex items-center gap-1 text-primary">
                            <% for (let star = 1; star <= 5; star++) { %>
                                <span class="material-symbols-outlined text-sm"><%= star <= Number(review.rating || 0) ? 'star' : 'star_outline' %></span>
                            <% } %>
                        </div>
                    </div>
                    <% if (review.title) { %>
                        <h5 class="font-semibold text-on-surface mt-5"><%= review.title %></h5>
                    <% } %>
                    <p class="text-secondary leading-relaxed mt-2"><%= review.comment %></p>
                </article>
            <% }); %>
        <% } else { %>
            <div class="bg-surface-container-low rounded-2xl p-8 text-center">
                <span class="material-symbols-outlined text-5xl text-secondary/60">reviews</span>
                <p class="text-secondary mt-3">No approved reviews yet for this product.</p>
            </div>
        <% } %>
    </div>
</section>

<% } %>
</main>

<script>
(function() {
  var mainImg = document.getElementById('mainProductImg');
  var thumbs = document.querySelectorAll('.product-thumb');

  thumbs.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var src = this.dataset.src;
      if (!src || !mainImg) return;
      mainImg.style.opacity = '0';
      setTimeout(function() {
        mainImg.src = src;
        mainImg.style.opacity = '1';
      }, 150);
      thumbs.forEach(function(t) {
        t.classList.remove('border-primary-container', 'ring-2', 'ring-primary-container/20');
        t.classList.add('border-transparent');
      });
      this.classList.remove('border-transparent');
      this.classList.add('border-primary-container', 'ring-2', 'ring-primary-container/20');
    });
  });
})();
</script>

<%- include('../partials/footer') %>
