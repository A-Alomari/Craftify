<%- include('../partials/header', { title: title }) %>
<div class="container py-4">
  <h3 class="mb-4"><i class="bi bi-gavel"></i> My Bids</h3>
  <% if (bids.length > 0) { %>
    <div class="row g-4">
      <% bids.forEach(function(bid) { %>
        <div class="col-md-6">
          <div class="card shadow-sm border-0">
            <div class="row g-0">
              <div class="col-4">
                <img src="<%= bid.image %>" class="img-fluid rounded-start h-100" style="object-fit: cover;">
              </div>
              <div class="col-8">
                <div class="card-body">
                  <h6><a href="/auctions/<%= bid.auction_id %>" class="text-decoration-none"><%= bid.product_name %></a></h6>
                  <p class="mb-1">Your bid: <strong class="text-primary">$<%= bid.amount.toFixed(2) %></strong></p>
                  <p class="mb-1">Current: $<%= (bid.current_highest_bid || 0).toFixed(2) %></p>
                  <% if (bid.isWinning) { %>
                    <span class="badge bg-success">Winning!</span>
                  <% } else { %>
                    <span class="badge bg-warning">Outbid</span>
                  <% } %>
                  <span class="badge bg-<%= bid.auction_status === 'active' ? 'primary' : 'secondary' %>"><%= bid.auction_status %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <p class="text-muted">You haven't placed any bids yet. <a href="/auctions">Browse auctions</a></p>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
