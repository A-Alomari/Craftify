<%- include('../partials/header', { title: title }) %>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="mb-6">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-primary font-semibold">Auction Desk</span>
    <h1 class="font-headline text-3xl text-on-surface mt-2">My Bids</h1>
    <p class="text-secondary mt-1">Live status of all bids you have placed.</p>
  </div>

  <% if (bids && bids.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <% bids.forEach(function(bid) { %>
        <article class="bg-surface-container-lowest rounded-xl overflow-hidden">
          <div class="grid grid-cols-3">
            <div class="col-span-1">
              <img src="<%= bid.image || '/images/placeholder-product.jpg' %>" alt="<%= bid.product_name %>" class="w-full h-full min-h-[150px] object-cover" onerror="this.src='/images/placeholder-product.jpg'">
            </div>

            <div class="col-span-2 p-4">
              <h2 class="text-sm font-semibold text-on-surface"><a href="/auctions/<%= bid.auction_id %>" class="hover:text-primary"><%= bid.product_name %></a></h2>
              <p class="text-sm text-on-surface mt-2">Your bid: <span class="font-bold">$<%= Number(bid.amount || 0).toFixed(2) %></span></p>
              <p class="text-sm text-secondary mt-1">Current: $<%= Number(bid.current_highest_bid || 0).toFixed(2) %></p>

              <div class="mt-3 flex flex-wrap gap-2">
                <% if (bid.isWinning) { %>
                  <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-emerald-100 text-emerald-700">Winning</span>
                <% } else { %>
                  <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-amber-100 text-amber-700">Outbid</span>
                <% } %>
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= bid.auction_status === 'active' ? 'bg-primary-container text-on-primary-container' : 'bg-surface-container-high text-on-surface' %>"><%= bid.auction_status %></span>
              </div>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  <% } else { %>
    <div class="bg-surface-container-lowest rounded-xl py-14 text-center">
      <span class="material-symbols-outlined text-5xl text-secondary/60">gavel</span>
      <p class="text-secondary mt-3">You haven't placed any bids yet.</p>
      <a href="/auctions" class="inline-block mt-4 bg-primary-container text-on-primary-container px-5 py-2.5 rounded-xl text-sm font-semibold">Browse Auctions</a>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
