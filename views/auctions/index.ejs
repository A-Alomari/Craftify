<%- include('../partials/header', { title: title }) %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="bi bi-hammer"></i> Live Auctions</h3>
    <div class="btn-group">
      <a href="/auctions?status=active" class="btn btn-<%= filters.status === 'active' ? 'primary' : 'outline-primary' %> btn-sm">Active</a>
      <a href="/auctions?status=all" class="btn btn-<%= filters.status === 'all' ? 'primary' : 'outline-primary' %> btn-sm">All</a>
    </div>
  </div>

  <% if (auctions.length > 0) { %>
    <div class="row g-4">
      <% auctions.forEach(function(auction) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <img src="<%= auction.image %>" class="card-img-top" alt="<%= auction.product_name %>" style="height: 200px; object-fit: cover;">
            <% if (auction.status === 'active') { %>
              <span class="badge bg-success position-absolute top-0 end-0 m-2">LIVE</span>
            <% } %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= auction.title || auction.product_name %></h5>
              <p class="text-muted small mb-2">By <%= auction.shop_name %></p>
              
              <div class="mb-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <small class="text-muted">Current Bid</small>
                    <h5 class="text-primary mb-0">$<%= (auction.current_highest_bid || auction.starting_price).toFixed(2) %></h5>
                  </div>
                  <div class="text-end">
                    <small class="text-muted">Bids</small>
                    <h5 class="mb-0"><%= auction.bid_count || 0 %></h5>
                  </div>
                </div>
              </div>

              <% if (auction.status === 'active') { %>
                <% var endTime = new Date(auction.end_time); var remaining = Math.max(0, endTime - new Date()); %>
                <% var hours = Math.floor(remaining / 3600000); var mins = Math.floor((remaining % 3600000) / 60000); %>
                <p class="text-danger small mb-2">
                  <i class="bi bi-clock"></i> 
                  <% if (hours > 24) { %>
                    <%= Math.floor(hours/24) %> days left
                  <% } else if (hours > 0) { %>
                    <%= hours %>h <%= mins %>m left
                  <% } else { %>
                    <%= mins %> minutes left
                  <% } %>
                </p>
              <% } else { %>
                <span class="badge bg-secondary mb-2"><%= auction.status %></span>
              <% } %>

              <a href="/auctions/<%= auction.id %>" class="btn btn-primary mt-auto">
                <% if (auction.status === 'active') { %>
                  <i class="bi bi-gavel"></i> Place Bid
                <% } else { %>
                  View Details
                <% } %>
              </a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-hammer display-4 text-muted"></i>
      <p class="text-muted mt-3">No auctions found.</p>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
