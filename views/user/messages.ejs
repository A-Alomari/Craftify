<%- include('../partials/header', { title: title }) %>
<div class="container py-4">
  <h3 class="mb-4"><i class="bi bi-chat-dots"></i> Messages</h3>
  <% if (conversations.length > 0) { %>
    <% conversations.forEach(function(conv) { %>
      <a href="/user/messages/<%= conv.other_user_id %>" class="text-decoration-none">
        <div class="card shadow-sm border-0 mb-2">
          <div class="card-body d-flex align-items-center">
            <div class="bg-primary rounded-circle text-white d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
              <%= (conv.other_user_name || '?')[0].toUpperCase() %>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between">
                <h6 class="mb-0"><%= conv.other_user_name %> <% if (conv.shop_name) { %><small class="text-muted">(<%= conv.shop_name %>)</small><% } %></h6>
                <small class="text-muted"><%= conv.last_message_time ? new Date(conv.last_message_time).toLocaleDateString() : '' %></small>
              </div>
              <p class="text-muted small mb-0 text-truncate"><%= conv.last_message || '' %></p>
            </div>
            <% if (conv.unread_count > 0) { %>
              <span class="badge bg-primary rounded-pill ms-2"><%= conv.unread_count %></span>
            <% } %>
          </div>
        </div>
      </a>
    <% }); %>
  <% } else { %>
    <div class="text-center py-5"><i class="bi bi-chat display-4 text-muted"></i><p class="text-muted mt-3">No conversations yet.</p></div>
  <% } %>
</div>
<%- include('../partials/footer') %>
