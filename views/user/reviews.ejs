<%- include('../partials/header', { title: title }) %>
<div class="container py-4">
  <h3 class="mb-4"><i class="bi bi-star"></i> My Reviews</h3>
  <% if (reviews.length > 0) { reviews.forEach(function(r) { %>
    <div class="card shadow-sm border-0 mb-3"><div class="card-body">
      <div class="d-flex justify-content-between">
        <div>
          <h6><%= r.product_name %></h6>
          <% for (var s = 0; s < r.rating; s++) { %><i class="bi bi-star-fill text-warning"></i><% } %>
          <% if (r.title) { %><p class="fw-bold mb-1 mt-2"><%= r.title %></p><% } %>
          <p class="mb-0"><%= r.comment %></p>
        </div>
        <form action="/user/reviews/<%= r.id %>/delete" method="POST"><input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
      </div>
    </div></div>
  <% }); } else { %><div class="text-center py-5"><p class="text-muted">No reviews yet. Purchase a product to leave a review!</p></div><% } %>
</div>
<%- include('../partials/footer') %>
