<%- include('../partials/header', { title: title }) %>

<main class="flex-grow min-h-screen">

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="mb-6">
    <span class="font-label text-xs uppercase tracking-[0.2em] text-primary font-semibold">Customer Area</span>
    <h1 class="font-headline text-3xl text-on-surface mt-2">My Reviews</h1>
    <p class="text-secondary mt-1">Feedback you've shared on purchased products.</p>
  </div>

  <% if (reviews && reviews.length > 0) { %>
    <div class="space-y-3">
      <% reviews.forEach(function(r) { %>
        <article class="bg-surface-container-lowest rounded-xl p-5 md:p-6">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
            <div>
              <h2 class="text-sm font-semibold text-on-surface"><%= r.product_name %></h2>
              <div class="mt-2 flex items-center gap-1 text-amber-500">
                <% for (let s = 0; s < Number(r.rating || 0); s++) { %>
                  <span class="material-symbols-outlined text-sm">star</span>
                <% } %>
              </div>
              <% if (r.title) { %>
                <p class="text-sm font-semibold text-on-surface mt-3"><%= r.title %></p>
              <% } %>
              <p class="text-sm text-secondary mt-1"><%= r.comment %></p>
            </div>
            <form action="/user/reviews/<%= r.id %>/delete" method="POST" data-confirm="Delete this review?">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-2 rounded-lg text-xs font-semibold">Delete</button>
            </form>
          </div>
        </article>
      <% }); %>
    </div>
  <% } else { %>
    <div class="bg-surface-container-lowest rounded-xl py-14 text-center">
      <span class="material-symbols-outlined text-5xl text-secondary/60">rate_review</span>
      <p class="text-secondary mt-3">No reviews yet. Purchase a product to leave one.</p>
    </div>
  <% } %>
</section>

</main>

<%- include('../partials/footer') %>
