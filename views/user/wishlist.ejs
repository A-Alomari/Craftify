<%- include('../partials/header', { title: title }) %>
<div class="container py-4">
  <h3 class="mb-4"><i class="bi bi-heart"></i> My Wishlist</h3>
  <% if (items.length > 0) { %>
    <div class="row g-4">
      <% items.forEach(function(item) { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card h-100 border-0 shadow-sm">
            <img src="<%= item.image || '/images/placeholder-product.jpg' %>" class="card-img-top" alt="<%= item.name %>" style="height: 180px; object-fit: cover;" onerror="this.src='/images/placeholder-product.jpg'">
            <div class="card-body d-flex flex-column">
              <h6><a href="/products/<%= item.product_id %>" class="text-decoration-none text-dark"><%= item.name %></a></h6>
              <span class="text-primary fw-bold mb-2">$<%= item.price.toFixed(2) %></span>
              <div class="mt-auto d-flex gap-2">
                <form action="/user/wishlist/move-to-cart" method="POST" class="flex-grow-1">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="productId" value="<%= item.product_id %>">
                  <button class="btn btn-primary btn-sm w-100"><i class="bi bi-cart-plus"></i></button>
                </form>
                <form action="/user/wishlist/remove" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="productId" value="<%= item.product_id %>">
                  <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-heart display-4 text-muted"></i>
      <p class="text-muted mt-3">Your wishlist is empty. <a href="/products">Browse products</a></p>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
