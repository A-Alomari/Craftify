<%- include('../partials/header', { title: title }) %>

<%
const activeTypeVal = typeof activeType !== 'undefined' ? activeType : 'all';
const unread = typeof unreadCount !== 'undefined' ? unreadCount : 0;
const csrfVal = typeof csrfToken !== 'undefined' ? csrfToken : '';

function notifIcon(type) {
  if (type === 'order') return { icon: 'package_2', bg: 'bg-blue-50', color: 'text-blue-600' };
  if (type === 'auction') return { icon: 'gavel', bg: 'bg-amber-50', color: 'text-amber-600' };
  if (type === 'message') return { icon: 'chat_bubble', bg: 'bg-emerald-50', color: 'text-emerald-600' };
  if (type === 'review') return { icon: 'star', bg: 'bg-amber-50', color: 'text-amber-600' };
  if (type === 'system') return { icon: 'sell', bg: 'bg-purple-50', color: 'text-purple-600' };
  return { icon: 'notifications', bg: 'bg-blue-50', color: 'text-blue-600' };
}

function timeAgo(dateStr) {
  if (!dateStr) return '';
  const now = new Date();
  // Normalize SQLite dates ('YYYY-MM-DD HH:MM:SS') to ISO UTC.
  // Strip any existing timezone suffix then force Z (UTC).
  let s = String(dateStr).trim().replace(' ', 'T');
  s = s.replace(/(\.\d+)?([Zz]|[+-]\d{2}:?\d{2})?$/, '') + 'Z';
  const then = new Date(s);
  if (isNaN(then.getTime())) return '';
  const diff = Math.floor((now - then) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff/60) + 'm ago';
  if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
  if (diff < 604800) return Math.floor(diff/86400) + 'd ago';
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function actionBtn(n) {
  if (!n.link) return null;
  if (n.link.includes('/orders/')) return n.type === 'order' && n.title && n.title.toLowerCase().includes('deliver') ? 'Write Review' : 'Track Order';
  if (n.link.includes('/auctions/')) return n.title && n.title.toLowerCase().includes('won') ? 'Complete Payment' : 'View Auction';
  if (n.link.includes('/messages')) return 'Reply';
  if (n.link.includes('/products/')) return 'View Item';
  if (n.link.includes('/artisan/')) return 'View';
  return 'View';
}

const unreadNotifs = notifications ? notifications.filter(n => !n.is_read) : [];
const readNotifs = notifications ? notifications.filter(n => n.is_read) : [];
%>

<main class="flex-grow">
<div class="max-w-7xl mx-auto w-full px-6 flex flex-col md:flex-row gap-8 pt-10 pb-20">

  <!-- Sidebar -->
  <aside class="md:w-64 shrink-0">
    <div class="sticky top-28 space-y-6">
      <div>
        <h1 class="font-headline text-3xl font-bold text-on-surface mb-1 tracking-tight">Notifications</h1>
        <p class="text-[10px] uppercase tracking-widest text-secondary opacity-60"><%= unread %> unread alert<%= unread === 1 ? '' : 's' %></p>
      </div>

      <nav class="flex flex-col gap-1">
        <% const tabs = [
          { id: 'all', label: 'All', icon: 'apps' },
          { id: 'orders', label: 'Orders', icon: 'package_2' },
          { id: 'auctions', label: 'Auctions', icon: 'gavel' },
          { id: 'messages', label: 'Messages', icon: 'chat_bubble' },
          { id: 'promotions', label: 'Promotions', icon: 'sell' }
        ]; %>
        <% tabs.forEach(function(tab) { %>
          <a href="/user/notifications?type=<%= tab.id %>"
             class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all w-full <%= activeTypeVal === tab.id ? 'bg-primary-container text-on-primary-container font-semibold shadow-sm' : 'text-secondary hover:bg-surface-container-low' %>">
            <span class="material-symbols-outlined text-[20px]"><%= tab.icon %></span>
            <%= tab.label %>
          </a>
        <% }); %>
      </nav>

      <div class="pt-6 border-t border-outline-variant flex flex-col gap-3">
        <% if (notifications && notifications.length > 0 && unread > 0) { %>
        <form action="/user/notifications/read-all" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfVal %>">
          <button type="submit" class="text-xs font-bold uppercase tracking-widest text-primary hover:underline transition-all text-left">Mark All as Read</button>
        </form>
        <% } %>
      </div>
    </div>
  </aside>

  <!-- Main content -->
  <div class="flex-grow min-w-0">
    <% if (!notifications || notifications.length === 0) { %>
      <div class="bg-surface-container-lowest rounded-2xl py-20 text-center">
        <span class="material-symbols-outlined text-5xl text-emerald-500 filled-icon">check_circle</span>
        <p class="text-secondary mt-3 font-medium">You're all caught up!</p>
        <p class="text-xs text-secondary mt-1">No notifications in this category.</p>
      </div>
    <% } else { %>
    <div class="space-y-8">

      <% if (unreadNotifs.length > 0) { %>
      <div id="new-activity-section">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-primary mb-3 px-4">New Activity</h2>
        <div class="space-y-2" id="unread-notifs-list">
          <% unreadNotifs.forEach(function(n) { %>
          <% const ic = notifIcon(n.type); const btn = actionBtn(n); %>
          <div class="notif-card group relative bg-[#FFF7ED] p-4 rounded-xl border-l-4 border-primary transition-all hover:bg-white hover:shadow-md" data-id="<%= n.id %>">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full <%= ic.bg %> flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined <%= ic.color %> text-[20px]"><%= ic.icon %></span>
              </div>
              <div class="flex-grow min-w-0">
                <div class="flex justify-between items-center mb-0.5 gap-2">
                  <h3 class="font-headline text-base font-bold text-on-surface truncate"><%= n.title %></h3>
                  <span class="text-[10px] font-medium text-secondary whitespace-nowrap shrink-0" style="opacity:0.7"><%= timeAgo(n.created_at) %></span>
                </div>
                <p class="text-on-surface-variant text-sm mb-3 leading-relaxed"><%= n.message %></p>
                <div class="flex items-center gap-2 flex-wrap">
                  <% if (btn && n.link) { %>
                    <a href="<%= n.link %>" data-notif-id="<%= n.id %>" data-csrf="<%= csrfVal %>" data-action="view"
                       class="notif-view-link px-3 py-1.5 rounded-lg bg-primary-container text-on-primary-container text-[10px] font-bold uppercase tracking-wider hover:brightness-110 transition-all"><%= btn %></a>
                  <% } %>
                  <button type="button" data-notif-id="<%= n.id %>" data-csrf="<%= csrfVal %>" data-action="dismiss"
                    class="notif-action-btn px-3 py-1.5 rounded-lg bg-surface-container-low border border-outline-variant text-[10px] font-bold uppercase tracking-wider text-on-surface hover:bg-surface-container-high transition-all">
                    Mark as Read
                  </button>
                </div>
              </div>
            </div>
            <div class="absolute top-4 right-4 w-2 h-2 rounded-full bg-primary-container"></div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (readNotifs.length > 0) { %>
      <div id="earlier-section">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-secondary mb-3 px-4" style="opacity:0.5">Earlier</h2>
        <div class="space-y-2" id="read-notifs-list">
          <% readNotifs.forEach(function(n) { %>
          <% const ic = notifIcon(n.type); const btn = actionBtn(n); %>
          <div class="notif-card group relative bg-surface-container-lowest p-4 rounded-xl transition-all hover:bg-surface-container-low border border-outline-variant" data-id="<%= n.id %>" style="border-opacity:0.1">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full <%= ic.bg %> flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined <%= ic.color %> text-[20px]"><%= ic.icon %></span>
              </div>
              <div class="flex-grow min-w-0">
                <div class="flex justify-between items-center mb-0.5 gap-2">
                  <h3 class="font-headline text-base font-bold text-on-surface truncate" style="opacity:0.8"><%= n.title %></h3>
                  <span class="text-[10px] font-medium text-secondary whitespace-nowrap shrink-0" style="opacity:0.4"><%= timeAgo(n.created_at) %></span>
                </div>
                <p class="text-on-surface-variant text-sm mb-3 leading-relaxed" style="opacity:0.8"><%= n.message %></p>
                <div class="flex items-center gap-2 flex-wrap">
                  <% if (btn && n.link) { %>
                    <a href="<%= n.link %>" class="px-3 py-1.5 rounded-lg bg-surface-container-low text-[10px] font-bold uppercase tracking-wider text-on-surface hover:bg-surface-container-high transition-all"><%= btn %></a>
                  <% } %>
                  <button type="button" data-notif-id="<%= n.id %>" data-csrf="<%= csrfVal %>" data-action="delete"
                    class="notif-action-btn px-3 py-1.5 rounded-lg bg-red-50 text-[10px] font-bold uppercase tracking-wider text-red-600 hover:bg-red-100 transition-all">
                    Delete
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

    </div>

    <% if (pagination && pagination.totalPages > 1) { %>
    <div class="mt-10 text-center">
      <% if (pagination.currentPage < pagination.totalPages) { %>
      <a href="/user/notifications?type=<%= activeTypeVal %>&page=<%= pagination.currentPage + 1 %>"
         class="group inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-surface-container-low font-bold text-sm text-secondary hover:bg-surface-container-high transition-all">
        <span>Load More</span>
        <span class="material-symbols-outlined text-[18px] group-hover:translate-y-0.5 transition-transform">expand_more</span>
      </a>
      <% } %>
    </div>
    <% } %>

    <% } %>
  </div>

</div>
</main>

<script>
// Handle Mark as Read / Delete buttons
function handleNotifAction() {
  var btn = this;
  var id = btn.dataset.notifId;
  var action = btn.dataset.action;
  var csrf = btn.dataset.csrf;
  var card = document.querySelector('.notif-card[data-id="' + id + '"]');

  var url = action === 'dismiss'
    ? '/user/notifications/' + id + '/read'
    : '/user/notifications/' + id + '?_method=DELETE';

  btn.disabled = true;
  btn.style.opacity = '0.5';

    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: '_csrf=' + encodeURIComponent(csrf)
    }).then(function(res) {
      if (res.ok || res.redirected) {
        if (card) {
          card.style.transition = 'opacity 0.3s, transform 0.3s';
          card.style.opacity = '0';
          card.style.transform = 'translateX(20px)';
          setTimeout(function() {
            if (action === 'dismiss') {
              // Convert to read style
              card.classList.remove('bg-[#FFF7ED]', 'border-l-4', 'border-primary');
              card.classList.add('bg-surface-container-lowest', 'border', 'border-outline-variant');
              // Remove unread dot
              var dot = card.querySelector('.absolute.top-4.right-4');
              if (dot) dot.remove();
              // Replace buttons: remove "Mark as Read" + view link, add Delete only
              var btnRow = card.querySelector('.flex.items-center.gap-2');
              if (btnRow) {
                var viewLink = btnRow.querySelector('.notif-view-link');
                if (viewLink) {
                  var href2 = viewLink.getAttribute('href');
                  var label2 = viewLink.textContent.trim();
                  var newLink = document.createElement('a');
                  newLink.href = href2;
                  newLink.className = 'px-3 py-1.5 rounded-lg bg-surface-container-low text-[10px] font-bold uppercase tracking-wider text-on-surface hover:bg-surface-container-high transition-all';
                  newLink.textContent = label2;
                  viewLink.replaceWith(newLink);
                }
              }
              // Replace Mark as Read button with Delete using btn directly
              var delBtn = document.createElement('button');
              delBtn.type = 'button';
              delBtn.dataset.notifId = id;
              delBtn.dataset.csrf = csrf;
              delBtn.dataset.action = 'delete';
              delBtn.className = 'notif-action-btn px-3 py-1.5 rounded-lg bg-red-50 text-[10px] font-bold uppercase tracking-wider text-red-600 hover:bg-red-100 transition-all';
              delBtn.textContent = 'Delete';
              delBtn.addEventListener('click', handleNotifAction);
              btn.replaceWith(delBtn);
              // Move card to Earlier section
              var earlierSection = document.getElementById('earlier-section');
              var readList = document.getElementById('read-notifs-list');
              if (!earlierSection) {
                earlierSection = document.createElement('div');
                earlierSection.id = 'earlier-section';
                earlierSection.innerHTML = '<h2 class="text-[10px] font-bold uppercase tracking-widest text-secondary mb-3 px-4" style="opacity:0.5">Earlier</h2><div class="space-y-2" id="read-notifs-list"></div>';
                var mainContent = document.querySelector('.space-y-8');
                if (mainContent) mainContent.appendChild(earlierSection);
                readList = earlierSection.querySelector('#read-notifs-list');
              }
              card.style.opacity = '0';
              card.style.transform = 'translateX(0)';
              if (readList) readList.prepend(card);
              card.style.transition = 'opacity 0.3s, transform 0.3s';
              requestAnimationFrame(function() {
                card.style.opacity = '1';
                card.style.transform = 'none';
              });
              // Clean up New Activity if empty
              var unreadList = document.getElementById('unread-notifs-list');
              if (unreadList && !unreadList.querySelector('.notif-card')) {
                var section = document.getElementById('new-activity-section');
                if (section) section.remove();
              }
            } else {
              // Delete: remove the card
              card.remove();
              var readList2 = document.getElementById('read-notifs-list');
              if (readList2 && !readList2.querySelector('.notif-card')) {
                var section2 = document.getElementById('earlier-section');
                if (section2) section2.remove();
              }
            }
          }, 300);
        }
      } else {
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    }).catch(function() {
      btn.disabled = false;
      btn.style.opacity = '1';
    });
}

document.querySelectorAll('.notif-action-btn').forEach(function(btn) {
  btn.addEventListener('click', handleNotifAction);
});

// Handle View links: mark as read via AJAX, then navigate
document.querySelectorAll('.notif-view-link').forEach(function(link) {
  link.addEventListener('click', function(e) {
    e.preventDefault();
    var href = link.getAttribute('href');
    var id = link.dataset.notifId;
    var csrf = link.dataset.csrf;

    fetch('/user/notifications/' + id + '/read', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: '_csrf=' + encodeURIComponent(csrf)
    }).finally(function() {
      window.location.href = href;
    });
  });
});
</script>

<%- include('../partials/footer') %>
