<%- include('../partials/header', { title: title }) %>

<main class="flex-grow min-h-screen">

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
    <div>
      <span class="font-label text-xs uppercase tracking-[0.2em] text-primary font-semibold">Customer Area</span>
      <h1 class="font-headline text-3xl text-on-surface mt-2">Notifications</h1>
      <p class="text-secondary mt-1">Order updates, moderation notes, and account events.</p>
    </div>
    <% if (notifications && notifications.length > 0) { %>
      <form action="/user/notifications/read-all" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button class="bg-surface-container-high text-on-surface px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider">Mark All as Read</button>
      </form>
    <% } %>
  </div>

  <% if (notifications && notifications.length > 0) { %>
    <div class="space-y-3">
      <% notifications.forEach(function(n) { %>
        <article class="bg-surface-container-lowest rounded-xl p-5 <%= n.is_read ? '' : 'border-l-4 border-primary-container' %>">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <h2 class="text-sm font-semibold text-on-surface"><%= n.title %></h2>
              <p class="text-sm text-secondary mt-1"><%= n.message %></p>
              <p class="text-xs text-secondary mt-2"><%= new Date(n.created_at).toLocaleString() %></p>
            </div>
            <div class="flex gap-2">
              <% if (n.link) { %>
                <a href="<%= n.link %>" class="bg-surface-container-high text-on-surface hover:bg-surface-container-highest px-3 py-2 rounded-lg text-xs font-semibold">View</a>
              <% } %>
              <% if (!n.is_read) { %>
                <form action="/user/notifications/<%= n.id %>/read" method="POST">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button class="bg-primary-container text-on-primary-container px-3 py-2 rounded-lg text-xs font-semibold">Mark Read</button>
                </form>
              <% } %>
              <form action="/user/notifications/<%= n.id %>?_method=DELETE" method="POST" data-confirm="Delete this notification?">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-2 rounded-lg text-xs font-semibold">Delete</button>
              </form>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  <% } else { %>
    <div class="bg-surface-container-lowest rounded-xl py-14 text-center">
      <span class="material-symbols-outlined text-5xl text-emerald-600">check_circle</span>
      <p class="text-secondary mt-3">You're all caught up.</p>
    </div>
  <% } %>

  <% if (pagination && pagination.totalPages > 1) { %>
    <div class="mt-8">
      <%- include('../partials/pagination', { 
        pagination: pagination, 
        baseUrl: '/user/notifications', 
        query: {} 
      }) %>
    </div>
  <% } %>
</section>

</main>

<%- include('../partials/footer') %>
