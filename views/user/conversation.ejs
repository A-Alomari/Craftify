<%- include('../partials/header', { title: title }) %>

<main class="flex-grow bg-surface-container-lowest" style="height:calc(100vh - 72px); overflow:hidden;">

<%
  const conversationList = Array.isArray(conversations) ? conversations : [];
  const threadMessages = Array.isArray(messages) ? messages : [];
  const activeUserId = Number(otherUser.id);

  const formatThreadTime = function(value) {
    if (!value) return '';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return '';
    const now = new Date();
    const sameDay = now.toDateString() === parsed.toDateString();
    if (sameDay) {
      return parsed.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }
    return parsed.toLocaleDateString();
  };

  const formatMessageTime = function(value) {
    if (!value) return '';
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return '';
    return parsed.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  };

  const getRoleLabel = function(role) {
    return role === 'artisan' ? 'Artisan' : 'Customer';
  };
%>

<section class="flex overflow-hidden" style="height:calc(100vh - 72px);">
  <aside class="hidden md:flex md:w-[30%] lg:w-[25%] bg-surface-container-lowest border-r border-outline-variant/10 flex-col overflow-hidden" style="height:calc(100vh - 72px);">
    <div class="p-6 pb-4">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold font-headline text-on-surface">Messages</h1>
        <a href="/user/messages" class="p-2 text-secondary hover:bg-surface-container-low rounded-full transition-colors" aria-label="View all messages">
          <span class="material-symbols-outlined">inbox</span>
        </a>
      </div>
      <div class="relative group">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary text-lg group-focus-within:text-primary transition-colors">search</span>
        <input class="w-full bg-surface-container-low border-none rounded-xl py-2.5 pl-10 pr-4 text-sm focus:ring-0 transition-all" placeholder="Search conversations..." type="text"/>
      </div>
    </div>

    <div class="flex-grow overflow-y-auto bg-surface-container-lowest px-2 space-y-1 pb-4">
      <% conversationList.forEach(function(conv) { %>
        <% const isActive = Number(conv.other_user_id) === activeUserId; %>
        <a href="/user/messages/<%= conv.other_user_id %>" class="flex items-start gap-3 p-4 rounded-2xl cursor-pointer group transition-all relative <%= isActive ? 'bg-primary-container/10' : 'hover:bg-surface-container-low' %>">
          <div class="relative flex-shrink-0">
            <% if (conv.other_user_avatar) { %>
              <img alt="<%= conv.other_user_name %>" class="w-12 h-12 rounded-full object-cover <%= isActive ? 'border-2 border-primary-container' : '' %>" src="<%= conv.other_user_avatar %>" onerror="this.onerror=null; this.src='/images/default-avatar.png';"/>
            <% } else { %>
              <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold <%= isActive ? 'border-2 border-primary-container' : '' %>">
                <%= (conv.other_user_name || '?')[0].toUpperCase() %>
              </div>
            <% } %>
          </div>

          <div class="flex-grow min-w-0">
            <div class="flex justify-between items-baseline mb-0.5">
              <h3 class="font-semibold text-on-surface truncate"><%= conv.other_user_name %></h3>
              <span class="text-[10px] text-secondary uppercase tracking-tighter"><%= formatThreadTime(conv.last_message_time) %></span>
            </div>
            <div class="flex items-center gap-1.5 mb-1">
              <span class="bg-secondary-container text-on-secondary-container text-[10px] font-bold px-1.5 py-0.5 rounded uppercase"><%= getRoleLabel(conv.other_user_role) %></span>
              <% if (conv.shop_name) { %>
                <span class="text-[10px] text-secondary truncate"><%= conv.shop_name %></span>
              <% } %>
            </div>
            <p class="text-xs text-secondary truncate"><%= conv.last_message || 'No messages yet' %></p>
          </div>

          <% if (Number(conv.unread_count || 0) > 0) { %>
            <div class="absolute right-4 bottom-4 min-w-5 h-5 px-1.5 bg-primary text-on-primary rounded-full text-[10px] font-bold flex items-center justify-center">
              <%= conv.unread_count %>
            </div>
          <% } %>
        </a>
      <% }); %>
    </div>
  </aside>

  <section class="flex flex-col flex-1 bg-surface overflow-hidden" style="height:calc(100vh - 72px);">
    <header class="bg-surface/80 backdrop-blur-xl px-4 md:px-8 py-4 flex items-center justify-between border-b border-outline-variant/5 flex-shrink-0">
      <div class="flex items-center gap-4 min-w-0">
        <a href="/user/messages" class="md:hidden p-2 text-secondary hover:bg-surface-container-high rounded-full transition-all">
          <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div class="relative">
          <% if (otherUser.avatar) { %>
            <img alt="<%= otherUser.name %>" class="w-10 h-10 rounded-full object-cover" src="<%= otherUser.avatar %>" onerror="this.onerror=null; this.src='/images/default-avatar.png';"/>
          <% } else { %>
            <div class="w-10 h-10 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold">
              <%= (otherUser.name || '?')[0].toUpperCase() %>
            </div>
          <% } %>
        </div>
        <div class="min-w-0">
          <h2 class="font-bold font-headline text-lg leading-tight truncate"><%= otherUser.name %></h2>
          <div class="flex items-center gap-2">
            <span class="text-[10px] text-green-600 font-bold uppercase tracking-widest"><%= getRoleLabel(otherUser.role) %></span>
            <% if (artisanProfile) { %>
              <span class="text-xs text-secondary/40">•</span>
              <a class="text-xs text-primary font-medium hover:underline truncate" href="/user/artisan/<%= otherUser.id %>"><%= artisanProfile.shop_name %></a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <% if (artisanProfile) { %>
          <a href="/user/artisan/<%= otherUser.id %>" class="p-2 text-secondary hover:bg-surface-container-high rounded-full transition-all" aria-label="View artisan profile">
            <span class="material-symbols-outlined">storefront</span>
          </a>
        <% } %>
        <a href="/user/messages" class="hidden md:inline-flex p-2 text-secondary hover:bg-surface-container-high rounded-full transition-all" aria-label="Back to messages">
          <span class="material-symbols-outlined">forum</span>
        </a>
      </div>
    </header>

    <div id="msg-container" class="flex-1 min-h-0 overflow-y-auto p-4 md:p-8">
      <div class="flex flex-col justify-end min-h-full gap-6">
      <% if (threadMessages.length > 0) { %>
        <% const firstMessageDate = new Date(threadMessages[0].created_at); %>
        <div class="flex justify-center">
          <span class="px-4 py-1.5 bg-surface-container text-[11px] font-bold text-on-surface-variant uppercase tracking-[0.1em] rounded-full"><%= Number.isNaN(firstMessageDate.getTime()) ? '' : firstMessageDate.toLocaleDateString() %></span>
        </div>

        <% threadMessages.forEach(function(msg) { %>
          <% if (msg.sender_id === user.id) { %>
            <div class="flex flex-row-reverse items-start gap-3 max-w-[85%] ml-auto">
              <div class="space-y-1 text-right">
                <div class="bg-primary text-on-primary p-4 rounded-2xl rounded-tr-none leading-relaxed text-sm shadow-lg shadow-primary/10">
                  <% if (msg.image_url) { %>
                    <a href="<%= msg.image_url %>" target="_blank" class="block">
                      <img src="<%= msg.image_url %>" alt="Image" class="max-w-[220px] rounded-lg mb-1 cursor-pointer hover:opacity-90 transition-opacity">
                    </a>
                  <% } %>
                  <% if (msg.content) { %><%= msg.content %><% } %>
                </div>
                <span class="text-[10px] text-secondary mr-1"><%= formatMessageTime(msg.created_at) %></span>
              </div>
            </div>
          <% } else { %>
            <div class="flex items-start gap-3 max-w-[85%]">
              <% if (msg.sender_avatar) { %>
                <img alt="<%= msg.sender_name %>" class="w-8 h-8 rounded-full object-cover flex-shrink-0 mt-1" src="<%= msg.sender_avatar %>" onerror="this.onerror=null; this.src='/images/default-avatar.png';"/>
              <% } else { %>
                <div class="w-8 h-8 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center text-xs font-bold flex-shrink-0 mt-1">
                  <%= (msg.sender_name || '?')[0].toUpperCase() %>
                </div>
              <% } %>
              <div class="space-y-1">
                <div class="bg-surface-container-low text-on-surface p-4 rounded-2xl rounded-tl-none leading-relaxed text-sm">
                  <% if (msg.image_url) { %>
                    <a href="<%= msg.image_url %>" target="_blank" class="block">
                      <img src="<%= msg.image_url %>" alt="Image" class="max-w-[220px] rounded-lg mb-1 cursor-pointer hover:opacity-90 transition-opacity">
                    </a>
                  <% } %>
                  <% if (msg.content) { %><%= msg.content %><% } %>
                </div>
                <span class="text-[10px] text-secondary ml-1"><%= formatMessageTime(msg.created_at) %></span>
              </div>
            </div>
          <% } %>
        <% }); %>
      <% } else { %>
        <div class="h-full flex items-center justify-center py-16">
          <p class="text-secondary text-center">No messages yet. Start the conversation.</p>
        </div>
      <% } %>
      </div>
    </div>

    <form id="msg-send-form" action="/user/messages" method="POST" enctype="multipart/form-data" class="border-t border-outline-variant/10 bg-surface/80 backdrop-blur-xl p-4 md:p-6 flex-shrink-0">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="receiver_id" value="<%= otherUser.id %>">
      <input type="file" id="msg-img-input" name="message_image" accept="image/jpeg,image/png,image/webp" class="hidden">
      <div id="msg-img-preview" class="hidden mb-2 flex items-center gap-2 pl-1">
        <img id="msg-img-thumb" src="" alt="Preview" class="h-16 w-16 object-cover rounded-lg border border-outline-variant/20">
        <button type="button" id="msg-img-remove" class="p-1 text-secondary hover:text-error transition-colors">
          <span class="material-symbols-outlined text-lg">close</span>
        </button>
      </div>
      <div class="flex items-center gap-2 md:gap-3">
        <button type="button" id="msg-attach-btn" class="p-2.5 text-secondary hover:text-primary hover:bg-surface-container-low rounded-xl transition-all flex-shrink-0" title="Attach photo">
          <span class="material-symbols-outlined text-xl">attach_file</span>
        </button>
        <input type="text" name="content" placeholder="Type a message…" class="flex-1 bg-surface-container-low border-none rounded-xl px-4 py-3 text-sm focus:ring-0"/>
        <button type="submit" class="px-5 py-3 bg-primary-container text-on-primary-container font-bold rounded-xl hover:bg-primary transition-colors duration-200 inline-flex items-center gap-2">
          <span class="material-symbols-outlined text-base">send</span>
          Send
        </button>
      </div>
    </form>
  </section>
</section>

</main>

<script>
(function() {
  // Auto-scroll messages to bottom on load
  var msgContainer = document.getElementById('msg-container');
  var msgInner = msgContainer ? msgContainer.querySelector('.flex.flex-col.justify-end') : null;
  if (msgContainer) msgContainer.scrollTop = msgContainer.scrollHeight;

  // Attachment button triggers file input
  var attachBtn = document.getElementById('msg-attach-btn');
  var imgInput = document.getElementById('msg-img-input');
  var imgPreview = document.getElementById('msg-img-preview');
  var imgThumb = document.getElementById('msg-img-thumb');
  var imgRemoveBtn = document.getElementById('msg-img-remove');

  if (attachBtn && imgInput) {
    attachBtn.addEventListener('click', function() { imgInput.click(); });
  }

  if (imgInput && imgPreview && imgThumb) {
    imgInput.addEventListener('change', function() {
      var file = imgInput.files[0];
      if (file) {
        imgThumb.src = URL.createObjectURL(file);
        imgPreview.classList.remove('hidden');
      }
    });
  }

  if (imgRemoveBtn && imgInput && imgPreview) {
    imgRemoveBtn.addEventListener('click', function() {
      imgInput.value = '';
      imgPreview.classList.add('hidden');
      imgThumb.src = '';
    });
  }

  var form = document.getElementById('msg-send-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    e.stopImmediatePropagation();
    var contentInput = form.querySelector('input[name="content"]');
    var content = contentInput ? contentInput.value.trim() : '';
    var file = imgInput ? imgInput.files[0] : null;
    if (!content && !file) return;

    var csrf = (form.querySelector('input[name="_csrf"]') || {}).value || '';
    var receiverId = form.querySelector('input[name="receiver_id"]').value;
    var btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;

    var formData = new FormData();
    formData.append('receiver_id', receiverId);
    formData.append('content', content);
    formData.append('_csrf', csrf);
    if (file) formData.append('message_image', file);

    // Optimistic bubble
    var now = new Date();
    var timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    var blobUrl = file ? URL.createObjectURL(file) : null;

    var msgEl = document.createElement('div');
    msgEl.className = 'flex flex-row-reverse items-start gap-3 max-w-[85%] ml-auto';
    var imgHtml = blobUrl
      ? '<a href="' + blobUrl + '" target="_blank" class="block"><img src="' + blobUrl + '" alt="Image" class="max-w-[220px] rounded-lg mb-1 cursor-pointer hover:opacity-90 transition-opacity"></a>'
      : '';
    var textHtml = content
      ? content.replace(/</g,'&lt;').replace(/>/g,'&gt;')
      : '';
    msgEl.innerHTML =
      '<div class="space-y-1 text-right">' +
        '<div class="bg-primary text-on-primary p-4 rounded-2xl rounded-tr-none leading-relaxed text-sm shadow-lg shadow-primary/10">' +
          imgHtml + textHtml +
        '</div>' +
        '<span class="text-[10px] text-secondary mr-1">' + timeStr + '</span>' +
      '</div>';

    if (msgContainer) {
      var target = msgInner || msgContainer;
      target.appendChild(msgEl);
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    if (contentInput) contentInput.value = '';
    if (imgInput) {
      imgInput.value = '';
      if (imgPreview) imgPreview.classList.add('hidden');
      if (imgThumb) imgThumb.src = '';
    }

    fetch('/user/messages', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'x-csrf-token': csrf },
      body: formData
    }).then(function(res) {
      btn.disabled = false;
      if (!res.ok && typeof showToast === 'function') showToast('Failed to send message', 'error');
    }).catch(function() {
      btn.disabled = false;
      if (typeof showToast === 'function') showToast('Error sending message', 'error');
    });
  }, true);
})();
</script>
