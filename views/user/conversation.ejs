<%- include('../partials/header', { title: title }) %>
<div class="container py-4" style="max-width: 700px;">
  <div class="d-flex align-items-center mb-4">
    <a href="/user/messages" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h5 class="mb-0"><%= otherUser.name %></h5>
      <small class="text-muted"><%= artisanProfile ? artisanProfile.shop_name : '' %></small>
    </div>
  </div>
  
  <div class="card shadow-sm border-0 mb-3" style="max-height: 400px; overflow-y: auto;">
    <div class="card-body">
      <% if (messages.length > 0) { messages.forEach(function(msg) { %>
        <div class="mb-3 <%= msg.sender_id === user.id ? 'text-end' : '' %>">
          <div class="d-inline-block p-2 rounded <%= msg.sender_id === user.id ? 'bg-primary text-white' : 'bg-light' %>" style="max-width: 70%;">
            <p class="mb-0"><%= msg.content %></p>
          </div>
          <br><small class="text-muted"><%= new Date(msg.created_at).toLocaleString() %></small>
        </div>
      <% }); } else { %><p class="text-muted text-center">No messages yet. Start the conversation!</p><% } %>
    </div>
  </div>
  
  <form action="/user/messages" method="POST" class="d-flex gap-2">
  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <input type="hidden" name="receiver_id" value="<%= otherUser.id %>">
    <input type="text" name="content" class="form-control" placeholder="Type a message..." required>
    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i></button>
  </form>
</div>
<%- include('../partials/footer') %>
